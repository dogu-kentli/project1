        $(this).find('textarea').trigger('keyup');

    });
</script>

<script>
document.querySelectorAll('.notify-option').forEach(function(checkbox) {
    checkbox.addEventListener('change', function() {
        if (this.checked) {
            // Diğer checkbox'ları kapat
            document.querySelectorAll('.notify-option').forEach(function(other) {
                if (other !== checkbox) {
                    other.checked = false;
                }
            });
        }
    });
});
</script>
<script>
$(document).ready(function() {
    function updateMessage() {
        var template = '{{ text_message_mail }}';

        var no    = $('#input-toplanti-no').val();
        var name  = $('#toplanti_category_id option:selected').text();
        var tarih = $('#input-toplanti-tarihi').val();
        var saat  = $('#input-toplanti-saati').val();

        var msg = template.replace("%s", no || "___")
                          .replace("%s", name || "___")
                          .replace("%s", tarih || "___")
                          .replace("%s", saat || "___");

        $('#form-toplanti .mail-message').val(msg);
    }

    // Normal form değişikliklerini dinle (Kategori, Tarih, Saat için)
    $('#form-toplanti').on('change', 'select, input', function() {
        updateMessage();
    });

    // JavaScript ile input değeri değiştirildiğinde updateMessage'ı tetikleme hilesi
    var originalVal = $.fn.val;
    $.fn.val = function(value) {
        var res = originalVal.apply(this, arguments);
        
        // Eğer değeri değişen element bizim toplantı no inputu ise mesajı güncelle
        if (value !== undefined && this.is('#input-toplanti-no')) {
            updateMessage();
        }
        
        return res;
    };
});
</script>

