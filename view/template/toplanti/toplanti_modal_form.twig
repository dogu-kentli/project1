<form id="form-toplanti" class="row g-3">
    <!-- Toplantı Türü ve Kategorisi -->
    <div class="col-12 col-md-6">
        <label class="form-label fw-bold mb-2" for="toplanti-turu">Toplantı Zamanı</label>
        <select name="toplanti_turu" id="toplanti-turu" class="form-select">
            <option value="1">{{ "Hemen Yapılacak" }}</option>
            <option value="2">{{ "İleri Tarihe Planla" }}</option>
        </select>
    </div>

    <div class="col-12 col-md-6">
        <label class="form-label fw-bold mb-2" for="toplanti_category_id">Kategorisi</label>
        <select name="toplanti_category_id" id="toplanti_category_id" class="form-select">
            <option value="">--Toplantı Kategorisini Seçiniz--</option>
            {% for key,value in category_array %}
            <option value="{{key}}">{{ value }}</option>
            {% endfor %}
        </select>
    </div>

    <!-- Devam Eden Toplantılar -->
    <div class="col-12" id="select-history" style="display:none;">
        <label class="form-label fw-bold mb-2">Devam Eden Toplantılar</label>
        <div class="dropdown">
            <button class="btn btn-light border dropdown-toggle w-100 text-start" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                --Seçim Yapınız--
            </button>
            <ul class="dropdown-menu w-100" aria-labelledby="dropdownMenuButton">
                {% for history in category_history %}
                <li>
                    <a class="dropdown-item" href="javascript:void(0)" onclick="toplanti({{ history.toplanti_id }});">
                        <i class="bi bi-arrow-right-circle text-warning me-1"></i>
                        {{ category_array[history.id] }} (No :{{ history.no }})
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <!-- Toplantı No ve Yeri -->
    <div class="col-12 col-md-6">
        <label class="form-label fw-bold mb-2" for="input-toplanti-no">Toplantı No</label>
        <input type="text" name="toplanti_no" id="input-toplanti-no" class="form-control bg-light-info" placeholder="Toplantı Numarası" />
    </div>

    <div class="col-12 col-md-6">
        <label class="form-label fw-bold mb-2" for="input-yer">Toplantı Yeri</label>
        <input type="text" name="toplanti_yeri" id="input-yer" class="form-control" placeholder="Toplantı Yeri" />
    </div>

    <!-- Konu -->
    <div class="col-12" id="toplanti-baslik" style="display:none;">
        <label class="form-label fw-bold mb-2" for="input-konusu">Konusu</label>
        <input type="text" name="toplanti_konusu" id="input-konusu" class="form-control" placeholder="Toplantı Konusu" />
    </div>

    <!-- Tarih ve Saat -->
    <div class="col-12 col-md-6 toplanti-date-time" style="display:none;">
        <label class="form-label fw-bold mb-2" for="input-toplanti-tarihi">Toplantı Tarihi</label>
        <input type="date" name="toplanti_tarihi" id="input-toplanti-tarihi" class="form-control" value="{{bugun}}" />
    </div>

    <div class="col-12 col-md-6">
        <label class="form-label fw-bold mb-2" for="input-toplanti-saati">Toplantı Saati</label>
        <input type="time" name="toplanti_saati" id="input-toplanti-saati" class="form-control" />
    </div>

    <!-- Gündem -->
    <div class="col-12">
        <label class="form-label fw-bold mb-2" for="input-gundem">Toplantı Gündemi</label>
        <div class="input-group">
            <input type="text" name="toplanti_gundemi" id="input-gundem" class="form-control" value="{{ toplanti_gundemi }}" placeholder="Toplantı Gündemi" />
            <button class="btn btn-outline-secondary button-gundem-add" type="button">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>
        <div class="border rounded p-2 mt-2" id="toplanti-gundem-well" style="height: 150px; overflow: auto;">
            <table id="gundem-filter" class="table table-striped table-sm mb-0">
                <tbody>
                    {% for key,value in gundem_array %}
                    <tr id="gundem-filter-{{ value }}" class="list{{key}}">
                        <td>
                            {{value}}
                            <input type="hidden" name="gundem_array[]" value="{{value}}" />
                        </td>
                        <td class="text-end" style="width:1%;">
                            <button type="button" class="btn btn-danger btn-sm-new"><i class="bi bi-dash-circle"></i></button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Bildirim Seçenekleri -->
    <div class="col-12 col-md-4">
        <div class="form-check">
            <input class="form-check-input notify-option" type="checkbox" onclick="$('#mail-message').toggle()" name="bildirim_mail" id="checkbox-mail">
            <label class="form-check-label fw-bold" for="checkbox-mail">Mail ile bildir</label>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="form-check">
            <input class="form-check-input notify-option" type="checkbox" name="bildirim_sms" id="checkbox-sms" disabled>
            <label class="form-check-label fw-bold" for="checkbox-sms">SMS ile bildir</label>
        </div>
    </div>

    <!-- Mail Mesajı -->
    <div class="col-12" id="mail-message" style="display:none;">
        <label class="form-label fw-bold mb-2" for="mail-message">Mail bilgilendirme metni</label>
        <textarea class="form-control mail-message">{{text_message_mail}}</textarea>
    </div>
</form>


<script>
    function toplanti(toplanti_history_id) {    
        if (toplanti_history_id) {
            $('#form-toplanti-data').load('index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + toplanti_history_id);
            $('#step-1,#buttons').hide();
            $('input[name=\'toplanti_id\']').val(toplanti_history_id);
            $('#step-2').show();
        }
    }
</script>
