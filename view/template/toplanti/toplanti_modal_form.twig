<script>
    function addRows(element) {
        var bolum = element;
        $.ajax({
            url: 'index.php?route=toplanti/toplanti/updatePersonel&user_token={{ user_token }}&bolum=' + bolum + '&toplanti_id=' + $('input[name="toplanti_id"]').val(),
            type: 'post',
            dataType: 'json', // JSON parse için önemli
            success: function(json) {
                $('.alert-dismissible').remove();
                if (json.success) {
                    $('#form-toplanti-data').load(
                        'index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id
                    );
                    $('#alert').empty().append(
                        '<div class="alert border-0 border-success border-start border-2 bg-light-success alert-dismissible fade show py-1">' +
                        '<div class="d-flex align-items-center">' +
                        '<div class="fs-3 text-success"><i class="bi bi-check-circle-fill"></i></div>' +
                        '<div class="ms-3"><div class="text-dynamic">' + $('<div>').text(json.success).html() + '</div></div>' +
                        '</div>' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                        '</div>'
                    );
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }

    let autoSaveTimer;

function autoSave(element, element_bolum, element_kolon, element_id) {
    

    autoSaveTimer = setTimeout(function() {
        let form;

        if (element_bolum === 'temenni') {
            form = $('#form-temenni').serialize();
        } else {
            form = {
                toplanti_id: $('input[name="toplanti_id"]').val(),
                id: element_id,
                kolon: element_kolon,
                veri: $(element).val()
            };
        }

        $.ajax({
            url: 'index.php?route=toplanti/toplanti/autosave&user_token={{ user_token }}&bolum=' + element_bolum,
            type: 'post',
            dataType: 'json',
            data: form,
            beforeSend: function() {
                $('#cover-spin').show(0);
            },
            complete: function() {
                $('#cover-spin').hide(0);
            },
            success: function(json) {
                $('.alert-dismissible').remove();
                if (json.success) {
                    $('#form-toplanti-data').load(
                        'index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id
                    );
                }
                if (json['form']) {
                    location = json['form'];
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }, 1000); // 1 saniye bekle
}



    function deleteRows(element, element_id) {
        if (confirm('Dikkat : Bu işlem geri alınamaz. Bu veriyi silmek istediğinize emin misiniz?') == false) {
            exit();
        }

        var bolum = element;
        var id = element_id;
        $.ajax({
            url: 'index.php?route=toplanti/toplanti/deleteRow&user_token={{ user_token }}&bolum=' + bolum + '&id=' + id + '&toplanti_id=' + $('input[name="toplanti_id"]').val(),
            type: 'post',
            dataType: 'json', // JSON parse için önemli
            success: function(json) {
                if (json.success) {
                    $('#form-toplanti-data').load(
                        'index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id
                    );
                    alertsuccess(json.success);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }
</script>


