<script>
    function addRows(element) {
        var bolum = element;
        $.ajax({
            url: 'index.php?route=toplanti/toplanti/updatePersonel&user_token={{ user_token }}&bolum=' + bolum + '&toplanti_id=' + $('input[name="toplanti_id"]').val(),
            type: 'post',
            dataType: 'json', // JSON parse için önemli
            success: function(json) {
                $('.alert-dismissible').remove();
                if (json.success) {
                    $('#form-toplanti-data').load(
                        'index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id
                    );
                    $('#alert').empty().append(
                        '<div class="alert border-0 border-success border-start border-2 bg-light-success alert-dismissible fade show py-1">' +
                        '<div class="d-flex align-items-center">' +
                        '<div class="fs-3 text-success"><i class="bi bi-check-circle-fill"></i></div>' +
                        '<div class="ms-3"><div class="text-dynamic">' + $('<div>').text(json.success).html() + '</div></div>' +
                        '</div>' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                        '</div>'
                    );
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }

    function autoSave(element, element_bolum, element_kolon, element_id) {
        let form;

        if (element_bolum === 'temenni') {
            form = $('#form-temenni').serialize();
        } else {
            form = {
                toplanti_id: $('input[name="toplanti_id"]').val(),
                id: element_id,
                kolon: element_kolon,
                veri: $(element).val()
            };
        }

        $.ajax({
            url: 'index.php?route=toplanti/toplanti/autosave&user_token={{ user_token }}&bolum=' + element_bolum,
            type: 'post',
            dataType: 'json',
            data: form,
            beforeSend: function() {
                $('#cover-spin').show(0);
            },
            complete: function() {
                $('#cover-spin').hide(0);
            },
            success: function(json) {
                $('.alert-dismissible').remove();
                if (json.success) {
                    $('#form-toplanti-data').load('index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id);
                    //alertsuccess(json.success);
                }

                if (json['form']) {
                    location = json['form'];
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }


    function deleteRows(element, element_id) {
        if (confirm('Dikkat : Bu işlem geri alınamaz. Bu veriyi silmek istediğinize emin misiniz?') == false) {
            exit();
        }

        var bolum = element;
        var id = element_id;
        $.ajax({
            url: 'index.php?route=toplanti/toplanti/deleteRow&user_token={{ user_token }}&bolum=' + bolum + '&id=' + id + '&toplanti_id=' + $('input[name="toplanti_id"]').val(),
            type: 'post',
            dataType: 'json', // JSON parse için önemli
            success: function(json) {
                if (json.success) {
                    $('#form-toplanti-data').load(
                        'index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + json.toplanti_id
                    );
                    alertsuccess(json.success);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }
</script>


<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>

<script>
    $('#button-export').on('click', function() {

        $('.tfooty-button').hide();
        $('#kararlar-row .TK').hide();
        $('#description').find('button').hide();
        $('#cover-spin').fadeIn(200);
        var name = 'toplanti-' + $('.toplanti-no').html() + '.pdf';
        var table = document.querySelector('#toplanti-dokuman');
        var clone = table.cloneNode(true); // Tabloyu kopyala

        html2pdf(clone, {
            margin: [2, 2],
            filename: name,
            image: {
                type: 'png',
                quality: 1.0
            },
            html2canvas: {
                dpi: 600,
                letterRendering: true
            },
            jsPDF: {
                unit: 'mm',
                format: 'a4',
                orientation: 'portrait'
            }
        });

        $('.tfooty-button').show();

        setTimeout(function() {
            $('#cover-spin').fadeOut(200); // 2 saniye sonra spinner'ı gizle

            $('#kararlar-row .TK').show();
            $('#button-save').click();
        }, 2500);



    });
</script>
<script>
    function autoTextHeight(el) {
        el.style.height = 'auto';
        el.style.height = el.scrollHeight + 'px';
    }

    $('#kararlar-row').on('click', 'td', function() {
        var value = $(this).find('span').html();
        $(this).find('span').hide();
        $(this).find('textarea').show();
        $(this).find('textarea').trigger('keyup');

    });
</script>

<script>
    $('#button-toplanti-generate').on('click', function() {
        var $btn = $(this);
        $.ajax({
            url: 'index.php?route=toplanti/toplanti/save&user_token={{ user_token }}&toplanti_no=' + $('input[name=\'toplanti_no\']').val(),
            type: 'post',
            dataType: 'json',
            data: $('#form-toplanti').serialize(),
            beforeSend: function() {
                $('#button-toplanti-generate').buttonanimate('loading');
                $btn.find(".loading").removeClass("visually-hidden");
                $btn.find(".reset").addClass("visually-hidden");
            },
            complete: function() {
                $('#button-toplanti-generate').buttonanimate('reset');
            },
            success: function(json) {
                if (json.error.warning) {
                    $('#alert').prepend(
                        '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-2">' +
                        '<div class="d-flex align-items-center">' +
                        '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
                        '<div class="ms-3"><div class="text-dynamic">' + json.error.warning + '</div></div>' +
                        '</div>' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                        '</div>'
                    );
                }

                if (json.success) {
                    $('#step-1').hide();
                    $('#form-toplanti-data').load('index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}' + '&toplanti_history_id=' + json['toplanti_history_id']);
                    $('#step-2').show();
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    });
</script>

<style>
    .table {
        font-size: 14px;
    }

    .table2 {
        font-size: 12px;
    }

    .input-border-none {
        width: 100%;
        height: 28px;
        border: none;
        outline: none;
        /* Opsiyonel: focus durumundaki çerçeveyi kaldırmak için */
        resize: none;
        /* Yeniden boyutlamayı kapatır */
        overflow: hidden;

    }

    .input-border-none::placeholder {
        color: #545252;
    }

    .textarea-new {
        width: 100%;
        height: 100%;
        border: none;
        outline: none;
        /* Opsiyonel: focus durumundaki çerçeveyi kaldırmak için */
        overflow: hidden;
        /* Taşan içeriği gizle */
        resize: none;
        /* Kullanıcının manuel olarak boyutlandırmasını engelle */
        box-sizing: border-box;
        /* Padding ve border'ı yüksekliğe dahil et */
    }

    .btn-sm-new {
        --bs-btn-padding-y: 0.15rem;
        /* daha dar dikey boşluk */
        --bs-btn-padding-x: 0.35rem;
        /* daha dar yatay boşluk */
        --bs-btn-font-size: 0.65rem;
        /* daha küçük yazı boyutu */
        --bs-btn-border-radius: 0.18rem;
        /* köşeler daha az yuvarlatılmış */
    }
</style>