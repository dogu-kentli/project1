{{ header }}{{ column_left }}
<main id="page-content" class="page-content">
    <div class="row" id="step-1">
        <div class="col-lg-12 mx-auto">
            <div class="card">
                <div class="card-header py-3 bg-transparent">
                    <div class="d-sm-flex align-items-center">
                        <h5 class="mb-2 mb-sm-0">{{ text_form }}</h5>
                        <div class="ms-auto">
                            <button id="button-save" data-toggle="tooltip" title="{{ "Kaydet" }}" class="btn btn-primary btn-sm"><i class="bi bi-save"></i></button>
                            <a href="{{ cancel }}" type="button" data-toggle="tooltip" title="geri Dön" class="btn btn-light border border-dark shadow-sm btn-sm bg-white"><i class="bi bi-arrow-counterclockwise"></i></a>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <form id="form-toplanti" class="row g-2">
                       <div class="row mb-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-bold" for="input-sehir">Toplantı Zamanı</label>
                                <select name="toplanti_turu" id="toplanti-turu" class="form-select bg bg-light-info">
                                    <option value="1">{{ "Hemen Yapılacak" }}</option>
                                    <option value="2">{{ "İleri Tarihe Planla" }}</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-bold" for="input-sehir">Kategoris</label>
                                <select name="toplanti_category_id" id="toplanti_category_id" class="form-select bg bg-light-info">
                                    <option value="">{{ "--Toplantı Kategorisini Seçiniz--" }}</option>
                                    {% for key,value in category_array %}
                                    <option value="{{key}}">{{ value}}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3" id="select-history" style="display:none;">
                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-bold">Devam Eden Toplantılar</label>
                            
                            <div class="dropdown">
                            <button class="btn btn-light border dropdown-toggle w-100 text-start" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                --Seçim Yapınız--
                            </button>
                            <ul class="dropdown-menu w-100" aria-labelledby="dropdownMenuButton">
                                {% for history in category_history %}
                                <li>
                                    <a class="dropdown-item" href="javascript:void(0)" onclick="toplanti({{ history.toplanti_id }});">
                                        <i class="bi bi-arrow-right-circle text-warning me-1"></i>
                                         {{ category_array[history.id] }} (No :{{ history.no }})
                                    </a>

                                </li>
                                {% endfor %}
                            </ul>
                            </div>
                        </div>
                        </div>

                        <!-- Konu -->
                        <div class="row mb-3">
                            <div class="col-12 col-lg-2">
                                <label class="form-label fw-bold" for="input-subject">{{ "Toplantı No" }}</label>
                                <input type="text" name="toplanti_no" value="" placeholder="{{ "Toplantı Numarası" }}" id="inputtoplanti-no" class="form-control bg bg-light-info" />
                            </div>
                        </div>

                        <div class="row mb-3" id="toplanti-baslik" style="display:none;">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-bold" for="input-subject">{{ "Konusu" }}</label>
                                <input type="text" name="toplanti_konusu" value="" placeholder="{{ "Toplantı Konusu" }}" id="input-konusu" class="form-control bg bg-light-info" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-bold" for="input-subject">{{ "Tarihi"}}</label>
                                <input type="date" name="toplanti_tarihi" value="{{bugun}}" placeholder="{{ "Toplantı Tarih" }}" id="input-toplanti-tarihi" class="form-control bg bg-light-info" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="form-label fw-bold" for="input-subject">Toplantı Gündemi</label>
                            <div class="col-12 col-lg-6">
                                <div class="input-group">
                                    <input type="text" name="toplanti_gundemi" value="{{ toplanti_gundemi }}" placeholder="Toplantı Gündemi" id="input-gundem" class="form-control bg bg-light-info" />
                                    <button class="btn btn-outline-secondary button-gundem-add" type="button">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                                <div class="border rounded p-2 mt-2" id="toplanti-gundem-well" style="height: 150px; overflow: auto;">
                                    <table id="gundem-filter" class="table table-striped table-sm mb-0">
                                        <tbody>
                                            {% for key,value in gundem_array %}
                                            <tr id="gundem-filter-{{ value }}" class="list{{key}}">
                                                <td>
                                                    {{value}}
                                                    <input type="hidden" name="gundem_array[]" id="gundem-input-array" value="{{value}}" />
                                                </td>
                                                <td class="text-end" style="width:1%;">
                                                    <button type="button" class="btn btn-danger btn-sm-new"><i class="bi bi-dash-circle"></i></button>
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label fw-bold" for="input-subject">{{ "Toplantı Yeri" }}</label>
                                <input type="text" name="toplanti_yeri" value="" placeholder="{{ "Toplantı Yeri" }}" id="input-yer" class="form-control bg bg-light-info" />
                            </div>
                        </div>

                    </form>

                    <div class="text-start mt-3 pt-2 border-top">
                        <button type="button" id="button-toplanti-generate" class="btn btn-info"><i class="bi bi-save"></i> DEVAM ET</button>
                        <span class="spinner-border spinner-border-sm loading visually-hidden" role="status" aria-hidden="true"></span>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <div id="step-2" class="row" style="display:none;">
        <div class="col-lg-12 mx-auto">
            <div class="card">
                <div id="form-toplanti-data" class="card-body">
                    <div class="text-start mt-3 pt-2 border-top">
                        <button type="button" id="button-toplanti-generate" class="btn btn-info"><i class="bi bi-save"></i> TOPLANTIYI KAYDET</button>
                        <span class="spinner-border spinner-border-sm loading visually-hidden" role="status" aria-hidden="true"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{ footer }}
</main>
<script>
    function toplanti(toplanti_history_id) {
        
        if (toplanti_history_id) {
            $('#form-toplanti-data').load('index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}&toplanti_history_id=' + toplanti_history_id);
            $('#step-1').hide();
            $('input[name=\'toplanti_id\']').val(toplanti_history_id);
            $('#step-2').show();
        }
    }
</script>

