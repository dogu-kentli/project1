      background: #888; /* Kaydırma çubuğunun rengi */
      border-radius: 6px; /* Köşeleri yuvarlatma */
  }
  
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #555; /* Kaydırma çubuğunun üstüne gelindiğinde rengi değişir */
  }
  .input-border-none::placeholder {
    color: #dbdbdb;
  }
  
  .add-line {
      display: inline;
      color: blue;
      cursor: pointer;
  }
    
  .add-line:hover {
      text-decoration: underline;
  }

.karar-plus-icon {
  position: absolute;
  bottom: 2px;
  right: 2px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background-color: #8abaf8ff;
  color: white;
  font-weight: bold;
  text-align: center;
  line-height: 18px;
  font-size: 14px;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 10;
}

td:hover .karar-plus-icon {
  opacity: 1;
}
