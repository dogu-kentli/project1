<script type="text/javascript"><!--
$('#button-onay').on('click', function() {
  if($('input[name=\'sms_code\']').val() == '') {
		$('input[name=\'sms_code\']').css('border-color','red');
		exit();
	}

  $.ajax({
		url: 'index.php?route=tool/sms/smsonay&user_token={{ user_token }}',
		type: 'post',
		dataType: 'json',
		data: 'code=' + $('input[name=\'sms_code\']').val(),
		success: function(json) {
		
			 if (json.success) {
				  $('#modal-sms').modal('hide');
           location = json.success;
			 }else{
				  $('input[name=\'sms_code\']').css('border-color','red');
					$('.countdown-alert').html('<span class="text-danger">' + json.error['code'] + '</span>');
			 }
			
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});
//--></script>


