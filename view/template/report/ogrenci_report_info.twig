<script type="text/javascript"><!--
$('#select-input-il').on('change', function() {
  var element = this;

  if(element.value == '') {
      $('select[name=\'filter_ilce\']').prop('disabled', true);
  }else{
      $('select[name=\'filter_ilce\']').prop('disabled', false);
  }

	$.ajax({
		url: 'index.php?route=setting/autocomplete/sehirautocomplete&user_token={{ user_token }}&sehir_id=' + element.value,
		dataType: 'json',
		success: function(json) {
			html = '<option value="">{{ text_select }}</option>';

			if (json['city'] && json['city'] != '') {
				for (i = 0; i < json['city'].length; i++) {
					html += '<option value="' + json['city'][i]['ilce_id'] + '"';

					if (json['city'][i]['ilce_id'] == '{{ filter_ilce }}' ) {
						html += ' selected="selected"';
					}else{
					   html += '';
					}

					html += '>' + json['city'][i]['name'] + '</option>';
				}
			} else {
				html += '<option value="">{{ text_none }}</option>';
			}

			    $('select[name=\'filter_ilce\']').html(html);
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});
$('select[name=\'filter_il\']').trigger('change');
//--></script>

<script type="text/javascript"><!--
$('input[name=\'filter_name\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=setting/autocomplete/customerautocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['customer_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
	}
});

