{{ header }}{{ column_left }}
<main id="content" class="page-content">
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ breadcrumb.text }}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>
         <div class="ms-auto text-end">
            <button type="button" data-toggle="tooltip" title="{{ "Gelişmiş filtre" }}" class="btn btn-light border border-dark shadow-sm btn-sm bg-white" data-bs-toggle="collapse" data-bs-target="#filter-panel"><i class="bi bi-filter"></i> Filtre 
				<i id="filter-icon" class="bi bi-arrow-down"></i>
			</button>

            <a href="javascript:void(0);" data-toggle="tooltip" title="{{ "Excel dökümü al" }}" id="button-export" class="btn btn-success btn-sm shadow-sm">
                <i class="bi bi-file-earmark-excel"></i> Döküm Al
            </a>
			<button type="button" data-toggle="tooltip" title="{{ "Tüm filtreyi temizle" }}" onclick="location='index.php?route=report/ogrenci_transaction&user_token={{ user_token }}';" class="btn btn-outline-danger btn-sm px-4 me-2">
                Filtre <i class="bi bi-x"></i>
             </button>
        </div>
    </div>

    <div id="ogrenci-filter" class="card shadow-sm border-0">
        <div class="card-body">
            
            <div class="collapse mb-4" id="filter-panel">
                <div class="p-4 border rounded bg-light">
                    <div class="row g-2">
                        <div class="col-md-3">
						 <label class="form-label small fw-bold">Öğrenci Adı</label>
						     <div class="ms-auto position-relative">
							  <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                             <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="Öğrenci Adı" class="form-control ps-4 {% if filter_name %} bg-light-info {% endif %}" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">E-Posta</label>
                            <input type="text" name="filter_email" value="{{ filter_email }}" placeholder="E-posta adresi" class="form-control {% if filter_email %} bg-light-info {% endif %}"  />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">T.C. Kimlik No</label>
                            <input type="text" name="filter_kimlik" value="{{ filter_kimlik }}" placeholder="Kimlik No" class="form-control {% if filter_kimlik %} bg-light-info {% endif %}" />
                        </div>
						 <div class="col-md-3">
                            <label class="form-label small fw-bold">Cinsiyet</label>
                            <select name="filter_gender"id="input-gender"  class="form-select {% if filter_gender %} bg-light-info {% endif %}">
                                <option value="">{{ text_all }}</option>
                                <option value="E" {% if filter_gender == 'E' %} selected {% endif %}>Erkek</option>
                                <option value="K" {% if filter_gender == 'K' %} selected {% endif %}>Bayan</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Grubu</label>
                            <select name="filter_customer_group_id" id="input-customer-group" class="form-select {% if filter_customer_group_id %} bg-light-info {% endif %}">
								<option value="">{{ text_all }}</option>
								{% for customer_group in customer_groups %}
								{% if customer_group.customer_group_id == filter_customer_group_id %}
									<option value="{{ customer_group.customer_group_id }}" selected="selected">{{ customer_group.name }}</option>
								{% else %}
									<option value="{{ customer_group.customer_group_id }}">{{ customer_group.name }}</option>
								{% endif %}
								{% endfor %}
							</select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Durum</label>
                            <select name="filter_status" class="form-select {% if filter_status %} bg-light-info {% endif %}">
                                <option value="">{{ text_all }}</option>
                                 {% for key,value in status_array %}
                                 <option value="{{key}}" {% if filter_status == key and filter_status != '' %} selected="selected" {% endif %}>{{ value }}</option>
						         {% endfor %}
                            </select>
                        </div>

						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ entry_medeni_durumu }}</label>
                            <select name="filter_medeni" id="input-medeni" class="form-select {% if filter_medeni %} bg-light-info {% endif %}">
							   <option value="">{{ text_all }}</option>
                               <option value="2" {% if filter_medeni == 2 %} selected="selected" {% endif %}>{{ text_evli }}</option>
							   <option value="1" {% if filter_medeni == 1 %} selected="selected" {% endif %}>{{ text_bekar }}</option>
                            </select>
                        </div>

						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ entry_barinma }}</label>
                            <select name="filter_barinma" id="input-barinma" class="form-select {% if filter_barinma %} bg-light-info {% endif %}">
							   <option value="">{{ text_all }}</option>
                               <option value="1" {% if filter_barinma == 1 %} selected="selected" {% endif %}>{{ text_ev }}</option>
							   <option value="2" {% if filter_barinma == 2 %} selected="selected" {% endif %}>{{ text_yurt }}</option>
                            </select>
                        </div>
                       
					   {% for custom_field in custom_fields %}
                      {% if custom_field.location_sort == 'account1' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_kgrubu" id="input-custom-field{{ custom_field.custom_field_id }}"  class="form-select {% if filter_kgrubu %} bg-light-info {% endif %}">
							 <option value="">{{ text_all }}</option>
							    {% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id == filter_kgrubu %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Bölge</label>
                            <select name="filter_bolge" onchange="bolge(this, '{{ filter_country }}');" class="form-select {% if filter_bolge %} bg-light-info {% endif %}">
                                <option value="">{{ text_all }}</option>
                                {% for bolge in bolgeler %}
                                <option value="{{ bolge.bolge_id }}" {% if filter_bolge == bolge.bolge_id %}selected{% endif %}>{{ bolge.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Ülke</label>
                            <select name="filter_country" class="form-select {% if filter_country %} bg-light-info {% endif %}" id="filter_country">
                                <option value="">{{ text_all }}</option>
                            </select>
                        </div>
                        <div class="col-md-3">
						 <label class="form-label small fw-bold">Üniversite/</label>
						     <div class="ms-auto position-relative">
							  <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                             <input type="text" name="filter_universite" value="{{ filter_universite}}" id="input-universite" placeholder="Üniversite Adı" class="form-control ps-4 {% if filter_universite %} bg-light-info {% endif %}"  />
							 <input type="hidden" name="f_universite_id" value="{{ f_universite_id }}" id="input-universite" class="form-control"/>
                            </div>
                        </div>

						<div class="col-md-3">
						 <label class="form-label small fw-bold">Fakülte</label>
						     <div class="ms-auto position-relative">
							  <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                             <input type="text" name="filter_fakulte" value="{{ filter_fakulte}}" id="input-fakulte" placeholder="Fakülte Adı" class="form-control ps-4 {% if filter_fakulte %} bg-light-info {% endif %}"  />
							 <input type="hidden" name="f_fakulte_id" value="{{ f_fakulte_id }}" id="input-fakulte" class="form-control"/>
                            </div>
                        </div>

						<div class="col-md-3">
						 <label class="form-label small fw-bold">Bölüm</label>
						     <div class="ms-auto position-relative">
							  <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                             <input type="text" name="filter_bolum" value="{{ filter_bolum}}" placeholder="Bölüm Adı" id="input-name" class="form-control ps-4 {% if filter_bolum %} bg-light-info {% endif %}"  />
							 <input type="hidden" name="f_bolum_id" value="{{ f_bolum_id }}" id="input-bolum" class="form-control"/>
                            </div>
                        </div>

						{% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account5' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_kgrubu" id="input-custom-field{{ custom_field.custom_field_id }}"  class="form-select {% if filter_kgrubu %} bg-light-info {% endif %}">
							 <option value="">{{ text_all }}</option>
							    {% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id == filter_kgrubu %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

					   {% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account14' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_hobi[]" id="input-custom-field{{ custom_field.custom_field_id }}"  class="multiple-select select2-hidden-accessible {% if filter_hobi %} bg-light-info {% endif %}" data-placeholder="İlgi Alanları"  multiple="multiple">
							   <option value="">{{ text_all }}</option>
							    {% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id in filter_hobi %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

                        {% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account7' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_dil[]" id="input-custom-field{{ custom_field.custom_field_id }}"  class="multiple-select select2-hidden-accessible" data-placeholder="İyi derecede bildiği diller"  multiple="multiple">
							    <option value="">{{ text_all }}</option>
								{% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}"  {% if custom_field_value.custom_field_value_id in filter_dil %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

                        {% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account8' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_music" id="input-custom-field{{ custom_field.custom_field_id }}" class="form-select" data-placeholder="Enstrumanlar" >
							    <option value="">{{ text_all }}</option>
								{% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}"  {% if custom_field_value.custom_field_value_id in filter_dil %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

					    <div class="col-md-3">
                            <label class="form-label small fw-bold">{{ entry_akademi }}</label>
                            <select name="filter_akademi" id="input-tez-sertifika" class="form-select {% if filter_akademi %} bg-light-info {% endif %}" id="filter_country">
                                <option value="">{{ text_all }}</option>
								<option value="1" {% if filter_akademi == 1 %} selected="selected" {% endif %} >{{ text_akademi1 }}</option>
								<option value="2" {% if filter_akademi == 2 %} selected="selected" {% endif %} >{{ text_akademi2 }}</option>
			
                            </select>
                        </div>

						{% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account6' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_gorev[]" id="input-custom-field{{ custom_field.custom_field_id }}" class="multiple-select select2-hidden-accessible" data-placeholder="Aldığı Görevler"  multiple="multiple">
							    <option value="">{{ text_all }}</option>
								{% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}"  {% if custom_field_value.custom_field_value_id in filter_gorev %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                       {% endfor %} 

                       {% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account15' %}
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ custom_field.name }}</label>
                            <select name="filter_burs[]" id="input-custom-field{{ custom_field.custom_field_id }}" class="multiple-select select2-hidden-accessible" data-placeholder="Aldığı Burslar"  multiple="multiple">
							    <option value="">{{ text_all }}</option>
								{% for custom_field_value in custom_field.custom_field_value %}
								<option value="{{ custom_field_value.custom_field_value_id }}"  {% if custom_field_value.custom_field_value_id in filter_burs %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>					
								{% endfor %}
                            </select>
                        </div>
						{% endif %}
                        {% endfor %} 
                        
						<div class="col-md-3">
                            <label class="form-label small fw-bold">{{ entry_il }}</label>
                            <select name="filter_il" id="select-input-il" class="single-select {% if filter_il %} bg-light-info {% endif %}">
                                <option value="" selected="selected">{{ text_select }}</option>
					            {% for sehir in sehirler %}
                                <option value="{{sehir.il_id}}" {% if sehir.il_id == filter_il %} selected="selected" {% endif %}/ >{{ sehir.name }}</option>
							    {% endfor %}
			
                            </select>
                        </div>

						<div class="col-md-2">
                            <label class="form-label small fw-bold">{{ entry_ilce}}</label>
                            <select name="filter_ilce" id="select-input-ilce" class="single-select {% if filter_ilce %} bg-light-info {% endif %}"></select>
                        </div>

						<div class="col-md-1 d-flex flex-column justify-content-center align-items-center mb-3">
							<label class="form-label small fw-bold">{{ entry_yetim }}</label>
							<div class="form-check">
								<input class="form-check-input" type="checkbox" name="filter_yetim" value="1" {% if filter_yetim == 1 %} checked{% endif %}>
							</div>
						</div>

						<div class="col-md-1 d-flex flex-column justify-content-center align-items-center mb-3">
							<label class="form-label small fw-bold">{{ entry_hafiz }}</label>
							<div class="form-check">
								<input class="form-check-input" type="checkbox" name="filter_hafiz" value="1" {% if filter_hafiz == 1 %} checked {% endif %}>
							</div>
						</div>

						 <div class="col-md-2">
                            <label class="form-label small fw-bold">Limit</label>
                            <select name="limit" class="form-select {% if limit %} bg-light-info {% endif %}">
								 {% for key,value in limits %}
						   <option value="{{value}}" {% if limit == value %} selected="selected" {% endif %}>{{value}}</option>
						   {% endfor %}
                            </select>
                        </div>

                        <div class="row mt-3 border-top pt-3 align-items-center">
						<!-- Sol taraf: tüm checkboxlar -->
						<div class="col-md-10" style="font-size:13px;">
							<label class="form-label fw-bold">{{ entry_column }}</label>
							<span class="fw-normal">{{ text_column }}</span><br>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column1" value="dogum_tarihi" id="filter_column1"
								{% if filter_column1 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column1">Doğum Tarihi</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column2" value="medeni" id="filter_column2"
								{% if filter_column2 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column2">Medeni Hali</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column3" value="cocuk" id="filter_column3"
								{% if filter_column3 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column3">Çocuk Sayısı</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column4" value="barinma" id="filter_column4"
								{% if filter_column4 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column4">Barınma Ev/Yurt</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column5" value="burs_status" id="filter_column5"
								{% if filter_column5 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column5">Burs Durumu</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column6" value="customer_group_id" id="filter_column6"
								{% if filter_column6 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column6">Öğrenci Grubu</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column7" value="kan_grubu" id="filter_column7"
								{% if filter_column7 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column7">Kan Grubu</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column8" value="dil" id="filter_column8"
								{% if filter_column8 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column8">Bildiği Diller</label>
							</div>

							<div class="form-check form-check-inline">
							<input class="form-check-input checkbox-column" type="checkbox" name="filter_column9" value="adres" id="filter_column9"
								{% if filter_column9 in columns %} checked {% endif %}>
							<label class="form-check-label" for="filter_column9">Adresi</label>
							</div>
						</div>

						<!-- Sağ taraf: filtreleme butonu -->
						<div class="col-md-2 text-end">
							<button type="button" id="button-filter" class="btn btn-info btn-sm px-4">
							<i class="bi bi-search"></i> Filtrele
							</button>
						</div>
						</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive-sm">
               <table class="table table-bordered table-striped align-middle mb-0">
                           <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                        <tr >
                            <th style="width: 50px;" class="text-center">#</th>
                            <th style="width: 180px;">{{ column_name }}</th>
                            <th style="width: 120px;">Ülke/Bölge</th>
                            <th style="width: 220px;">Okul Bilgileri</th>
                            <th style="width: 120px;">{{ column_telefon }} / E-Posta</th>
                            <th style="width: 130px;">{{ column_store }}</th>
                            <th style="width: 80px;" class="text-center">Cinsiyet</th>
                            <th style="width: 110px;" class="text-center">{{ column_status }}</th>
                            <th style="width: 140px;" class="text-center">{{ column_date_added }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if customers %}
                            {% set row_num = row %}
                            {% for customer in customers %}
                            {% set row_num = row_num + 1 %}
                            <tr>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-light text-dark border fw-normal shadow-sm">{{ row_num }}</span>
                                </td>
                                <td class="text-wrap">
                                    <div class="fw-bold text-dark">{{ customer.name }}</div>
                                    
                                </td>
                                <td class="text-wrap small">
                                    <strong>{{ customer.country['name'] }}</strong><br>
                                    <span class="text-muted">{{ customer.bolge['name'] }}</span>
                                </td>
                                <td class="text-wrap small">
                                    <div class="text-primary fw-bold" style="font-size: 0.78rem;">{{ customer.universite['name'] }}</div>
                                    <div class="text-dark">{{ customer.fakulte['name'] }}</div>
                                    <div class="text-muted italic">{{ customer.bolum }}</div>
                                </td>
                                <td class="small">{{ customer.telephone }}
                                <div class="small text-muted">{{ customer.email }}</div>
                                </td>
                                <td class="text-wrap small text-secondary">
                                    {{ customer.store['name'] }}
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold {{ customer.gender == 'E' ? 'text-info' : 'text-danger' }}">
                                        {{ customer.gender == 'E' ? 'E' : 'K' }}
                                    </span>
                                </td>
                                <td class="text-center">
                                    {% if customer.status == 1 %}
                                        <span class="badge bg-success">Aktif</span>
                                    {% elseif customer.status == 2 %}
                                        <span class="badge bg-warning">Mezun</span>
                                    {% else %}
                                        <span class="badge bg-danger">Pasif</span>
                                    {% endif %}
                                </td>
                                <td class="text-center small">
                                    <div class="d-flex align-items-center justify-content-center text-muted">
                                        <i class="bi bi-calendar3 me-2 text-primary" style="font-size: 0.75rem;"></i>
                                        {{ customer.date_added }}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        {% else %}
                            <tr><td colspan="9" class="text-center py-5 text-muted">{{ text_no_results }}</td></tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
        </div>
    </div>
	{{footer}}
</main>



<script type="text/javascript"><!--
$('#button-filter-reset').on('click', function() {
