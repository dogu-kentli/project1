<script type="text/javascript"><!--
function bolge(element, index, filter_country) {
	$.ajax({
		url: 'index.php?route=setting/autocomplete/bolgeautocomplete&user_token={{ user_token }}&bolge_id=' + element.value,
		dataType: 'json',
		beforeSend: function() {
			$('select[name=\'bolge_id\']').prop('disabled', true);
		},
		complete: function() {
			$('select[name=\'bolge_id\']').prop('disabled', false);
		},
		success: function(json) {

			html = '<option value="">{{ text_select }}</option>';

			if (json['country'] && json['country'] != '') {
				for (i = 0; i < json['country'].length; i++) {
					html += '<option value="' + json['country'][i]['country_id'] + '"';

					if (json['country'][i]['country_id'] == '{{ filter_country }}' ) {
						html += 'selected="selected"';
					}else{
					    html += '';
					}

					html += '>' + json['country'][i]['name'] + '</option>';
				}
			} else {
				html += '<option value="">{{ text_none }}</option>';
			}

			$('select[name=\'filter_country\']').html(html);
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
}

$('select[name$=\'filter_bolge\']').trigger('change');
//--></script>

