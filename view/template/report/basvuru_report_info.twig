{{ header }}{{ column_left }}
<main id="universiteler" class="page-content">
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>
        <div class="ms-auto text-end me-3">
            <a href="{{ export }}" data-toggle="tooltip" title="Excel Dökümü" class="btn btn-success border border-success shadow-sm btn-sm" {{disabled}}><i class="bi bi-filetype-xls"></i></a>
            <button type="button" id="button-clear-top" data-toggle="tooltip" title="Filtreyi Temizle" class="btn btn-light border border-dark shadow-sm btn-sm bg-white"><i class="bi bi-filter"></i></button>
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100 shadow-sm">
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-information">
                    <div class="card-body">
                        
                        <div class="p-3 mb-4 border rounded bg-light">
                            <div class="row align-items-center g-3">
                                <div class="col-12 col-lg-3">
                                    <label class="form-label small fw-bold text-secondary">Başvuru Filtresi</label>
                                    <select name="filter_basvuru_id" id="input-basvuru" class="form-select auto-filter shadow-sm">
                                        <option value="">{{ "--Başvuru Seçin--" }}</option>
                                        {% for item in basvuru_list %}
                                        <option value="{{ item.basvuru_id }}" {% if item.basvuru_id == filter_basvuru_id %} selected="selected" {% endif %}>{{ item.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-12 col-lg-7">
                                    <label class="form-label small fw-bold text-secondary">
                                        <i class="bi bi-info-circle me-1"></i>Excel Dökümü Ekstra Sütunlar
                                    </label>
                                    <div class="d-flex flex-wrap gap-3 align-items-center mt-1">
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column1" value="kimlikno" class="form-check-input checkbox-column" id="col1" {% if filter_column1 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col1">Kimlik No</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column2" value="email" class="form-check-input checkbox-column" id="col2" {% if filter_column2 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col2">E-Posta</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column3" value="barinma" class="form-check-input checkbox-column" id="col3" {% if filter_column3 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col3">Barınma</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column4" value="adres" class="form-check-input checkbox-column" id="col4" {% if filter_column4 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col4">Adres</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column5" value="gender" class="form-check-input checkbox-column" id="col5" {% if filter_column5 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col5">Cinsiyet</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="filter_column7" value="store" class="form-check-input checkbox-column" id="col7" {% if filter_column7 in columns %} checked {% endif %}/>
                                            <label class="form-check-label small" for="col7">Derneği</label>
                                        </div>
                                    </div>
                                </div>

                                
                            </div>
                        </div>

                        <div class="table-responsive-sm">
                            <table class="table table-bordered table-striped align-middle mb-0">
                           <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                    <tr >
                                        <th style="width: 50px;" class="text-center">#</th>
                                        <th style="width: 160px;">{{ column_name }}</th>
                                        <th style="width: 130px;">{{ column_basvuru }}</th>
                                        <th style="width: 100px;">Ülke/Bölge</th>
                                        <th style="width: 200px;">{{ column_okul }}</th>
                                        <th style="width: 110px;">{{ column_telefon }}</th>
                                        <th style="width: 130px;">{{ column_store }}</th>
                                        <th style="width: 80px;" class="text-center">Cinsiyet</th>
                                        <th style="width: 110px;">{{ column_status }}</th>
                                        <th style="width: 140px;" class="text-center">{{ column_date_added }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set row_count = row %}
                                    {% if basvurular %}
                                        {% for basvuru in basvurular %}
                                        <tr>
                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-light text-dark border shadow-sm fw-normal">
                                                    {{ row_count }}
                                                </span>
                                            </td>

                                            <td class="text-wrap">
                                                <a href="{{basvuru.edit}}" class="fw-bold text-decoration-none text-primary">
                                                    {{ basvuru.name }}
                                                </a>
                                            </td>

                                            <td class="text-wrap text-secondary">{{ basvuru.isim['name'] }}</td>

                                            <td class="text-wrap small">
                                                <strong>{{ basvuru.country['name'] }}</strong><br>
                                                <span class="text-muted">{{ basvuru.bolge['name'] }}</span>
                                            </td>

                                            <td class="text-wrap small">
                                                <div class="text-primary fw-bold" style="font-size: 0.78rem;">{{ basvuru.universite['name'] }}</div>
                                                <div class="text-dark">{{ basvuru.fakulte['name'] }}</div>
                                                <div class="text-muted small italic">{{ basvuru.bolum['name'] }}</div>
                                            </td>

                                            <td class="text-nowrap small">{{ basvuru.telephone }}</td>

                                            <td class="text-wrap small text-secondary">
                                                {{ basvuru.store['name'] }}
                                            </td>

                                            <td class="text-center">
                                                {% if basvuru.gender == 'Erkek' %}
                                                    <span class="text-info fw-bold">E</span>
                                                {% else %}
                                                    <span class="text-danger fw-bold">K</span>
                                                {% endif %}
                                            </td>

                                            <td class="text-center">
                                                {% if basvuru.status == 0 %}
                                                    <span class="badge bg-light text-danger border border-danger w-100">{{ text_disabled }}</span>
                                                {% elseif basvuru.status == 1 %}
                                                    <span class="badge bg-success w-100">{{ text_enabled }}</span>
                                                {% elseif basvuru.status == 2 %}
                                                    <span class="badge bg-warning text-dark w-100">Mezun</span>
                                                {% else %}
                                                    <span class="badge bg-info text-white w-100">Onay Bekliyor</span>
                                                {% endif %}
                                            </td>

                                            <td class="text-center small">
                                                <div class="d-flex align-items-center justify-content-center mb-1 text-muted">
                                                    <i class="bi bi-calendar3 me-2 text-primary" style="font-size: 0.75rem;"></i>
                                                    {{ basvuru.date_added }}
                                                </div>
                                                {% if basvuru.download %}
                                                    <a href="{{ basvuru.download }}" class="btn btn-outline-secondary btn-sm py-0 px-2" style="font-size: 0.7rem;">
                                                        <i class="bi bi-download"></i> İndir
                                                    </a>
                                                {% endif %}
                                            </td>
                                        </tr>
                                        {% set row_count = row_count + 1 %}
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td class="text-center py-5 text-muted" colspan="10">
                                                <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                                                {{ text_no_results }}
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {{ footer }}
</main>
<script type="text/javascript"><!--
$('.auto-filter').on('change', function() {
   $('#cover-spin').show(0);
	var url = '';
	
	var filter_basvuru_id = $('select[name=\'filter_basvuru_id\']').val();
	
	if (filter_basvuru_id) {
		url += '&filter_basvuru_id=' + encodeURIComponent(filter_basvuru_id);
	}
		
	location = 'index.php?route=report/basvuru_transaction&user_token={{ user_token }}' + url;
});

$('#button-clear').on('click', function() {
	url = 'index.php?route=report/basvuru_transaction&user_token={{ user_token }}';
	location = url;
});

$('.checkbox-column').on('click', function() {
  $.ajax({
		url: 'index.php?route=report/basvuru_transaction/columnFilter&user_token={{ user_token }}', 
		type: 'post',
		dataType: 'json',
		data: $('#form-checkbox').serialize(),
		success: function(json) {
			console.log(json['column1']);
			
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});

});

//--></script> 
<style>
    /* Tablo metinlerinin alt satıra geçmesini garanti eder */
    .text-wrap {
        white-space: normal !important;
        word-wrap: break-word;
        word-break: break-word;
    }
    .table td, .table th {
        padding: 12px 8px !important;
    }
    /* Hover efektini güçlendirir */
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }
</style>

<script type="text/javascript"></script>