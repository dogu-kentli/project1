<script type="text/javascript">
    $('.btn-save').on('click', function() {
        var action = $(this).data('form');
        var customer_id = '{{customer_id}}';

        $.ajax({
            url: 'index.php?route=customer/customer/save&user_token={{ user_token }}&action=' + action + '&customer_id=' + customer_id,
            type: 'post',
            data: $('#form-' + action).serialize(),
            dataType: 'json',

            success: function(json) {
                $('.alert-dismissible').remove();
                $('.page-content').removeClass('is-invalid');

                if (json.error.warning) {
                    alerterror(json.error.warning)
                }

                if (json.error.firstname) {
                    $('input[name=\'firstname\']').addClass('is-invalid');
                }

                if (json.error.lastname) {
                    $('input[name=\'lastname\']').addClass('is-invalid');
                }

                if (json.error.email) {
                    $('input[name=\'email\']').addClass('is-invalid');
                }

                if (json.error.bolge) {
                    $('select[name=\'bolge_id\']').addClass('is-invalid');
                }

                if (json.error.universite) {
                    $('select[name=\'universite_id\']').addClass('is-invalid');
                }

                if (json.error.fakulte) {
                    $('select[name=\'fakulte_id\']').addClass('is-invalid');
                }

                if (json.error.bolum) {
                    $('select[name=\'bolum_id\']').addClass('is-invalid');
                }

                if (json.error.country) {
                    $('select[name=\'country_id\']').addClass('is-invalid');
                }

                if (json.error.customer_group) {
                    $('select[name=\'customer_group_id\']').addClass('is-invalid');
                }

                if (json.error.dogum_tarihi) {
                    $('input[name=\'dogum_tarihi\']').addClass('is-invalid');
                }

                if (json.error.gender) {
                    $('select[name=\'gender\']').addClass('is-invalid');
                }

                if (json.error.kimlikno) {
                    $('input[name=\'kimlikno\']').addClass('is-invalid');
                }

                if (json.error.telephone) {
                    $('input[name=\'telephone\']').addClass('is-invalid');
                }

                if (json.success) {
                    alertsuccess(json.success);
                }
            },

            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    });
</script>

<script>
    function remove(element, bolum, id) {
        if (confirm('Dikkat : Bu işlem geri alınamaz. Bu veriyi silmek istediğinize emin misiniz?') == false) {
            exit();
        }

        $.ajax({
            url: 'index.php?route=customer/customer/remove&user_token={{ user_token }}&bolum=' + bolum + '&id=' + id,
            type: 'post',
            dataType: 'json',
            success: function(json) {

                if (json.error.warning) {
                    alerterror(json.error.warning);
                }

                if (json.success) {
                    alertsuccess(json.success);

                    $(element).closest('tr').remove();
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });

    }
</script>