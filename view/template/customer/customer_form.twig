{{ header }}{{ column_left }}
<main id="page-content" class="page-content">

    <div class="row">
        <div class="col-lg-12 mx-auto">
            <div class="card">
                <div class="card-header py-3 bg-transparent">
                    <div class="d-sm-flex align-items-center">
                        <h5 class="mb-2 mb-sm-0">ÖĞRENCİ BİLGİ FORMU</h5>
                        <div class="ms-auto">
                            <a href="{{ cancel }}" type="button" data-toggle="tooltip" title="geri Dön" class="btn btn-light border border-dark shadow-sm btn-sm bg-white"><i class="bi bi-arrow-counterclockwise"></i></a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-12 col-sm-12">
                            <div class="accordion" id="accordionExample">
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading-kisisel">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-kisisel" aria-expanded="true" aria-controls="collapse-kisisel">
                                            <i class="bi bi-person me-2"></i> KİŞİSEL BİLGİLER
                                        </button>
                                    </h2>
                                    <div id="collapse-kisisel" class="accordion-collapse collapse show" aria-labelledby="heading-kisisel" data-bs-parent="#accordionExample">
                                        <form id="form-kisisel">
                                            <div class="accordion-body">
                                                <div class="p-4 border rounded">
                                                    <div class="profile-avatar text-center">
                                                        <a href="javascript:void(0);" id="thumb-image" class="thumbnail"><img src="{{thumb}}" id="thumb-img" class="border border-primary border-primary rounded-lg shadow" width="120" height="120" data-toggle="tooltip" title="Resim eklemek için tıklayın" class="rounded-circle"></a>
                                                        <input type="hidden" name="image" value="{{ image }}" id="input-image" />
                                                    </div>

                                                    <div class="col-12 d-flex align-items-center justify-content-around mt-5 gap-3" {% if store_id !=0 %} style="display:none;" {% endif %}>

                                                        <div class="form-check form-switch">
                                                            <label class="form-check-label" for="flexSwitchCheckDefault">Projeli Öğrenci</label>
                                                            <input class="form-check-input" name="projeli" data-toggle="tooltip" title="{{ 'Bu öğrenci İHH projeli öğrencisi ise butonu aktif edin.' }}" type="checkbox" value="1" {% if projeli %} checked {% endif %} id="flexSwitchCheckDefault">
                                                        </div>

                                                    </div>
                                                    <hr>
                                                    <div class="row g-3">
                                                        <div class="col-12 col-md-6">
                                                            {% if status == 1 %} {% set color = 'success' %} {% endif %}
                                                            {% if status == 0 %} {% set color = 'secondary' %} {% endif %}
                                                            {% if status == 2 %} {% set color = 'warning' %} {% endif %}
                                                            {% if status == 3 %} {% set color = 'info' %} {% endif %}
                                                            <label class="form-label">{{entry_status}} </label>
                                                            <select name="status" class="form-select">
                                                                <option value="1" {% if status == 1 %} selected {% endif %}><span class="text-success">{{ text_enabled }}</span></option>
                                                                <option value="0" {% if status == 0 %} selected {% endif %}>{{ text_disabled }}</option>
                                                                <option value="2" {% if status == 2 %} selected {% endif %}>{{ text_end }}</option>
                                                                <option value="3" {% if status == 3 %} selected {% endif %}>{{ text_beklemede }}</option>
                                                            </select>
                                                        </div>

                                                        <div class="col-12 col-md-6 ">
                                                            <label class="form-label">{{ entry_customer_group }}</label>
                                                            <select name="customer_group_id" id="input-customer-group" class="form-select">
                                                                <option value="" selected="selected">{{ text_select }}</option>
                                                                {% for customer_group in customer_groups %}
                                                                {% if customer_group.customer_group_id != 6 %}
                                                                {% if customer_group.customer_group_id == customer_group_id %}
                                                                <option value="{{ customer_group.customer_group_id }}" selected="selected">{{ customer_group.name }}</option>
                                                                {% else %}
                                                                <option value="{{ customer_group.customer_group_id }}">{{ customer_group.name }}</option>
                                                                {% endif %}
                                                                {% endif %}
                                                                {% endfor %}
                                                            </select>
                                                        </div>


                                                        <div class="col-md-6">
                                                            <label for="validationServer02" class="form-label">{{entry_firstname}}</label>
                                                            <input type="text" class="form-control" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label for="validationServer01" class="form-label">{{ entry_lastname }}</label>
                                                            <input type="text" class="form-control" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" fhalid="validationServer01" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>


                                                        <div class="col-md-6">
                                                            <label for="validationServer01" class="form-label">{{ entry_email }}</label>
                                                            <input type="text" class="form-control" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email" fhalid="validationServer01" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>

                                                        <div class="col-md-6">
                                                            <label for="validationServer02" class="form-label">{{ entry_telephone }}</label>
                                                            <input type="text" class="form-control" name="telephone" maxlength="15" value="{{ telephone }}" placeholder="{{ entry_telephone }}" id="input-telephone" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>

                                                        <div class="col-md-6">
                                                            <label for="validationServer02" class="form-label">{{ entry_kimlikno }}</label>
                                                            <input type="text" class="form-control" name="kimlikno" value="{{ kimlikno }}" placeholder="{{ entry_kimlikno }}" id="input-kimlikno" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>

                                                        <div class="col-md-6">
                                                            <label for="validationServer02" class="form-label">{{ entry_dogum_tarihi }}</label>
                                                            <input type="date" class="form-control" name="dogum_tarihi" value="{{ dogum_tarihi }}" placeholder="{{ entry_dogum_tarihi }}" id="input-dogum-tarihi" required="">
                                                            <div class="valid-feedback"></div>
                                                        </div>


                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{entry_gender}}</label>
                                                            <select name="gender" class="form-select" id="validationServer04" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                <option value="E" {% if gender == "E" %} selected {% endif %}>{{ text_bay}}</option>
                                                                <option value="K" {% if gender == "K" %} selected {% endif %}>{{ text_bayan}}</option>
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{"Barınma"}}</label>
                                                            <select name="barinma" class="form-select" id="validationServer04" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                <option value="1" {% if barinma == 1 %} selected {% endif %}>{{ "Ev"}}</option>
                                                                <option value="2" {% if barinma == 2 %} selected {% endif %}>{{ "Yurt"}}</option>
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{"Medeni Hali"}}</label>
                                                            <select name="medeni_durumu" class="form-select" id="validationServer04" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                <option value="1" {% if medeni_durumu == 1 %} selected {% endif %}>{{ "Bekar"}}</option>
                                                                <option value="2" {% if medeni_durumu == 2 %} selected {% endif %}>{{ "Evli"}}</option>
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer02" class="form-label">{{ entry_cocuk }}</label>
                                                            <input type="number" class="form-control" name="cocuk" value="{{ cocuk }}" placeholder="{{ entry_cocuk }}" id="input-cocuk">
                                                            <div class="valid-feedback"></div>
                                                        </div>


                                                        {% for custom_field in custom_fields %}
                                                        {% if custom_field.location_sort == 'account1' %}
                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" name="medeni_durumu" class="form-label">{{ custom_field.name }}</label>
                                                            <select class="form-select" name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                                {% if account_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == account_custom_field[custom_field.custom_field_id] %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}" selected="selected">{{ custom_field_value.name }}</option>
                                                                {% else %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}">{{ custom_field_value.name }}</option>
                                                                {% endif %}
                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        {% endif %}
                                                        {% endfor %}

                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" class="form-label">{{"Bölgesi"}}</label>
                                                            <select class="form-select" name="bolge_id" id="input-bolge" onchange="bolge(this, '{{ bolge_id }}');" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for bolge in bolgeler %}
                                                                <option value="{{ bolge.bolge_id }}" {% if bolge.bolge_id == bolge_id %} selected="selected" {%  endif %}>{{ bolge.name }}</option>
                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" class="form-label">{{ entry_country }}</label>
                                                            <select class="form-select" name="country_id" id="input-country" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for bolge in bolgeler %}
                                                                <option value="{{ bolge.bolge_id }}" {% if bolge.bolge_id == bolge_id %} selected="selected" {%  endif %}>{{ bolge.name }}</option>
                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-6">
                                                            <label for="validationServer04" class="form-label">{{ entry_sehir }}</label>
                                                            <select class="form-select" name="sehir_id" onchange="sehir(this, '{{ city_id }}');" aria-describedby="validationServer04Feedback" required="">
                                                                {% for sehir in sehirler %}
                                                                <option value="{{ sehir.il_id }}" {% if sehir.il_id == sehir_id %} selected="selected" {% endif %}>{{ sehir.name }}</option>
                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-6">
                                                            <label for="validationServer04" class="form-label">{{ entry_ilce }}</label>
                                                            <select class="form-select" name="city_id" aria-describedby="validationServer04Feedback" required="">

                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12">
                                                            <label class="form-label">Adres</label>
                                                            <textarea class="form-control" name="adres" placeholder="{{ entry_address_1 }}" id="input-address-1" rows="2" cols="4">{{ adres }}</textarea>
                                                        </div>

                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" class="form-label">{{ entry_universite }}</label>
                                                            <select name="universite_id" onchange="universite(this, '{{ fakulte_id }}');" class="single-select">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for univer in universites %}
                                                                <option value="{{ univer.universite_id }}" {% if universite_id == univer.universite_id %} selected="selected" {% endif %}>{{ univer.name }}</option>
                                                                {% endfor %}
                                                            </select>

                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" class="form-label">{{ entry_fakulte }}</label>
                                                            <select name="fakulte_id" id="input-fakulte" onchange="fakulte(this, '{{ bolum_id }}');" class="single-select">
                                                                {% for fakulte in fakultes %}
                                                                <option value="{{ fakulte.fakulte_id }}" {% if fakulte.fakulte_id == fakulte_id %} selected="selected" {% endif %}>{{ fakulte.name }}</option>
                                                                {% endfor %}
                                                            </select>

                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>

                                                        <div class="col-12 col-md-4">
                                                            <label for="validationServer04" class="form-label">{{ entry_bolum }}</label>
                                                            <select name="bolum_id" id="select-bolum" class="single-select"></select>

                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                            <input type="text" name="bolum" value="{{ bolum }}" placeholder="{{ entry_bolum }}" id="input-bolum" class="form-control" />
                                                        </div>
                                                        {% for custom_field in custom_fields %}
                                                        {% if custom_field.location_sort == 'account5' %}
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{"Sınıfı"}}</label>
                                                            <select class="form-select" name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if account_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == account_custom_field[custom_field.custom_field_id] or custom_field_value.custom_field_value_id == sinif %} selected {% endif %}>{{ custom_field_value.name }}</option>

                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        {% endif %}
                                                        {% endfor %}

                                                        {% for custom_field in custom_fields %}
                                                        {% if custom_field.location_sort == 'account11' %}
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{ custom_field.name }}</label>
                                                            <select class="form-select" name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if account_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == account_custom_field[custom_field.custom_field_id] %} selected {% endif %}>{{ custom_field_value.name }}</option>

                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        {% endif %}
                                                        {% endfor %}

                                                        {% for custom_field in custom_fields %}
                                                        {% if custom_field.location_sort == 'account12' %}
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{ custom_field.name }}</label>
                                                            <select class="form-select" name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if account_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == account_custom_field[custom_field.custom_field_id] %} selected {% endif %}>{{ custom_field_value.name }}</option>

                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        {% endif %}
                                                        {% endfor %}

                                                        {% for custom_field in custom_fields %}
                                                        {% if custom_field.location_sort == 'account13' %}
                                                        <div class="col-12 col-md-3">
                                                            <label for="validationServer04" class="form-label">{{ custom_field.name }}</label>
                                                            <select class="form-select" name="custom_field[{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" aria-describedby="validationServer04Feedback" required="">
                                                                <option value="">{{ text_select }}</option>
                                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if account_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == account_custom_field[custom_field.custom_field_id] %} selected {% endif %}>{{ custom_field_value.name }}</option>

                                                                {% endfor %}
                                                            </select>
                                                            <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                                        </div>
                                                        {% endif %}
                                                        {% endfor %}
                                                        <div class="col-12">
                                                            <button class="btn btn-primary btn-save btn-sm" data-form="kisisel" type="button"><i class="bi bi-save" aria-label="Kaydet"></i> {{button_save}}</button>
                                                        </div>
                                                    </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading-aile">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-aile" aria-expanded="false" aria-controls="collapse-aile">
                                    <i class="bi bi-people me-2"></i> AİLE BİLGİLERİ VE DİĞER BİLGİLER
                                </button>
                            </h2>
                            <div id="collapse-aile" class="accordion-collapse collapse" aria-labelledby="heading-aile" data-bs-parent="#accordionExample">
                                <div class="accordion-body">
                                    <form id="form-aile">
                                        <div class="row g-3">
                                            <div class="col-md-3">
                                                <label for="validationServer02" class="form-label">Anne Adı</label>
                                                <input type="text" class="form-control" name="anne_adi" value="{{anne_adi}}" placeholder="{{ "Annenizin Adı" }}" id="input-firstname" required="">
                                                <div class="valid-feedback"></div>
                                            </div>
                                            <div class="col-md-3">
                                                <label for="validationServer01" class="form-label">{{ entry_lastname }}</label>
                                                <input type="text" class="form-control" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" fhalid="validationServer01" required="">
                                                <div class="valid-feedback"></div>
                                            </div>

                                            <div class="col-12 col-md-3">
                                                <label for="validationServer04" class="form-label">{{ "Çalışma Durumu" }}</label>
                                                <select class="form-select" name="is_durumu1" aria-describedby="validationServer04Feedback" required="">
                                                    <option value="1" {% if is_durumu1 == 1 %} selected="selected" {% endif %}>{{ "Çalışıyor" }}</option>
                                                    <option value="0" {% if is_durumu1 != 1 %} selected="selected" {% endif %}>{{ "Çalışmıyor" }}</option>
                                                </select>
                                                <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                            </div>

                                            <div class="col-12 col-md-3">
                                                <label for="validationServer04" class="form-label">{{ "Sağlık Durumu" }}</label>
                                                <select class="form-select" name="saglik_durumu1" aria-describedby="validationServer04Feedback" required="">
                                                    <option value="1" {% if saglik_durumu1 == 1 %} selected="selected" {% endif %}>{{ "Sağ" }}</option>
                                                    <option value="0" {% if saglik_durumu1 != 1 %} selected="selected" {% endif %}>{{ "Vefat" }}</option>
                                                </select>
                                                <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                            </div>

                                            <div class="col-md-3">
                                                <label for="validationServer02" class="form-label">Baba Adı</label>
                                                <input type="text" class="form-control" name="baba_adi" value="{{baba_adi}}" placeholder="{{ "Baba Adı" }}" id="input-baba-adi" required="">
                                                <div class="valid-feedback"></div>
                                            </div>
                                            <div class="col-md-3">
                                                <label for="validationServer01" class="form-label">{{ "Baba Soyadı" }}</label>
                                                <input type="text" class="form-control" name="baba_soyadi" value="{{ baba_soyadi }}" placeholder="{{ "Baba Soyadı" }}" id="input-baba-soyadi" fhalid="validationServer01" required="">
                                                <div class="valid-feedback"></div>
                                            </div>

                                            <div class="col-12 col-md-3">
                                                <label for="validationServer04" class="form-label">{{ "Çalışma Durumu" }}</label>
                                                <select class="form-select" name="is_durumu2" aria-describedby="validationServer04Feedback" required="">
                                                    <option value="1" {% if is_durumu2 == 1 %} selected="selected" {% endif %}>{{ "Çalışıyor" }}</option>
                                                    <option value="0" {% if is_durumu2 != 1 %} selected="selected" {% endif %}>{{ "Çalışmıyor" }}</option>
                                                </select>
                                                <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                            </div>

                                            <div class="col-12 col-md-3">
                                                <label for="validationServer04" class="form-label">{{ "Sağlık Durumu" }}</label>
                                                <select class="form-select" name="saglik_durumu2" aria-describedby="validationServer04Feedback" required="">
                                                    <option value="1" {% if saglik_durumu2 == 1 %} selected="selected" {% endif %}>{{ "Sağ" }}</option>
                                                    <option value="0" {% if saglik_durumu2 != 1 %} selected="selected" {% endif %}>{{ "Vefat" }}</option>
                                                </select>
                                                <div id="validationServer04Feedback" class="invalid-feedback">Bu alan boş bırakılamaz.</div>
                                            </div>

                                            <div class="col-md-3">
                                                <label for="validationServer01" class="form-label">{{ "Kardeş Sayısı" }}</label>
                                                <input type="number" class="form-control" name="kardes_sayisi" value="{{kardes_sayisi}}" placeholder="{{ "Kardeş Sayısı" }}" fhalid="validationServer01" required="">
                                                <div class="valid-feedback"></div>
                                            </div>

                                            <div class="col-12">
                                                <div class="form-check form-switch">
