<div class="row">
  {% if cart_image %}
    <div class="col-12 text-center mb-3">
      <img src="{{ cart_image }}" class="img-fluid" alt="Kart Görseli" style="max-width:575px;">
    </div>
  {% endif %}

  {% if onay == 1 %}
    <div class="col-12 text-center mb-3">
      <i class="fa fa-check-circle fa-2x text-success"></i>
    </div>
  {% else %}
    <div class="col-12 mb-3">
      <strong>Not :</strong>
      <a href="{{ profile }}" target="_blank">profil bilgilerini</a> inceledikten sonra
      <strong>Kartı Onaylayın</strong>. Eksik bilgi halinde bildirimde bulunun.
    </div>
  {% endif %}

  {% if onay != 1 and text %}
    <div class="col-12 mb-3">
      <span class="fw-bold">Bildirim :</span> {{ text }}
    </div>
  {% endif %}
</div>

<div id="modal-message" class="mb-3"></div>

<div class="mb-3">
  <textarea name="text" rows="4" class="form-control d-none" placeholder="Lütfen kısaca iptal nedenini yazınız."></textarea>
</div>

