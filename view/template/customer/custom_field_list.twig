{{ header }}{{ column_left }}
<main id="custom-field" class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

        <div class="ms-auto text-end me-3">
         {% if level %}
         <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Ekle</a>
         <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger btn-sm" onclick="confirm('{{ text_confirm }}') ? $('#form-information').submit() : false;"><i class="bi bi-trash"></i> Sil</button>
        {% endif %}
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-12 me-auto">
                            <div class="ms-auto position-relative">
                                <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                                <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ "Aramak için başlık yazınız." }}" id="input-universite"  class="form-control auto-filter form-control-lg ps-4">
                               
                            </div>
                        </div>

                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-custom-field">
                    <div class="card-body">

                        <div class="table-responsive-sm">
                            <table class="table table-striped align-middle mb-0">
                                   <thead class="table-light">
                                   <tr>
                                    <th style="width: 1px;" class="text-center">
                                      <input type="checkbox" class="form-check-input" onclick="$('input[name*=\'selected\']').trigger('click');"/>
                                    </th>
                                    <th class="text-left">{{ column_name }}</th>
                                    <th class="text-left">{{ column_location }}</th>
                                    <th class="text-left">{{ column_type }}</th>
                                    <th class="text-right">{{ column_sort_order }}</th>
                                    <th style="width: 1px;" class="text-right">{{ column_action }}</th>
                                  </tr>
                                   </thead>
                                  <tbody>
                {% if custom_fields %}
                  {% for custom_field in custom_fields %}
                    <tr>
                      <td class="text-center">
                          <input type="checkbox" class="form-check-input" name="selected[]" value="{{ custom_field.custom_field_id }}"/>
                       </td>
                      <td class="text-left">{{ custom_field.name }}</td>
                      <td class="text-left">{{ custom_field.location }}</td>
                      <td class="text-left">{{ custom_field.type }}</td>
                      <td class="text-right">{{ custom_field.sort_order }}</td>
                      <td class="text-right"><a href="{{ custom_field.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-info btn-sm"><i class="bi bi-pencil"></i></a></td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr>
                    <td class="text-center" colspan="6">{{ text_no_results }}</td>
                  </tr>
                {% endif %}
              </tbody>
                                 </table>
                        </div>

                        <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
                </form>
            </div>
        </div>


    </div>

    {{footer}}
</main>
<script type="text/javascript"><!--
$('#universiteler .auto-filter').on('change', function() {
	url = 'index.php?route=universite/universite&user_token={{ user_token }}'; 

	if ($('input[name=\'filter_universite\']').val()) {
		url += '&filter_universite=' + encodeURIComponent($('input[name=\'filter_universite\']').val());
	}	
	
   $('#cover-spin').show(0);

	 location = url;
});

$('#button-clear').on('click', function() {
	url = 'index.php?route=universite/universite&user_token={{ user_token }}'; 

   $('#cover-spin').show(0);

	location = url;
});
//--></script>
<script type="text/javascript"><!--
$('input[name=\'filter_universite\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=universite/universite/autocomplete&user_token={{ user_token }}&filter_universite=' + encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
         
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['universite_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		 $('input[name=\'filter_universite\']').val(item['label']);
     $('input[name=\'filter_universite\']').trigger('change');
	}
});
//--></script>
<script>
var error_warning = '{{error_warning}}';
var success = '{{success}}';
$(document).ready(function() {
  if(error_warning) {
    alerterror(error_warning);
  }

  if (success) {
   alertsuccess(success);
  }
});
</script>