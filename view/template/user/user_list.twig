<script>
    function permissionFunction(name, user_id, user_group_id) {
        $('input[name=\'user_id\']').val(user_id);
        $('input[name=\'name\']').val(name);
        $('#data-permission').load('index.php?route=user/user/datapermission&user_token={{ user_token }}&user_id=' + user_id + '&user_group_id=' + user_group_id);
        $('.dropdown-item').removeClass('bg-light-info');
        $('.dropdown-item').find('i').remove();
        $('#modal-permission').modal('show');

    }
</script>
<script>
    var error_warning = '{{error_warning}}';
    var success = '{{success}}';
    $(document).ready(function() {
        if (error_warning) {
            alerterror(error_warning);
        }

        if (success) {
            alertsuccess(success);
        }
    });
</script>


<style>
    .group-box {
        display: inline-block;
        padding: 4px 8px;
        border: 1px solid #000000;
        /* Bootstrap primary rengi */
        border-radius: 4px;
        background: linear-gradient(to right, #e9f5ff, #fdfdfd);
        box-shadow: 0 2px 6px rgba(0, 123, 255, 0.2);
        font-weight: 500;
        color: #000000;
        transition: all 0.3s ease;
    }

    .group-box:hover {
        background: #007bff;
        color: #fff;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
    }

    /* Optgroup başlıklarının font boyutu */
    .form-select optgroup {
        font-size: 14px;
        /* istediğin boyutu yaz */
        font-weight: 600;
        /* opsiyonel: biraz kalın olsun */
        color: #2c3e50;
        /* opsiyonel: daha koyu renk */
    }
</style>