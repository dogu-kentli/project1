<script>
    $('input[name=\'filter_store\']').autocomplete({
        'source': function(request, response) {
            $.ajax({
                url: 'index.php?route=setting/autocomplete/storeautocomplete&user_token={{ user_token }}&filter_store=' + encodeURIComponent(request),
                dataType: 'json',
                success: function(json) {
                    json.unshift({
                        name: '--Tümünü Seç--',
                        value: '',
                    });
                    
                    response($.map(json, function(item) {
                        return {
                            label: item['name'],
                            value: item['store_id']
                        }
                    }));
                }
            });
        },
        'select': function(item) {
            $('input[name=\'filter_store\']').val(item['label']);
            $('input[name=\'filter_store_id\']').val(item['value']);
            $('input[name=\'filter_store_id\']').trigger('change');
        }
    });
</script>
<script type="text/javascript">
    $('.dropdown-item').on('click', function() {
        
        var select = $(this);
        var rota = select.data('value');
        var veri = select.data('for');
        var text = select.text();
        select.addClass('bg-light-info');
        // Başına ikon eklemek için prepend kullan
        select.prepend('<i class="bi bi-check-circle text-priyary me-1"></i>');

        // Eğer zaten bu rota için satır varsa ekleme
        if ($('#data-permission tbody tr[data-rota="' + rota + '"]').length > 0) {
            return; // çık
        }

        if (rota == '') {
            return; // çık
        }

        var row = `
    <tr data-rota="${rota}">
        <td class="fw-bold text-start">${text}</td>
        <td class="text-center">
            <input class="form-check-input" type="checkbox" name="permission[access][]" value="${rota}" checked="checked">
        </td>
        <td class="text-center">
            <input class="form-check-input ${veri}" type="checkbox" name="permission[modify][]" value="${rota}" >
        </td>
        <td class="text-center" style="width:1%;">
            <i class="bi bi-x-circle remove-row text-danger" title="Sil"></i>
        </td>
    </tr>
    `;

        $('#data-permission tbody').append(row);

        var lastRow = $('#data-permission tbody tr:last')[0];

        lastRow.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest'
        });
        lastRow.addClass('flash-once');
    });

    // Silme işlemi
    $('#data-permission').on('click', '.remove-row', function() {
        var row = $(this).closest('tr');
        var rota = row.data('rota');
        row.remove();

        var $option = $('.permission-option[data-value="' + rota + '"]');

        if ($option.length) {
            $option.removeClass('bg-light-info');
            $option.find('i').remove();
        }
    });
</script>
