{{ header }}{{ column_left }}
<main id="page-content" class="page-content">
    <div class="row">
        <div class="col-lg-12 mx-auto">
            <div class="card">
                <div class="card-header py-3 bg-transparent">
                    <div class="d-sm-flex align-items-center">
                        <h5 class="mb-2 mb-sm-0">Kullanıcı Grup İzinleri</h5>
                        <div class="ms-auto">
                            <button type="button" data-bs-toggle="tooltip" onclick="$('#form-user-group').submit();" title="{{ button_save }}" class="btn btn-primary btn-sm">
                                <i class="bi bi-save"></i>
                            </button>
                            <a href="{{ cancel }}" type="button" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light border border-dark shadow-sm bg-white btn-sm">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-user-group" class="form-horizontal">
                        <div class="col-sm-12">
                            <div class="mb-3 row">
                                <label class="col-2 col-form-label fw-bold" for="input-name">{{ "Kullanıcı Grup Adı" }}</label>
                                <div class="col-sm-4">
                                    <input type="text" name="name" value="{{ name }}" placeholder="{{ "Kullanıcı grup adı" }}" id="input-name" class="form-control bg-light" />
                                    {% if error_name %}
                                    <div class="text-danger">{{ error_name }}</div>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Accordion Permissions -->
                            <div class="permissions-container ">
                             <div class="accordion " id="accordionPermissions">
                                    {% set row = 0 %}
                                    {% for group, items in permissions %}
                                    {% if items|length > 0 %}
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="heading{{ row }}">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ row }}" aria-expanded="false" aria-controls="collapse{{ row }}">
                                                <i class="bi bi-folder"></i>&nbsp; {{ group }}
                                            </button>
                                        </h2>
                                        <div id="collapse{{ row }}" class="accordion-collapse collapse" aria-labelledby="heading{{ row }}" data-bs-parent="#accordionPermissions">
                                            <div class="accordion-body p-3">
                                                <table class="table table-striped align-middle mb-2">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th style="width:60%;"><h6>Bölüm Başlığı</h6></th>
                                                            <th class="text-center" style="width:10%;"><h6>Görüntüleme</h6></th>
                                                            <th class="text-center" style="width:10%;"><h6>Değiştirme</h6></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        {% for permission in items %}
                                                        <tr {% if permission.permission == 'setting/autocomplete' %} class="d-none" {% endif %}>
                                                            <td >
                                                                <a href="javascript:void(0)" >
                                                                    <h6 class="text-muted" >{{ permission.title }}</h6>
                                                                    <small class="text-muted">{{permission.heading_title_description}}</small>
                                                                    <input type="hidden" name="permission[title][]" value="{{ permission.title }}">
                                                                </a>
                                                            </td>
                                                            <td class="text-center">
                                                                <input type="checkbox" data-bs-toggle="tooltip" title="{{ "Bölümü görüntüleme iznini içerir" }}" name="permission[access][]" value="{{ permission.permission }}" class="form-check-input group_{{ row }}" {% if permission.permission in access %}checked{% endif %} {% if permission.permission == 'setting/autocomplete' %} checked {% endif %}>
                                                            </td>
                                                            <td class="text-center">
                                                             {% if permission.permission in permission.permission_modify_array %}
                                                                <input type="checkbox" data-bs-toggle="tooltip" title="{{ "Bölüm üzerinde değişlik yapma iznini içerir" }}" name="permission[modify][]" value="{{ permission.permission }}" class="form-check-input group_{{ row }}" {% if permission.permission in modify %}checked{% endif %} {% if permission.permission == 'setting/autocomplete' %} checked {% endif %}>
                                                             {% endif %}
                                                            </td>
                                                        </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    {% set row = row + 1 %}
                                    {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {{ footer }}
</main>
<style>
.form-check-input {
    width: 1.2rem;
    height: 1.2rem;
}
</style>

<script type="text/javascript"><!--
$('input[id^=\'input-permission-all\']').on('click', function () {
    var for_input = $(this).attr('for');
	if($(this).prop('checked') == true) {
	  $('.' + for_input).prop('checked',true)
	}else{
	  $('.' + for_input).prop('checked',false)
	}

});
//--></script>