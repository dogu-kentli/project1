                   <li class="nav-item" role="presentation">
										<a class="nav-link" data-bs-toggle="tab" href="#tab-denklik" role="tab" aria-selected="false" tabindex="-1">
											<div class="d-flex align-items-center">
												<div class="tab-icon"><i class="bx bx-vector font-18 me-1"></i>
