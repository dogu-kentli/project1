                  <li class="nav-item" role="presentation">
										<a class="nav-link" data-bs-toggle="tab" href="#tab-gorusme" role="tab" aria-selected="false" tabindex="-1">
											<div class="d-flex align-items-center">
												<div class="tab-icon"><i class="bx bx-microphone font-18 me-1"></i>
												</div>
												<div class="tab-title">{{ "Görüşmeler" }}</div>
											</div>
										</a>
									</li>
                   <li class="nav-item" role="presentation">
										<a class="nav-link" data-bs-toggle="tab" href="#tab-degerlendirme" role="tab" aria-selected="false" tabindex="-1">
											<div class="d-flex align-items-center">
												<div class="tab-icon"><i class="bx bx-like font-18 me-1"></i>
												</div>
												<div class="tab-title">{{ "Değerlendirme" }}</div>
											</div>
