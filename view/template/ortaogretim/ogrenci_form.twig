<script>
 $('button[id=\'button-document-upload\']').on('click', function() {
  var id = $(this).attr('name');
  
  var bolum = 'personel';

	$('#form-upload').remove();

	$('body').prepend('<form enctype="multipart/form-data" id="form-upload" style="display: none;"><input type="file" name="file" /></form>');

	$('#form-upload input[name=\'file\']').trigger('click');

	if (typeof timer != 'undefined') {
    	clearInterval(timer);
	}

	timer = setInterval(function() {
		if ($('#form-upload input[name=\'file\']').val() != '') {
			clearInterval(timer);
       
			$.ajax({
				url: 'index.php?route=tool/upload/upload&user_token={{ user_token }}&customer_id={{customer_id}}&file_code=' + id,
				type: 'post',
				dataType: 'json',
				data: new FormData($('#form-upload')[0]),
				cache: false,
				contentType: false,
				processData: false,
        beforeSend: function() {
					$('.button' + id).html('Bekleyin...');
				},
				
				success: function(json) {
          $('.alert-dismissible').remove(); 
					if (json.error) {
             $('.button' + id).html('<i class="fa fa-upload"></i> Dosya Yükle');
            $('.container-fluid').prepend('<div class="alert alert-fixed alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.error + '</div>');
					}

					if (json.success) {
            $('.button' + id).html('<i class="fa fa-check"></i> Yüklendi');
            $('.button' + id).prop('disabled',true);
             $('.container-fluid').prepend('<div class="alert success-fixed alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.success + '</div>');
            
						$('#filename' + id).val(json['filename']);
            $('#filecode' + id).val(json['code']);
             $('#filemask' + id).val(json['mask']);
              $('#download' + id).removeAttr('disabled');
             $('.delete' + id).removeAttr('disabled');
            $('#download' + id).attr('href',json['download']);
					}
				 },
				error: function(xhr, ajaxOptions, thrownError) {
					alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
				}
			});
		}
	}, 500);
});
</script>

<script>
 $('button[id=\'button-document-delete\']').on('click', function() {
     var id =  $(this).attr('name');
     $.ajax({
      url: 'index.php?route=tool/upload/deleteUpload&user_token={{ user_token }}&customer_id={{customer_id}}&key=' + id,
      type: 'post',
      dataType: 'json',
      data : 'file=' + $('#filemask' + id).val(),
      success: function(json) {
        $('.alert-dismissible').remove();

        if (json.success) {
          $('.container-fluid').prepend('<div class="alert success-fixed alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.success + '</div>');
          $('#filename' + id).val('');
          $('.button' + id).prop('disabled',false);
          $('#download' + id).attr('disabled','disabled');
          $('.delete' + id).attr('disabled','disabled');
          $('.button' + id).html('<i class="fa fa-upload"></i> Dosya Yükle');
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });

  });

 </script>
