{{ header }}{{ column_left }}
<main class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>
        <div class="ms-auto">
            <a href="{{ download }}" data-toggle="tooltip" title="{{ button_download }}" class="btn btn-info btn-sm"><i class="bi bi-download"></i></a>
            <a onclick="confirm('{{ text_confirm }}') ? location.href='{{ clear }}' : false;" data-toggle="tooltip" title="{{ button_clear }}" class="btn btn-danger btn-sm"><i class="bi bi-eraser"></i> Temizle</a>
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="container py-0">

        <div class="card-body">

            <div class="my-3 border-top"></div>
            {% if success %}
            <div class="alert border-0 border-dark border-start border-1 bg-light-success alert-dismissible fade show py-1">
                <div class="d-flex align-items-center">
                    <div class="fs-3 text-success"><i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div class="ms-3">
                        <div class="text-dark">{{ success }}</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            {% endif %}

            {% if error_warning %}
            <div class="alert border-0 border-dark border-start border-1 bg-light-warning alert-dismissible fade show py-1">
                <div class="d-flex align-items-center">
                    <div class="fs-3 text-warning"><i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div class="ms-3">
                        <div class="text-dark">eaeae{{ error_warning }}</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            {% endif %}


        </div>
    </div>
    <!--/row-->
    <!-- timeline item 2 -->
    <div class="row">
        <div class="col-12">

            <div class="col py-2">
                <div class="card border-primary shadow radius-15">
                    <div class="card-body">
                        <h4 class="card-title text-primary">Sistem Hata Logları</h4>

                        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-target="#t2_details" data-bs-toggle="collapse" aria-expanded="true">Detaylar...▼</button>
                        <div class="border collapse show" id="t2_details">
                            <div class="p-2 text-monospace" style="max-height:450px; overflow-y:auto;">
                                {{log}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--/row-->

    </div>

    {{footer}}
</main>