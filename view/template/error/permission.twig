{{ header }}{{ column_left }}
<main class="page-content">
              <!--breadcrumb-->
            <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
             
              <div class="ps-3">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb mb-0 p-0">
				    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
					{% endfor %}
                  </ol>
                </nav>
              </div>
              
            </div>
            <!--end breadcrumb-->

            <div class="row">
              <div class="col-12 col-lg-6 mx-auto">
                <div class="card shadow-none bg-transparent">
                  <div class="card-body text-center">
                    <h1 class="display-4 mt-5">{{ "İZİN SAYFASI" }}</h1>
                    <p>UYARI : {{text_permission}}</p>
                    <div class="row">
                      <div class="col-12 col-lg-12 mx-auto">
                        <form class="">
                          <div class="input-group input-group-lg">
                            <input type="text" class="form-control" placeholder="E-posta adresiniz">
                            <button class="btn btn-primary" type="button"><i class="bx bx-right-arrow-alt"></i>
                            </button>
                          </div>
                        </form>
                        <h4 class="mt-3">Paylaş :</h4>
                        <div class="error-social mt-3"> <a href="javascript:;" class="bg-facebook"><i class="bx bxl-facebook"></i></a>
                          <a href="javascript:;" class="bg-twitter"><i class="bx bxl-twitter"></i></a>
                          <a href="javascript:;" class="bg-google"><i class="bx bxl-google"></i></a>
                          <a href="javascript:;" class="bg-linkedin"><i class="bx bxl-linkedin"></i></a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            {{ footer }}
          </main>
