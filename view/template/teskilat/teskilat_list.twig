{{ header }}{{ column_left }}
<main class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

        <div class="ms-auto text-end me-3">
            {% if level == 1 %}
            <button type="button" id="button-report" data-toggle="tooltip" title="{{ "Özet Rapor Oluştur" }}" class="btn btn-rainbow-custom btn-glow-purple btn-sm"><i class="bi bi-pie-chart-fill"></i> {{"Özet Rapor"}}</button>
            <a href="{{ add }}" data-toggle="tooltip" title="{{ "Ekle" }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Ekle</a>
            
            <button type="button" data-toggle="tooltip" title="{{ "Sil" }}" class="btn btn-danger btn-sm" onclick="confirm('{{ "İşlemi onaylıyor musunuz?" }}') ? $('#form-teskilat-list').submit() : false;"><i class="bi bi-trash"></i> Sil</button>
            {% endif %}
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-lg-3 col-6 me-auto">
                            <select name="filter_store" class="form-select auto-filter">
                                <option value="">{{text_all}}</option>
                                {% for store in stores %}
                                <option value="{{ store.store_id }}" {% if filter_store == store.store_id %} selected="selected" {% endif %}>{{store.name}}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-lg-2 col-6 col-md-3">

                        </div>

                        <div class="col-lg-2 col-6 col-md-3">
                            <select name="filter_mounth" class="form-select auto-filter">
                                <option value="">{{text_select}}</option>
                                {% for key,value in mounths %}
                                <option value="{{value}}" {% if filter_mounth == value %} selected {% endif %}>{{value}}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-lg-2 col-6 col-md-3">
                            <select name="filter_year" class="form-select auto-filter">
                                <option value="">{{text_select}}</option>
                                {% for year in years %}
                                <option value="{{year.text}}" {% if filter_year == year.text %} selected {% endif %}>{{year.text}}</option>
                                {% endfor %}
                            </select>
                        </div>


                        <div class="col-lg-1 co1-6 col-md-3">
                            <select name="limit" class="form-select auto-filter">
                                {% for key,value in limits %}
                                <option value="{{value}}" {% if filter_limit == value %} selected="selected" {% endif %}>{{value}}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-teskilat-list">
                    <div class="card-body">

                        <div class="table-responsive-sm">
                            <table class="table table-bordered table-striped align-middle mb-0 ">
                                <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                    <tr>
                                        <th style="width: 1px;" class="text-center">
                                            <input type="checkbox" class="form-check-input" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
                                        </th>
                                        <th class="text-start">{{ "Başlık" }}</th>
                                        <th class="text-start">{{ "Dönemi" }}</th>
                                        <th class="text-start">{{ "Kayıt Tarihi" }}</th>
                                        <th colspan="2" class="text-center" style="width:1%;">{{ "Eylem" }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% if reports %}
                                    {% for report in reports %}
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input" name="selected[]" value="{{ report.teskilat_rapor_id }}" />
                                        </td>
                                        <td class="text-start">{{ report.name }}</td>
                                        <td class="text-start">{{ report.donemi }}</td>
                                        <td class="text-start">{{ report.date_added }}</td>
                                        <td class="text-center">
                                            <a href="{{report.pdf}}" data-toggle="tooltip" target="_blank" title="{{ "Pdf olarak görüntüle" }}" class="btn btn-warning btn-sm"><i class="bi bi-file-pdf"></i></a>
                                        </td>
                                        <td class="text-center">
                                            <a href="{{ report.edit }}" data-toggle="tooltip" title="{{ "Düzenle" }}" class="btn btn-info btn-sm"><i class="bi bi-pencil"></i></a>
                                        </td>

                                    </tr>
                                    {% endfor %}
                                    {% else %}
                                    <tr>
                                        <td class="text-center" colspan="3">{{ text_no_results }}</td>
                                    </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
                                {{ pagination }}
                            </div>
                            <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
                                {{ results }}
                            </div>
                        </div>
                </form>
            </div>
        </div>


    </div>

    <div class="modal fade" id="modal-report" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">ÖZET RAPOR OLUŞTUR</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="form-report">
                        <div class="mb-3">
                            <label for="select-mounth" class="form-label">Dönemi :</label>
                            <select name="mounth" id="select-mounth" class="form-select">
                                <option value="">{{ text_select }}</option>
                                {% for key,value in mounths %}
                                <option value="{{ value }}" {% if filter_mounth == value %} selected {% endif %}>{{ value }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="select-year" class="form-label">Yıl:</label>
                            <select name="year" id="select-year" class="form-select">
                                <option value="">{{ text_select }}</option>
                                {% for year in years %}
                                <option value="{{ year.text }}" {% if filter_year == year.text %} selected {% endif %}>{{ year.text }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <a href="#" id="button-download" class="btn btn-warning d-none"><i class="bi bi-download"></i> İndir</a>
                    <button type="button" id="button-creat" class="btn btn-primary">Rapor Oluştur</button>
                </div>
            </div>
        </div>
    </div>
    {{footer}}
</main>
<script>
    $('#button-report').on('click', function() {
        $('#modal-report').modal('show');
        $('#button-creat').prop('disabled', false);
        $('#button-download').addClass('d-none');
    });

    $('#button-creat').on('click', function() {
        $.ajax({
            url: 'index.php?route=teskilat/teskilat/report&user_token={{ user_token }}',
            type: 'post',
            data: $('#form-report').serialize(),

            beforeSend: function() {
                $('#button-creat').buttonanimate('loading')
            },


            success: function(json) {

                if (json.error.warning) {
                    $('#button-creat').buttonanimate('reset').prop('disabled', false);
                    $('#alert').prepend(
                        '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-1">' +
                        '<div class="d-flex align-items-center">' +
                        '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
                        '<div class="ms-3"><div class="text-dynamic">' + json.error.warning + '</div></div>' +
                        '</div>' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                        '</div>'
                    );
                }


                if (json.success) {
                    $('#button-download').attr('href', json['export']);
                    $('#button-download').removeClass('d-none');
                    $('#button-creat').buttonanimate('reset').prop('disabled', true);

                    $('#alert').append(
                        '<div class="alert border-0 border-success border-start border-2 bg-light-success alert-dismissible fade show py-1">' +
                        '<div class="d-flex align-items-center">' +
                        '<div class="fs-3 text-dark"><i class="bi bi-check-circle-fill"></i></div>' +
                        '<div class="ms-3"><div class="text-dynamic">' + json.success + '</div></div>' +
                        '</div>' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                        '</div>'
                    );
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    });
</script>

