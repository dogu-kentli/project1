<script type="text/javascript">
    $('.button-save').on('click', function(event) {
        event.preventDefault(); // Burada olmalı

        // Önceki hataları temizle
        $('.text-danger,.alert-dismissible').remove();
        $('.form-control').removeClass('is-invalid').css('border', '');

        var errorArray = [];

        // Dönemi kontrolü
        var donemi = $('select[name="donemi"]').val();
        if (donemi === '') {
            errorArray.push('Lütfen dönemi seçin.');
            $('select[name="donemi"]').addClass('is-invalid')
                                     .after('<div class="text-danger"><span>Dönemi seçin</span></div>');
        }

        // Zorunlu alanlar kontrolü
        $('#form-teskilat .required').each(function() {
            if ($(this).val().trim() === '') {
                errorArray.push('Lütfen gerekli alanları doldurun.');
                $(this).next('.text-danger').remove(); // Önceki mesajı sil
                $(this).after('<div class="text-danger"><span>Zorunlu</span></div>');
                $(this).css('border', '1px solid #f78981');
            } else {
                $(this).next('.text-danger').remove();
                $(this).css('border', '');
            }
        });

        // Sonuç
        if (errorArray.length === 0) {
            $('#form-teskilat').submit();
        } else {
            alerterror('Lütfen zorunlu alanları doldurunuz.');
        }
    });
</script>

