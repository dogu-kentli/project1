{{ header }}{{ column_left }}
<main id="page-content" class="page-content">
    <div class="row">
        <div class="col-lg-12 mx-auto">
            <div class="card">
                <div class="card-header py-3 bg-transparent">
                    <div class="d-sm-flex align-items-center">
                        <h5 class="mb-2 mb-sm-0">Aylık Teşkilat Raporu</h5>
                        <div class="ms-auto">
                            <button type="button" form="form-teskilat" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary button-save btn-sm">
                                <i class="bi bi-save"></i>
                            </button>
                            <a href="{{ cancel }}" type="button" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light border border-dark shadow-sm btn-sm bg-white">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-teskilat" class="form-horizontal">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th colspan="6" class="text-center">{% if store_logo  %} <img src="{{ store_logo}}" /> {% else %}<img src="view/image/logo.png" width="200" height="auto" /></a> {% endif %}
                                    </th>
                                </tr>
                                <tr>
                                    <th colspan="6" id="imza" {% if teskilat_id  < 1 %} style="display:none;" {% endif %}>
                                        <h4>Kıymetli dernek başkanım; kurumunuzun aylık raporunu zamanında ve eksiksiz şekilde doldurmanızı rica ederim.</h4><br>
                                        <h4>Abdullah Muhammed İslam<br> Başkan</h3>

                                    </th>
                                </tr>

                                <tr>
                                    <th colspan="6" class="text-center">
                                        <div class="input-container">
                                            <input type="hidden" name="name" value="{{store_name}}" placeholder="............" class="form-control" style="width:100px;">
                                        </div>

                                        <div class="input-container">
                                            <h3><strong> {{store_name}} </strong></h3>
                                        </div>
                                        <br>
                                        <div id="report-message" class="bg-light radius-10" style="font-size:14px;display:none;">

                                        </div>

                                        <div class="input-container">

                                            <select name="donemi" id="input-rapor-donemi" onchange="donemkontrol(this)" class="form-select">
                                                <option value="">{{"-- Dönemi --"}}</option>
                                                {% for month in aylar %}
                                                <option value="{{ month.text }}" {% if donemi == month.text %} selected {% endif %}>{{ month.text }}</option>
                                                {% endfor %}
                                            </select>

                                        </div>

                                    </th>
                                </tr>
                                <tr id="rapor-donemi" style="display:none;">
                                    <td class="text-center"></td>
                                </tr>
                            </thead>
                        </table>
                        <div id="table-data" {% if teskilat_id == false %} style="display:none;" {% endif %}>
