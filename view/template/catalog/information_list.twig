<script>
    document.getElementById('button-modal-katilim').addEventListener('click', async function() {
        const btn = this;
        const etkinlik_id = document.querySelector('input[name="etkinlik_id"]').value;
        const form = document.getElementById('form-katilim');

        try {

            // loading efekti (senin buttonanimate yerine)
            btn.disabled = true;
            btn.innerText = 'Yükleniyor...';

            const response = await fetch(
                'index.php?route=catalog/information/addOgrenci&user_token={{ user_token }}&etkinlik_id=' + etkinlik_id, {
                    method: 'POST',
                    body: new FormData(form)
                }
            );

            const json = await response.json();

            // hata
            if (json?.error?.warning) {
                alerterror(json.error.warning);
            }

            // başarılı
            if (json?.success) {
                const listResponse = await fetch(
                    'index.php?route=catalog/information/datakatilim&user_token={{ user_token }}&etkinlik_id=' + etkinlik_id
                );

                const html = await listResponse.text();
                document.getElementById('katilim-listesi').innerHTML = html;
                alertsuccess(json.success);
            }

        } catch (err) {
            console.error(err);
        } finally {
            // reset
            btn.disabled = false;
            btn.innerText = 'Kaydet';
        }

    });
</script>
<script>
    function edit(etkinlik_id) {
        $('#modal-etkinlik .form-select,.form-control').val('');
        $('#button-file-download').prop('href', '').addClass('d-none').prop('disabled', true);
        $('#thumb-img1').attr('src', '{{ thumb1 }}');
        $('#thumb-img2').attr('src', '{{ thumb2 }}');
        $('#thumb-img3').attr('src', '{{ thumb3 }}');
        $('#input-img1,#input-img2,#input-img3').val('');
        $('#download-img1,#download-img2,#download-img3').attr('href', 'javascript:void(0)');

        $('#modal-etkinlik input[name="etkinlik_id"]').val(etkinlik_id);

        $.ajax({
            url: 'index.php?route=catalog/information/viewForm&user_token={{ user_token }}&etkinlik_id=' + etkinlik_id,
            type: 'get',
            dataType: 'json',

            success: function(json) {
                if (json.error && json.error.warning) {
                    alerterror(json.error.warning);
                }

                if (json.etkinlik_adi) {
                    $('#modal-etkinlik input[name^=\'etkinlik_adi\']').val(json.etkinlik_adi);
                }

                if (json.title) {
                    $('#modal-etkinlik input[name^=\'title\']').val(json.title);
                }

                if (json.komisyon_id) {
                    $('#modal-etkinlik select[name^=\'komisyon_id\']').val(json.komisyon_id);
                }

                if (json.etkinlik_category_id) {
                    $('#modal-etkinlik select[name^=\'etkinlik_category_id\']').val(json.etkinlik_category_id);
                }

                if (json.kisi_sayisi) {
                    $('#modal-etkinlik input[name^=\'kisi_sayisi\']').val(json.kisi_sayisi);
                }

                if (json.date_added) {
                    $('#modal-etkinlik input[name^=\'date_added\']').val(json.date_added);
                }

                if (json.description) {
                    $('#modal-etkinlik textarea[name^=\'description\']').val(json.description);
                }

                if (json.thumb1) {
                    $('#thumb-img1').attr('src', json.thumb1);
                    $('#input-img1').val(json.image1);
                    $('#download-img1').attr('href', json.download1);
                }

                if (json.thumb2) {
                    $('#thumb-img2').attr('src', json.thumb2);
                    $('#input-img2').val(json.image2);
                    $('#download-img2').attr('href', json.download2);
                }

                if (json.thumb3) {
                    $('#thumb-img3').attr('src', json.thumb3);
                    $('#input-img3').val(json.image3); 
                    $('#download-img3').attr('href', json.download3);
                }

                if (json.filename) {
                    $('#modal-etkinlik input[name^=\'filename\']').val(json.filename);
                    $('#modal-etkinlik input[name^=\'code\']').val(json.code);
                    $('#button-file-download').prop('href', json.file_url).removeClass('d-none').prop('disabled', false);
                }


                $('#modal-etkinlik').modal('show');
            },

            error: function(xhr, ajaxOptions, thrownError) {
                console.error(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }

    function katilim(etkinlik_id) {
      $('#katilim-listesi').empty();
      $('input[name="etkinlik_id"]').val(etkinlik_id);
      $('#katilim-listesi').load('index.php?route=catalog/information/datakatilim&user_token={{ user_token }}&etkinlik_id=' + etkinlik_id);
      $('#modal-etkinlik-katilim').modal('show');
     
    }
</script>

