<script>
    $('#button-save').on('click', function() {
        var $btn = $(this);
        $('#image').hide();
        $('#loader').show();
        $('#alert').html(''); // Önceki uyarıları temizle

        $.ajax({
            url: 'index.php?route=catalog/information/report&user_token={{ user_token }}&id=' + $('input[name="id"]').val(),
            type: 'post',
            data: $('#form-rapor').serialize(),

            beforeSend: function() {
                $btn.find(".loading").removeClass("visually-hidden");
                $btn.find(".reset").addClass("visually-hidden");
            },
            complete: function() {
                $btn.find(".loading").addClass("visually-hidden");
                $btn.find(".reset").removeClass("visually-hidden");
            },

            success: function(json) {
                if (json.error.warning) {
                    alerterror(json.error.warning);
                    $('#loader').hide();
                    return;
                }

                if (json.success) {
                    $('#loader').hide();
                    $('#image').show();
                    $('.rapor-item').hide();
                    $('#button-save').hide();
                    $('#button-download').attr('href', json.download).show();
                    $('#report-image').attr('src', json.success);
                }
            },

            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
                $('#loader').hide();
            }
        });
    });
</script>
