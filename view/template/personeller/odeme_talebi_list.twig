<script>
    $('#btn-help').on('click', function() {
        $('#modal-talep .note').toggle();
    });

    $('#btn-apply').on('click', function() {
        var date_start = $('input[name="date_start"]').val();
        var date_end = $('input[name="date_end"]').val();

        $('.dropdown-menu').click();
        $('input[name="filter_date_start"]').val(date_start).trigger('change');
        $('input[name="filter_date_end"]').val(date_end).trigger('change');
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        document.body.addEventListener('click', function(e) {
            if (e.target.classList.contains('file-delete')) {
                const row = e.target.closest('.row');
                if (row) row.remove();
            }
        });
    });
</script>

<script>
    //PERSONEL AUTO COMPLETE
    $('input[name=\'filter_personel\']').autocomplete({
        'source': function(request, response) {
            $.ajax({
                url: 'index.php?route=setting/autocomplete/autocompletePersoneller&user_token={{ user_token }}&filter_personel=' + encodeURIComponent(request),
                dataType: 'json',
                success: function(json) {
                    response($.map(json, function(item) {
                        return {
                            label: item['name'],
                            value: item['personel_id']
                        }
                    }));
                }
            });
        },

        'select': function(item) {
            $('input[name=\'filter_personel\']').val(item['label']);
            $('input[name=\'filter_personel_id\']').val(item['value']);
            $('input[name=\'filter_personel_id\']').trigger('change');
        }
    });

    $('input[name=\'filter_birim\']').autocomplete({
        'source': function(request, response) {
            $.ajax({
                url: 'index.php?route=setting/autocomplete/birimautocomplete&user_token={{ user_token }}&filter_birim=' + encodeURIComponent(request),
                dataType: 'json',
                success: function(json) {
                    response($.map(json, function(item) {
                        return {
                            label: item['name'],
                            value: item['id']
                        }
                    }));
                }
            });
        },

        'select': function(item) {
            $('input[name=\'filter_birim\']').val(item['label']);
            $('input[name=\'filter_birim_id\']').val(item['value']);
            $('input[name=\'filter_birim_id\']').trigger('change');
        }
    });
</script>

