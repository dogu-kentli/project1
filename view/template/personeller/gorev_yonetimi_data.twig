<div class="table-responsive-sm">
   <form id="form-gorev">
   <table id="table-odeme" class="table table-bordered align-middle mb-0 table-md">
  
      <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
          
          </tr>
           <tr >
            <th class="text-left" style="width:1%"> {{ "ID:" }}</th>
            <th class="text-left" style="width:20%"> {{ "Görev Konusu" }}</th>
             
            <th class="text-left" style="width:10%"> {{ "Kurum / Birim" }}</th>
            <th class="text-left" style="width:10%"> {{ "Görev Tarihi" }}</th>
            <th class="text-left" style="width:10%"> {{ "Harcırah Tutarı" }}</th>
            <th class="text-left" style="width:10%"> {{ "Harcanan Tutar" }}</th>
            <th class="text-left" style="width:10%"> {{ "Kalan Tutar" }}</th>
            <th class="text-center" style="width:20%"> {{ "Derneği" }}</th>
            <th class="text-center" style="width:5%;"> {{ "Durumu" }}</th>
            <th class="text-center" colspan="2" style="width:1%;">{{"Eylem"}} </th>
          </tr>
      </thead>

     
     <tbody class="data-list">
      {% if gorev_data %}
	    {% set row = 1 %}
	    {% for isler in gorev_data %}

      <tr id="data-list{{isler.gorev_yonetimi_id}}" class="{{isler.color}}">
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left item text-muted">ID#{{ isler.gorev_yonetimi_id }}</td>
       
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-wrap">{{isler.konu}}</td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left"><strong>{{isler.personel}}</strong><br><span class="text-muted">{{ isler.name }}</span></td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left item">{{ isler.date_start }}</td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left item">{{ isler.harcirah_tutari }}</td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left item">{{ isler.harcama_tutari }}</td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-left item">{{ isler.kalan }}</td>
       <td id="{{ isler.gorev_yonetimi_id }}" class="text-center">
         <div class="border rounded p-2 bg-light">
                                <div class="fw-bold">{{ isler.store.name|replace({'Uluslararası Öğrenci Derneği':''}) }}
                        </div>
       </td>
     
       <td class="text-center">
       <span data-toggle="tooltip" data-placement="top" title="{{ isler.last_history }}" class="badge {{isler.status_bg}}">
       {% if isler.last_history and isler.status < 3 %}
       <i class="bi bi-question-circle"></i>
       {% endif %}
       {{ isler.status }}
       </span>
      
       </td>
    
       <td class="text-center">
	      <button type="button" id="button-view" data-toggle="tooltip" title="Görüntüle" onclick="functionView('{{ isler.gorev_yonetimi_id }}','{{ isler.personel_id }}')" class="btn btn-info btn-sm"> <i class="bi bi-eye"></i></button>
	     </td>
       
       <td class="text-center">
	       <button type="button" onclick="remove('{{isler.gorev_yonetimi_id}}');" class="btn btn-danger btn-sm button-delete" {{button_delete}}><i class="bi bi-x-circle"></i></button>
	     </td>	  
	     </tr>
     
	   {% set row = row + 1 %}
     {% endfor %}
     {% else %}
        <tr>
        <td class="text-center" colspan="6">{{"Sonuç bulunamadı"}}</td>
       </tr>
      {% endif %}
      </tbody>
      
      </table>  
       </form>    
</div>
 
  <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
  
<script type="text/javascript"><!--
$('input[name^=\'filter_birim\']').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=personeller/gorev_yonetimi/birimautocomplete&user_token={{ user_token }}&filter_personel=' +  encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item['name'],
              label2: item['birim'],
              value: item['personel_id'],
              value2: item['personel_birim_id']
            }
          }));
        }
      });
    },

    'select': function(item) {
      $('#personel' + sessionStorage.getItem('id')).val(item['label']);
      $('#personel_birim_id' + sessionStorage.getItem('id')).trigger('change');
    }
  });

//--></script>

<script type="text/javascript"><!--
// MODAL GÖRÜNTÜLEME 
function functionView(id,personel_id) {
    $('.table tr').removeClass('bg bg-light-info');
    var user_personel_id = '{{user_personel_id}}';
    $('#data-list' + id).addClass('bg bg-light-info');
    
    $('#form-gorev_yonetimi_id').val(id);
    
    $.ajax({
      url: 'index.php?route=personeller/gorev_yonetimi/detayFormu&user_token={{ user_token }}&gorev_yonetimi_id=' + id,
      dataType: 'html',
      success: function(html) {
        $('#gorev-detay-html').html(html);
        $('#modal-gorev-detay').modal('show');
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });

}

$('#modal-button-update').on('click', function() {
     $.ajax({
      url: 'index.php?route=personeller/gorev_yonetimi/save&user_token={{ user_token }}&form=edit' + '&gorev_yonetimi_id='  + $('#form-gorev_yonetimi_id').val(),
      type: 'post',
      dataType: 'json',
      data : $('#form-tanitim-edit').serialize(),
      
      success: function(json) {
        $('.alert-dismissible').remove();
      
        if (json.error.warning) {
          alerterror(json.error.warning);
        }

        if (json.success) {
            $('.modal').modal('hide');
            alertsuccess(json.success);

            $('#odeme-data').load('index.php?route=personeller/gorev_yonetimi/dataGorev&user_token={{ user_token }}');
            
        }


      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });

  });
</script>
<script>
 function remove(gorev_yonetimi_id) {
    if (confirm('Dikkat : Bu işlem geri alınamaz. Bu görevi silmek istediğinize emin misiniz?') == false) {    
        exit();
    }
   
     $.ajax({
      url: 'index.php?route=personeller/gorev_yonetimi/deleteData&user_token={{ user_token }}&gorev_yonetimi_id='  + gorev_yonetimi_id,
      type: 'post',
      dataType: 'json',
      success: function(json) {
        $('.alert-dismissible').remove();

        if (json.error.warning) {
          alerterror(json.error.warning);
        }
                
        if (json.success) {
          $('#modal-gorev-detay').modal('hide');
          $('#gorev-data').load('index.php?route=personeller/gorev_yonetimi/dataGorev&user_token={{ user_token }}'); 
          alertsuccess(json.success);
                  
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });

  }

$('#button-close').on('click', function() {
    $('#modal-gorev-detay').modal('hide');
});

//--></script>
<script>
$(document).ready(function(){
 $('#cover-spin').hide();
});

</script>
<script>
$('#gorev-data .button-count-filter').on('click', function() {
   $('#cover-spin').show();
   $('#gorev-data').load('index.php?route=personeller/gorev_yonetimi/dataGorev&user_token={{ user_token }}&filter_status=' + $(this).data('for'));
});	



</script>
