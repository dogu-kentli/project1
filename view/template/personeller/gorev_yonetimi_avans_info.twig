<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avans Harcama Dökümü</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 5px;
            padding: 40px;
            background-color: #f4f7fa;
            color: #333;
            line-height: 1.6;
        }

        .container {
            width: 75%;
            margin: auto;
            background-color: #ffffff;
            padding: 30px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            position: relative;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e0e6ed;
        }

        .logo-area {
            flex-grow: 1;
        }
        .logo-area img {
            max-height: 50px;
            width: auto;
        }

        .date-info {
            flex-shrink: 0;
            text-align: right;
            color: #777;
            font-size: 13px;
            margin-right: 15px;
            padding-top: 5px;
        }

        .print-button {
            flex-shrink: 0;
            background-color: #007bff;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            transition: background-color 0.3s ease, transform 0.2s ease;
            box-shadow: 0 4px 10px rgba(0, 123, 255, 0.2);
        }

        .print-button:hover {
            background-color: #0056b3;
            transform: translateY(-1px);
        }

        .title-area {
            text-align: center;
            margin-bottom: 30px;
        }

        .organization-info p {
            margin: 0;
            line-height: 1.4;
            font-size: 13px;
            color: #555;
        }

        h1 {
            font-size: 28px;
            font-weight: 600;
            color: #2c3e50;
            padding-bottom: 15px;
            border-bottom: 2px solid #e0e6ed;
            margin-top: 5px;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 25px;
            background-color: #fdfdfd;
            border-radius: 8px;
            overflow: hidden;
        }

        .info-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #eee;
            font-size: 14px;
            color: #444;
        }

        .info-table .label {
            width: 30%;
            background-color: #f8f9fa;
            font-weight: 600;
            color: #2c3e50;
        }

        .info-table .amount-label {
            width: 40%;
            background-color: #f8f9fa;
            font-weight: 600;
            color: #2c3e50;
        }

        .info-table .amount-value {
            width: 30%;
            text-align: right;
            font-weight: 700;
            color: #1a1a1a;
            font-size: 15px;
        }

        .detail-table {
            border: 1px solid #e0e6ed;
        }

        .detail-table th, .detail-table td {
            border: none;
            border-bottom: 1px solid #e0e6ed;
            padding: 12px 15px;
            text-align: left;
            font-size: 14px;
            color: #444;
        }

        .detail-table th {
            background-color: #eef2f7;
            font-weight: 600;
            color: #2c3e50;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-table .amount {
            text-align: right;
            font-weight: 700;
            color: #1a1a1a;
        }

        .detail-table tr.total-row td {
            background-color: #f1f4f8;
            font-weight: 700;
            border-top: 2px solid #d8e0e9;
            color: #1a1a1a;
            font-size: 15px;
        }

        .detail-table tr.total-row .amount {
            font-size: 16px;
            color: #000;
        }

        .signature-area {
            display: flex;
            justify-content: space-around;
            margin-top: 60px;
            font-size: 15px;
            color: #555;
        }

        .signature-area div {
            width: 40%;
            text-align: center;
            padding-top: 15px;
            position: relative;
        }

        .signature-area div::before {
            content: '';
            position: absolute;
            top: 0;
            left: 20%;
            right: 20%;
            height: 1px;
            background-color: #a0a0a0;
        }

    
        @media print {

            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .print-button {
                display: none !important;
            }

            body {
                padding: 0 !important;
                margin: 0 !important;
                background: #fff !important;
            }

            .container {
                width: 90% !important;
                margin: 0 !important;
                padding: 20px !important;
                background: #ffffff !important;
                box-shadow: none !important;
                border-radius: 0 !important;
            }

            table th {
                background-color: #eef2f7 !important;
            }

            .info-table .label,
            .info-table .amount-label {
                background-color: #f8f9fa !important;
            }

            .detail-table tr.total-row td {
                background-color: #f1f4f8 !important;
            }
        }

    </style>
</head>
<body>

<div class="container">
    
    <div class="top-bar">
        <div class="logo-area">
            <span class="placeholder-logo"><img src="view/image/logo.png" width="200" height="auto" /></span>
        </div>
        <div class="date-info">
            {{bugun}}
        </div>
        <button class="print-button" onclick="window.print()">
            &#128424; Yazdır
        </button>
    </div>

    <div class="title-area">
        <div class="organization-info">
            <p style="font-size: 12px; color: #777;">Görevlendirmeler</p>
        </div>
        <h1>AVANS HARCAMA DÖKÜMÜ</h1>
    </div>

    <table class="info-table">
        <tbody>
            <tr>
                <td class="label">Avans Kayıt No</td>
                <td>ID#{{ID}}</td>
                <td class="amount-label">Avans Ödemeleri Tutarı</td>
                <td class="amount-value">{{harcirah_tutari}} TRY</td>
            </tr>
            <tr>
                <td class="label">Avans Tarihi</td>
                <td>{{date_added}}</td>
                <td class="amount-label">Avans İadeleri Tutarı</td>
                <td class="amount-value">{{iade_total}} TRY</td>
            </tr>
            <tr>
                <td class="label">Kapanış Tarihi</td>
                <td>{{date_modified}}</td>
                <td class="amount-label">Harcama Tutarı</td>
                <td class="amount-value">{{harcama_tutari}} TRY</td>
            </tr>
            <tr>
                <td class="label">Sorumlu Kişi</td>
                <td colspan="3">{{sorumlu}}</td>
            </tr>
            <tr>
                <td class="label">Görevin Türü</td>
                <td colspan="3">İdari Görevlendirme</td>
            </tr>
            <tr>
                <td class="label">Görevin Konusu</td>
                <td colspan="3">{{konu}}</td>
            </tr>
            <tr>
                <td class="label">Görevin Amacı</td>
                <td colspan="3">{{description}}</td>
            </tr>
        </tbody>
    </table>

    <table class="detail-table">
        <thead>
            <tr>
                <th style="width: 15%;">Evrak Tarihi</th>
                <th style="width: 50%;">Harcama Açıklaması</th>
                <th class="amount" style="width: 20%;">Harcama Tutarı</th>
            </tr>
        </thead>
        <tbody>
           {% for harcama in harcamalar %}
            <tr>
                <td>{{harcama.tarih}}</td>
                <td>{{harcama.title}}</td>
                <td class="amount">{{harcama.tutar}} TRY</td>
            </tr>
            {% endfor %}
           
            <tr class="total-row">
                <td colspan="2" style="text-align: right;">Toplam Harcama:</td>
                <td class="amount">{{total}} TRY</td>
            </tr>
        </tbody>
    </table>

    <div class="signature-area">
        <div>
            <p>Teslim Eden</p>
        </div>
        <div>
            <p>Teslim Alan</p>
        </div>
    </div>

</div>

</body>
</html>
