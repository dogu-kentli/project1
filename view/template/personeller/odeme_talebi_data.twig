<script>
$(document).on('input', '.fatura-no', function() {
  var faturaNo = $(this).val();
  var row = $(this).closest('.row');       // aynı satırı bul
  var inputCode = row.find('.input-code'); // o satırdaki code alanı

  // Orijinal kodu saklamak için data attribute kullanalım
  var originalCode = inputCode.attr('data-original') || inputCode.val();

  // Eğer daha önce tireli eklenmişse, sadece orijinal kısmı al
  originalCode = originalCode.replace(/^.*-/, '');

  inputCode.attr('data-original', originalCode);

  // Birleştir: faturaNo + "-" + originalCode
  if (faturaNo.trim() !== "") {
    inputCode.val(faturaNo + '-' + originalCode);
  } else {
    inputCode.val(originalCode); // boşsa sadece orijinal kodu göster
  }
});
</script> 

   
