{{ header }}{{ column_left }}
<main class="page-content">

    <!--breadcrumb-->
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>
        <div class="ms-auto">
            <button type="submit" form="form-setting" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary btn-sm">
                <i class="bi bi-save"> Kaydet</i>
            </button>
            {% if level == 1 %}
            <button type="button" id="button-form" data-toggle="tooltip" title="{{ "Online form" }}" class="btn btn-warning btn-sm">
                <i class="bi bi-cog"></i> Online Form
            </button>
            {% endif %}
            <a href="{{ cancel }}"  data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light border border-dark shadow-sm bg-white btn-sm">
                <i class="bi bi-arrow-counterclockwise"></i> 
            </a>
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 mx-auto">
            <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-setting" class="form-horizontal">
                <div class="card">
                    <div class="card-body">

                        <input type="hidden" name="customer_group_id" value="6" class="form-control" />
                        <ul class="nav nav-tabs nav-primary" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" data-bs-toggle="tab" href="#tab-genel" role="tab" aria-selected="true">
                                    <div class="d-flex align-items-center">
                                        <div class="tab-icon"><i class="bx bx-cog font-18 me-1"></i>
                                        </div>
                                        <div class="tab-title">{{ "Kişisel Bilgiler" }}</div>
                                    </div>
                                </a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" data-bs-toggle="tab" href="#tab-egitim" role="tab" aria-selected="false" tabindex="-1">
                                    <div class="d-flex align-items-center">
                                        <div class="tab-icon"><i class="bx bx-book-reader font-18 me-1"></i>
                                        </div>
                                        <div class="tab-title">{{ "Eğitim Bilgileri" }}</div>
                                    </div>
                                </a>
                            </li>
                            {% if parent_id == 1 %}
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" data-bs-toggle="tab" href="#tab-category" role="tab" aria-selected="false" tabindex="-1">
                                    <div class="d-flex align-items-center">
                                        <div class="tab-icon"><i class="bx bx-server font-18 me-1"></i>
                                        </div>
                                        <div class="tab-title">{{ "Kategori Ve Birimler" }}</div>
                                    </div>
                                </a>
                            </li>
                            {% endif %}


                        </ul>
                        <div class="tab-content py-3">
                            <div class="tab-pane fade show active" id="tab-genel" role="tabpanel">
                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend class="the-legend">Genel Bilgiler</legend>
                                    <!-- Öğrenci Adı -->
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Adı <span class="text-danger">*</span></label>
                                            <input type="text" name="firstname" value="{{ firstname }}" placeholder="Adı" id="input-firstname" class="form-control" />
                                            {% if error_firstname %}
                                            <div class="text-danger">{{ error_firstname }}</div>
                                            {% endif %}
                                            {{profile_complete_ratio}}
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Soyadı <span class="text-danger">*</span></label>
                                            <input type="text" name="lastname" value="{{ lastname }}" placeholder="Soyadı" id="input-lastname" class="form-control" />
                                            {% if error_lastname %}
                                            <div class="text-danger">{{ error_lastname }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Kimlik No</label>
                                            <input type="text" name="kimlikno" value="{{ kimlikno }}" placeholder="Kimlik No" id="input-kimlik_no" class="form-control" />
                                        </div>
                                    </div>


                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Cep Telefonu (Operator Numarası) <span class="text-danger">*</span></label>
                                            <div class="input-group mb-3">
                                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">--Operator--</button>
                                                {% for custom_field in custom_fields %}
                                                {% if custom_field.location_sort == 'account22' %}
                                                <ul class="dropdown-menu" style="">
                                                    {% for custom_field_value in custom_field.custom_field_value %}
                                                    <li><a class="dropdown-item operator-code" href="javascript:void(0)" id="{{ custom_field_value.name }}">{{ custom_field_value.name }}</a></li>
                                                    {% endfor %}
                                                </ul>
                                                {% endif %}
                                                {% endfor %}
                                                <input type="text" name="telephone" value="{{ telephone }}" placeholder="Telefon" id="input-telephone" class="form-control" />
                                            </div>
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">İş Telefonu <span class="text-danger">*</span></label>
                                            <input type="text" name="telephone3" value="{{ telephone3 }}" placeholder="İş Telefonu" id="input-telephone3" class="form-control" />
                                            {% if error_lastname %}
                                            <div class="text-danger">{{ error_lastname }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">E-Mail</label>
                                            <input type="text" name="email" value="{{ email }}" placeholder="e-posta adresi" id="input-email" class="form-control" />
                                            {% if error_email %}
                                            <div class="text-danger">{{ error_email }}</div>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Doğum Yeri </label>
                                            <input type="text" name="dogum_yeri" value="{{ dogum_yeri }}" placeholder="Doğum Yeri" id="input-dogum-yeri" class="form-control" />
                                            {% if error_dogumyeri %}
                                            <div class="text-danger">{{ error_dogumyeri }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Doğum Tarihi <span class="text-danger">*</span></label>
                                            <input type="date" name="dogum_tarihi" value="{{ dogum_tarihi }}" placeholder="Doğum Tarihi" id="input-date-added" class="form-control" />
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Cinsiyet</label>
                                            <select name="gender" id="input-gender" class="form-select">
                                                <option value="">--Seçim Yapın--</option>
                                                <option value="E" {% if gender == 'E' %} selected="selected" {% endif %}>Erkek</option>
                                                <option value="K" {% if gender == 'K' %} selected="selected" {% endif %}>Kadın</option>
                                            </select>
                                            {% if error_gender %}
                                            <div class="text-danger">{{ error_gender }}</div>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="row">
                                        {% for custom_field in custom_fields %}
                                        {% if custom_field.location_sort == 'account1' %}
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Kan Grubu </label>
                                            <select name="kan_grubu" id="input-gender" class="form-select">
                                                <option value="">--Seçim Yapın--</option>
                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id == kan_grubu %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        {% endif %}
                                        {% endfor %}

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Medeni Hali <span class="text-danger">*</span></label>
                                            <select name="medeni_hali" id="input-medeni_hali" class="form-select">
                                                <option value="">--Seçim Yapın--</option>
                                                <option value="E" {% if medeni_hali == 'E' %} selected="selected" {% endif %}>Evli</option>
                                                <option value="B" {% if medeni_hali == 'B' %} selected="selected" {% endif %}>Bekar</option>
                                            </select>
                                             {% if error_medeni %}
                                            <div class="text-danger">{{ error_medeni }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Çocuk Sayısı</label>
                                            <input type="number" name="cocuk_sayisi" value="{{ cocuk_sayisi }}" placeholder="Çocuk Sayısı" id="input-meslegi" class="form-control" />
                                        </div>
                                    </div>

                                </fieldset>

                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend class="the-legend">Adres Bilgileri</legend>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Ev Adresi</label>
                                            <input type="text" name="adres1" value="{{ adres1}}" placeholder="Ev Adresi" id="input-adres1" class="form-control" />
                                            {% if error_adres1 %}
                                            <div class="text-danger">{{ error_adres1 }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Iş Adresi</label>
                                            <input type="text" name="adres2" value="{{ adres2}}" placeholder="İş Adresi" id="input-adres2" class="form-control" />
                                            {% if error_adres2 %}
                                            <div class="text-danger">{{ error_adres2 }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </fieldset>

                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend>Diğer Bilgiler</legend>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Askerlik Durumu </label>
                                            <select name="askerlik_durumu" id="input-askerlik-durumu" class="form-select">
                                                <option value="">--Seçim Yapın--</option>
                                                <option value="1" {% if askerlik_durumu == '1' %} selected="selected" {% endif %}>Yaptı</option>
                                                <option value="2" {% if askerlik_durumu == '2' %} selected="selected" {% endif %}>Yapmadı</option>
                                                <option value="3" {% if askerlik_durumu == '3' %} selected="selected" {% endif %}>Muaf</option>
                                            </select>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Terhis/Tecil Tarihi <span class="text-danger">*</span></label>
                                            <input type="date" name="askerlik_tecil" value="{{ askerlik_tecil}}" placeholder="Tarih" id="input-tecil" class="form-control" />
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Pasaport Türü</label>
                                            <input type="text" name="pass_turu" value="{{ pass_turu}}" placeholder="Pasaport Türü" id="input-pass-turu" class="form-control" />
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Pasaport Numarası </label>
                                            <input type="text" name="pass_number" value="{{ pass_number}}" placeholder="Numara" id="input-pass-number" class="form-control" />
                                        </div>

                                        <div class="col-md-4 mb-3">
                                            <label class="form-label fw-bold">Geçerlilik Tarihi</label>
                                            <input type="date" name="pass_date" value="{{ pass_date}}" placeholder="Tarih" id="input-pass-date" class="form-control" />
                                        </div>
                                    </div>
                                </fieldset>

                                <div class="row">
                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" name="src_belgesi" type="checkbox" id="flexSwitchCheckChecked" {% if src_belgesi == 1 %} checked="checked" {% endif %} name="src_belgesi" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Sürücü Belgesi</label>
                                        </div>
                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" {% if src_belgesi2 == 1 %} checked="checked" {% endif %} name="src_belgesi2" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Src Belgesi</label>
                                        </div>
                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" {% if trafik_tecrubesi == 1 %} checked="checked" {% endif %} name="trafik_tecrubesi" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Trafik Tecrübesi</label>
                                        </div>
                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" id="toggle-engel" type="checkbox" id="flexSwitchCheckChecked" {% if engel_durumu == 1 %} checked="checked" {% endif %} name="engel_durumu" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Engel Durumu</label>
                                        </div>
                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" {% if seyahat == 1 %} checked="checked" {% endif %} name="seyahat" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Seyahat İmkanı</label>
                                        </div>
                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" id="toggle-adli-sicil" type="checkbox" id="flexSwitchCheckChecked" {% if adli_sicil == 1 %} checked="checked" {% endif %} name="adli_sicil" value="1">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">Adli Sicil Kaydı</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3" id="engel-description" style="display:none;">
                                        <label class="form-label fw-bold">Engel Açıklama</label>
                                        <input type="text" name="engel_description" value="{{ engel_description}}" placeholder="Açıklama" id="input-engel-description" class="form-control" />
                                    </div>

                                    <div class="col-md-6 mb-3" id="sicil-description" style="display:none;">
                                        <label class="form-label fw-bold">Adli sicil detayları</label>
                                        <input type="text" name="adli_sicil_description" value="{{ adli_sicil_description}}" placeholder="Açıklama" id="input-adli-sicil-description" class="form-control" />
                                    </div>
                                </div>



                                </fieldset>

                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend>İş Ve Meslek Bilgileri</legend>
                                    <div class="row">
                                        <div class="col-md-2 mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" {% if calisma_durumu == 1 %} checked="checked" {% endif %} name="calisma_durumu" value="1">
                                                <label class="form-check-label" for="flexSwitchCheckChecked">Çalışma Durumu</label>
                                            </div>
                                        </div>

                                        <div class="col-md-2 mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" {% if is_arama == 1 %} checked="checked" {% endif %} name="is_arama" value="1">
                                                <label class="form-check-label" for="flexSwitchCheckChecked">İş Arama Durumu</label>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="row">
                                        <div class="col-md-3 mb-3 form-meslek" style="display:none;">
                                            <label class="form-label fw-bold">Çalıştığı Kurum</label>
                                            <input type="text" name="kurum" value="{{ kurum }}" placeholder="Şuan Çalıştığınız Kurumu" id="input-kurum" class="form-control" />
                                        </div>

                                        {% for custom_field in custom_fields %}
                                        {% if custom_field.location_sort == 'account23' %}
                                        <div class="col-md-3 mb-3 form-meslek" style="display:none;">
                                            <label class="form-label fw-bold">Meslek Grubu</label>
                                            <select name="meslek_grubu" id="select-meslek-grubu" class="form-select">
                                                <option value="">--Seçim Yapın--</option>
                                                {% for custom_field_value in custom_field.custom_field_value %}
                                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id == meslek_grubu %} selected="selected" {% endif %}>{{ custom_field_value.name }}</option>
                                                {% endfor %}
                                                <option value="diger" {% if meslek_grubu == "diger" %} selected="selected" {% endif %}>Diğer</option>
                                            </select>
                                        </div>
                                        {% endif %}
                                        {% endfor %}
                                        <input type="hidden" name="diger_meslek" value="{{ diger_meslek }}" placeholder="Meslek Grubunu Yazınız." id="input-meslek-grubu2" class="form-control" />

                                        <div class="col-md-3 mb-3 form-meslek" style="display:none;">
                                            <label class="form-label fw-bold">Meslek Ünvanı</label>
                                            <input type="text" name="meslek_unvan" value="{{ meslek_unvan }}" placeholder="Meslek Ünvanı" id="input-meslek-unvan" class="form-control" />
                                        </div>

                                        <div class="col-md-3 mb-3 form-meslek" style="display:none;">
                                            <label class="form-label fw-bold">Çalıştığı Pozisyon</label>
                                            <input type="text" name="pozisyon" value="{{ pozisyon }}" placeholder="Şuan çalıştığınız pozisyonu yazınız" id="input-pozisyon" class="form-control" />
                                        </div>
                                    </div>
                                </fieldset>

                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend class="the-legend">Kullanıcı İşlemleri</legend>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                                            <div class="input-group mb-3">
                                            <input type="text" name="username" value="{{ username }}" placeholder="Kullanıcı Adı" id="input-username" class="form-control" />
                                             <input type="hidden" name="user_id" value="{{ user_id }}" placeholder="Kullanıcı Adı" class="form-control" />
                                              {% if parent_id == 1 %}
                                              <a href="{{user_edit }}" class="btn btn-info"><i class="bi bi-pencil me-0"></i></a>
                                              {% endif %}
                                            </div>
                                            {% if error_username %}
                                            <div class="text-danger">{{ error_username }}</div>
                                            {% endif %}
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Parola</label>
                                            <div class="input-group mb-3">
                                                <input type="text" name="password" value="" placeholder="Parola" id="input-password" class="form-control" />
                                                <button type="button" class="btn btn-info" id="button-produce" data-loading-text="{{ text_loading }}"><i class="bi bi-gear me-0"></i> Üret</button>
                                            
                                            </div>
                                             {% if error_password %}
                                            <div class="text-danger">{{ error_password }}</div>
                                            {% endif %}
                                           
                                        </div>
                                    </div>
                                </fieldset>


                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    <legend>Sosyal Ağlar</legend>

                                    <div class="col-12">
                                        <div class="d-flex gap-3 flex-wrap">

                                            <!-- Facebook -->
                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-primary toggle-input">
                                                    <i class="bi bi-facebook"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">
                                                    <input type="text" name="social_network[fb]" value="{{ social_network['fb'] }}" class="form-control" placeholder="Facebook linki">
                                                </div>
                                            </div>

                                            <!-- Twitter -->
                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-info toggle-input">
                                                    <i class="bi bi-twitter"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">
                                                    <input type="text" class="form-control" name="social_network[tw]" value="{{ social_network['tw'] }}" placeholder="{{ "Twitter Linki" }}">
                                                </div>
                                            </div>

                                            <!-- Instagram -->
                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-primary toggle-input">
                                                    <i class="bi bi-instagram"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">

                                                    <input type="text" class="form-control" name="social_network[tw]" value="{{ social_network['tw'] }}" placeholder="{{ "Instagram Linki" }}">
                                                </div>
                                            </div>

                                            <!-- YouTube -->
                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-danger toggle-input">
                                                    <i class="bi bi-youtube"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">

                                                    <input type="text" class="form-control" name="social_network[yt]" value="{{ social_network['yt'] }}" placeholder="{{ "Youtube" }}" </div>
                                                </div>

                                            </div>

                                            <!-- Linkedin -->
                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-primary toggle-input">
                                                    <i class="bi bi-linkedin"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">

                                                    <input type="text" class="form-control" name="social_network[ln]" value="{{ social_network['ln'] }}" placeholder="{{ "Linkedin" }}" </div>
                                                </div>

                                            </div>

                                            <div class="social-item d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-white text-success toggle-input">
                                                    <i class="bi bi-whatsapp"></i>
                                                </button>
                                                <div class="input-group d-none flex-grow-1">

                                                    <input type="text" class="form-control" name="social_network[wt]" value="{{ social_network['wt'] }}" placeholder="{{ "WHatsapp" }}" </div>
                                                </div>

                                            </div>

                                            
                                        </div>
                                </fieldset>

                                <fieldset id="yonetim" class="border rounded p-3 mb-4">
                                    
                                    <div class="row" >
                                        <div class="col-md-4 mb-3"  style="display:{% if level == 1 %} block; {% else %} none; {% endif %}">
                                        <label class="form-label fw-bold">Derneği</label>
                                        <select name="store_id" class="form-select">
                                            <option value="" {% if store_id == '' %} selected="selected" {% endif %}>{{text_select}}</option>
                                            <option value="0" {% if store_id == '0' %} selected="selected" {% endif %}>Udef</option>
                                            {% for store in stores %}
