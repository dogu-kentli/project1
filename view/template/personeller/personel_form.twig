<script type="text/javascript">

    $('#input-lastname').on('change', function() {

        var firstname = $('#input-firstname').val();
        var lastname = $('#input-lastname').val();

        var name = firstname + ' ' + lastname;
        name = name.replaceAll(' ', '.');

        var username = convertChracter(name);
        username.trim();

        $('input[name=\'username\']').val(username.toLowerCase());

    });

    function convertChracter(text) {
        const turkishChars = {
            'ğ': 'g',
            'Ğ': 'G',
            'ü': 'u',
            'Ü': 'U',
            'ş': 's',
            'Ş': 'S',
            'ı': 'i',
            'İ': 'I',
            'ö': 'o',
            'Ö': 'O',
            'ç': 'c',
            'Ç': 'C'
        };

        return text.replace(/[ğüşıöçĞÜŞİÖÇ]/g, function(match) {
            return turkishChars[match];
        });
    }

</script>

