{{ header }}{{ column_left }}
<main id="fakulteler" class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

        <div class="ms-auto text-end me-3">
         
         <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Ekle</a>
         <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger btn-sm" onclick="confirm('{{ text_confirm }}') ? $('#form-fakulte').submit() : false;"><i class="bi bi-trash"></i> Sil</button>
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-12 me-auto">
                            <div class="ms-auto position-relative">
                                <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                                <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ "Fakülte adı / Üniversite adını yazınız." }}" id="input-fakulte-name" class="form-control form-control-lg ps-4">
                               <input type="hidden" name="f_fakulte_id" value="{{ f_fakulte_id }}" placeholder="{{ "Fakülte adı / Üniversite adını yazınız." }}" id="input-fakulte-name" class="form-control auto-filter"/>
                            </div>
                        </div>

                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-fakulte">
                    <div class="card-body">

                        <div class="table-responsive-sm">
                            <table class="table table-striped table-bordered table-hover">
                                   <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                    <tr>
                                      <th style="width: 1px;" class="text-center">
                                        <input type="checkbox" class="form-check-input" onclick="$('input[name*=\'selected\']').trigger('click');"/>
                                        </th>
                                        <th class="text-start">{{ column_name }}</th>
                                        <th class="text-start">{{ column_country }} </th>
                                        <th style="width: 1px;" class="text-center">{{ column_action }}</th>
                                    </tr>
                                   </thead>
                                   <tbody class="bg-">
                                   {% if fakultes %}
                                    {% for fakulte in fakultes %}
                                    <tr>
                                      <td class="text-center">
                                        <input type="checkbox" class="form-check-input" name="selected[]" value="{{ fakulte.fakulte_id }}" />
                                      </td>                 
                                      <td class="text-left">{{ fakulte.fakulte }}</td>
                                      <td class="text-left">{{ fakulte.universite }}</td>
                                      <td class="text-right"><a href="{{ fakulte.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-info btn-sm"><i class="bi bi-pencil"></i></a></td>
                                    </tr>
                                    {% endfor %}
                                    {% else %}
                                    <tr>
                                      <td class="text-center" colspan="5">{{ text_no_results }}</td>
                                    </tr>
                                    {% endif %}
                                                      </tbody>
                                 </table>
                        </div>

                        <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
                </form>
            </div>
        </div>


    </div>

    {{footer}}
</main>
<script type="text/javascript"><!--
$('#fakulteler .auto-filter').on('change', function() {
	url = 'index.php?route=universite/fakulte&user_token={{ user_token }}'; 

	var filter_fakulte = $('input[name=\'f_fakulte_id\']').val();

	if (filter_fakulte !== '') {
		url += '&filter_fakulte=' + encodeURIComponent(filter_fakulte);
	}	
	
	location = url;
});

$('#button-clear').on('click', function() {
	url = 'index.php?route=universite/fakulte&user_token={{ user_token }}'; 

  $('#cover-spin').show(0);

	location = url;
});
//--></script>
<script type="text/javascript"><!--
$('input[name=\'filter_name\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=setting/autocomplete/facultesautocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['fakulte_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
    $('input[name=\'f_fakulte_id\']').val(item['value']);
    $('input[name=\'f_fakulte_id\']').trigger('change');
	}
});
//--></script>

<script>
var error_warning = '{{error_warning}}';
var success = '{{success}}';
$(document).ready(function() {
  if(error_warning) {
    $('#alert').prepend(
      '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-2">' +
        '<div class="d-flex align-items-center">' +
          '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
          '<div class="ms-3"><div class="text-dynamic">' + error_warning + '</div></div>' +
        '</div>' +
        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
      '</div>'
    );
  }

  if (success) {
    $('#alert').append(
        '<div class="alert border-0 border-success border-start border-4 bg-light-success alert-dismissible fade show py-2">' +
          '<div class="d-flex align-items-center">' +
            '<div class="fs-3 text-success"><i class="bi bi-check-circle-fill"></i></div>' +
            '<div class="ms-3"><div class="text-dynamic">' + success + '</div></div>' +
          '</div>' +
          '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
        '</div>'
      );  
  }
});
</script>