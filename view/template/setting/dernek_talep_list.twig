{{ header }}{{ column_left }}
<main id="talepler" class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

        <div class="ms-auto text-end me-3">
            {% if store_id !=0 %}
            <button type="button" id="button-talep-add" data-toggle="tooltip" title="{{ button_talep }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> {{button_talep}}</button>
            {% endif %}

            <a href="{{ export }}" data-toggle="tooltip" title="Exel Dökümü" class="btn btn-success btn-sm"><i class="bi bi-download"></i></a>
            {% if store_id == 0 %}
            <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger btn-sm" onclick="confirm('{{ text_confirm }}') ? $('#form-talep').submit() : false;"><i class="bi bi-trash"></i> Sil</button>
            {% endif %}
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-lg-2 col-6 ">
                            <div class="ms-auto position-relative">
                                <select name="filter_store" class="form-select auto-filter">
                                    <option value="">{{text_all}}</option>
                                    {% for store in stores %}
                                    <option value="{{ store.store_id }}" {% if filter_store == store.store_id %} selected="selected" {% endif %}>{{store.name}}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="col-lg-2 col-6 ">
                            <div class="ms-auto position-relative">
                                <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                                <input type="text" name="filter_konu" id="input-filter-konu" value="{{filter_konu}}" placeholder="Konusu" class="form-control ps-4 auto-filter">
                            </div>
                        </div>

                        <div class="col-lg-2 col-6 ">
                            <div class="ms-auto position-relative">

                            </div>
                        </div>

                        <div class="col-lg-3 col-6 me-auto">
                            {% for custom_field in custom_fields %}
                            {% if custom_field.location_sort == 'account16' %}
                            <select name="filter_category" class="form-select auto-filter">
                                <option value="">{{text_select}}</option>
                                {% for custom_field_value in custom_field.custom_field_value %}
                                {% if custom_field_value.group == 'dernek' and custom_field_value.status == 1 %}
                                <option value="{{ custom_field_value.custom_field_value_id }}" {% if custom_field_value.custom_field_value_id == filter_category %} selected {% endif %}>{{ custom_field_value.name }}</option>
                                {% endif %}
                                {% endfor %}

                            </select>
                            {% endif %}
                            {% endfor %}
                        </div>



                        <div class="col-lg-2 col-6 col-md-3">
                            <select name="filter_status" class="form-select auto-filter">
                                <option value="">{{text_select}}</option>
                                <option value="0" {% if filter_status == 0 and filter_status !='' %} selected {% endif %}>{{text_wait}}</option>
                                <option value="1" {% if filter_status == 1 %} selected {% endif %}>{{text_olumlu}}</option>
                                <option value="2" {% if filter_status == 2 %} selected {% endif %}>{{text_olumsuz}}</option>
                                <option value="3" {% if filter_status == 3 %} selected {% endif %}>{{text_islem}}</option>
                            </select>
                        </div>

                        <div class="col-lg-1 co1-6 col-md-3">
                            <select name="limit" class="form-select auto-filter">
                                {% for key,value in limits %}
                                <option value="{{value}}" {% if filter_limit == value %} selected="selected" {% endif %}>{{value}}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-information">
                    <div class="card-body">

                        <div class="table-responsive-sm">
                            <table class="table table-striped table-bordered table-hover mb-0">

                                <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                    <tr>

                                        <th colspan="2" class="text-start">
                                            {{ "Derneği" }}
                                        </th>
                                        <th class="text-start">
                                            {{ column_konu }}
                                        </th>
                                        <th class="text-start">
                                            {{ column_date_added }}
                                        </th>
                                        <th class="text-start">
                                            {{ column_category }}
                                        </th>
                                        <th class="text-start">
                                            {{ column_description }}
                                        </th>

                                        <th class="text-center">
                                            {{ column_status }}
                                        </th>
                                        <th class="text-center">{{ column_action }}</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    {% if talepler_dernek %}
                                    {% for talep in talepler_dernek %}
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input" name="selected[]" value="{{ talep.talep_id }}" />
                                        </td>
                                        <td class="text-start ">{{ talep.name}}</td>
                                        <td class="text-start">{{ talep.konu }}</td>
                                        <td class="text-start">{{ talep.date_added}}</td>
                                        <td class="text-start">
                                            <span class="text-dark"><i class="fas fa-angle-double-right"></i> {{ talep.category }}</span>
                                        </td>
                                        <td class="text-start">{{ talep.text }}</td>

                                        <td class="text-center">
                                            {% if talep.status == 0 %}
                                            <span class="badge bg-secondary">{{text_wait }}</span>
                                            {% endif %}

                                            {% if talep.status == 1 %}
                                            <span class="badge bg-success">{{ text_olumlu }}</span>
                                            {% endif %}

                                            {% if talep.status == 2 %}
                                            <span class="badge bg-danger">{{ text_olumsuz }}</span>
                                            {% endif %}

                                            {% if talep.status == 3 %}
                                            <span class="badge bg-info">{{ text_islem }}</span>
                                            {% endif %}

                                            {% if talep.status == 4 %}
                                            <span class="badge bg-info">{{ text_islem }}</span>
                                            {% endif %}

                                        </td>
                                        <td class="text-center">
                                            <button type="button" id="button-view" name="{{ talep.talep_id }}" data-toggle="tooltip" title="{{ text_view }}" class="btn btn-info btn-sm"><i class="bi bi-eye"></i></button>
                                        </td>

                                    </tr>

                                    {% endfor %}

                                    {% else %}
                                    <tr>
                                        <td class="text-center" colspan="7">{{ text_no_results }}</td>
                                    </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
                                {{ pagination }}
                            </div>
                            <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
                                {{ results }}
                            </div>
                        </div>
                </form>
            </div>
        </div>
    </div>

    <div id="modal-new-talep" class="modal fade" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <!-- Modal Header -->
                <div class="modal-header">
                    <h3 class="modal-title">
                        <i class="bi bi-exclamation-circle"></i> Talep Formu
                    </h3>
                    <button type="button" id="button-close" data-bs-dismiss="modal" aria-label="Close" class="btn btn-sm">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="modal-body">
                    <form method="post" id="form-new-talep" class="row g-3">

                        <!-- Name Input -->
                        <div class="col-12">
                            <input type="text" name="name" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
                            <div id="input-name-error"></div>
                        </div>

                        <!-- Category Select -->
                        {% for custom_field in custom_fields %}
                        {% if custom_field.location_sort == 'account16' %}
                        <div class="col-12">
                            <select name="category" class="form-control" id="category-select">
                                {% for custom_field_value in custom_field.custom_field_value %}
                                {% if custom_field_value.group == 'dernek' %}
                                <option value="{{ custom_field_value.custom_field_value_id }}">
                                    {{ custom_field_value.name }}
                                </option>
                                {% endif %}
                                {% endfor %}
                            </select>
                            <div id="input-category-error"></div>
                        </div>
                        {% endif %}
                        {% endfor %}

                        <!-- Textarea -->
                        <div class="col-12">
                            <textarea name="text" rows="5" placeholder="{{ entry_text }}" id="input-text" class="form-control"></textarea>
                            <div id="input-text-error"></div>
                        </div>

                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer">
                    <button type="button" id="button-modal-save" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-info btn-sm">
                        <i class="bi bi-save"></i> Kaydet
                    </button>
                </div>

            </div>
        </div>
    </div>


    <div id="modal-talep-view" class="modal fade" tabindex="-1" aria-labelledby="modal-header-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header bg-light">
                    <h5 class="modal-title" id="modal-header-title">İşlem Formu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" data-bs-toggle="tooltip" title="{{ button_close }}" aria-label="Close"></button>
                </div>

                <div id="modal-view-body1" class="modal-body" style="font-size:14px;">
                </div>

                <div id="modal-view-body" class="modal-body">
                    <form id="form-modal-talepler">

                        <div class="mb-3">
                            <label for="input-gerekce" class="form-label fw-bold">Gerekçe</label>
                            <textarea name="gerekce" id="input-gerekce" rows="3" placeholder="Olumlu veya olumsuz ise kısaca gerekçe yazınız." class="form-control"></textarea>
                            <div class="text-danger small gerekce-select"></div>
                        </div>

                        <div class="mb-3">
                            <label for="select-islem" class="form-label fw-bold">İşlem Tipi</label>
                            <select name="islem" class="form-select" id="select-islem">
                                <option value="" selected>--İşlem Seçin--</option>
                                <option value="1">{{ "Olumlu" }}</option>
                                <option value="2">{{ "Olumsuz" }}</option>
                                <option value="3">{{ "İşleme Alındı" }}</option>
                                <option value="4">{{ "Çözüm Merkezine İlet" }}</option>
                            </select>
                            <div class="text-danger small islem-select"></div>
                        </div>

                    </form>
                </div>

                <div class="modal-footer">
                    <div class="w-100 d-flex justify-content-end">
                        <button type="button" id="button-islem" data-bs-toggle="tooltip" title="{{ 'Kaydet' }}" class="btn btn-info btn-sm">
                            <i class="bi bi-check-lg"></i> {{ "KAYDET" }}
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    {{footer}}
</main>
