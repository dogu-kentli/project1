{{ header }}{{ column_left }}
<main id="universiteler" class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

        <div class="ms-auto text-end me-3">
         <a href="{{ export }}" data-toggle="tooltip" title="Exel Dökümü" class="btn btn-success border border-success shadow-sm btn-sm" {{disabled}}><i class="bi bi-filetype-xls"></i></a>
         <button type="button" id="button-clear" data-toggle="tooltip" title="{{ "Filtreyi Temizle" }}" class="btn btn-light border border-dark shadow-sm btn-sm bg-white" ><i class="bi bi-filter"></i></button>
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-12 me-auto">
                            <div class="ms-auto position-relative">
                                <select name="filter_store" id="input-store" class="form-select auto-filter">
                                <option value="">{{ "--Derneği--" }}</option>
                                {% for store in stores %}
                                  <option value="{{ store.store_id }}" {% if store.store_id == filter_store %} selected="selected" {% endif %}>{{ store.name }}</option>
                                {% endfor %}
                                 </select>
                               
                            </div>
                        </div>

                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-information">
                    <div class="card-body">
                      <div class="table-responsive-sm">
                        <table class="table table-bordered table-striped align-middle mb-0">
                           <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                <tr >
                                    <th style="width: 60px;" class="text-center">#</th>
                                    <th style="width: 30%;" class="text-start">{{ "Kurum" }}</th>
                                    <th style="width: 25%;" class="text-start">{{ "Öğrenci Adı" }}</th>
                                    <th style="width: 25%;" class="text-start">{{ "Derneği" }}</th>
                                    <th style="width: 15%;" class="text-start">{{ "Tarih" }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set row_count = row %}
                                {% if reports %}
                                    {% for report in reports %}
                                    <tr>
                                        <td class="text-center">
                                            <span class="badge rounded-pill bg-light text-dark border fw-normal shadow-sm" style="font-size: 0.85rem;">
                                                {{ row_count }}
                                            </span>
                                        </td>
                                        
                                        <td class="text-wrap fw-bold text-dark" style="word-break: break-word; font-size: 0.9rem;">
                                            {{ report.kurum }}
                                        </td>
                                        
                                        <td class="text-wrap">
                                            <a href="{{report.edit}}" class="text-decoration-none fw-semibold link-primary">
                                                {{ report.name }}
                                            </a>
                                        </td>
                                        
                                        <td class="text-wrap text-secondary" style="font-size: 0.9rem;">
                                            {{ report.store['name'] }}
                                        </td>
                                        
                                        <td class="text-nowrap small text-muted">
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-calendar3 me-2 text-primary" style="font-size: 0.8rem;"></i>
                                                {{ report.date_added }}
                                            </div>
                                        </td>
                                    </tr>
                                    {% set row_count = row_count + 1 %}
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td class="text-center py-5 text-muted" colspan="5">
                                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                            {{ text_no_results }}
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>

                       <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
                </form>
            </div>
        </div>


    </div>

    {{footer}}
</main>

<script type="text/javascript"><!--
$('.auto-filter').on('change', function() {
   $('#cover-spin').show(0);
	var url = 'index.php?route=report/cart_transaction&user_token={{ user_token }}';
	
	var filter_store = $('select[name=\'filter_store\']').val();
	
	if (filter_store) {
		url += '&filter_store=' + encodeURIComponent(filter_store);
	}
		
	location =  url;
});


$('#button-clear').on('click', function() {
	url = 'index.php?route=report/cart_transaction&user_token={{ user_token }}';
	location = url;
});

//--></script> 