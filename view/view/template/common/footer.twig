<script>
    function epostaDogrulama() {
        
        $.ajax({
            url: 'index.php?route=common/dashboard/emailCode&user_token={{user_token}}',
            dataType: 'json',

            success: function(json) {
                if (json.error.warning) {
                    alerterror(json.error.warning);
                }

                if (json.success) {
                    alertsuccess(json.success);
                    $('#modal-dogrulama input[name=\'code\']').prop('disabled',false);
                    $('#modal-dogrulama').modal('show');
                }
            },

            error: function(xhr, ajaxOptions, thrownError) {
                console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }

        });
    }
  </script>
  <script>
    $('#button-dogrulama').on('click', function() {
        $.ajax({
             url: 'index.php?route=common/dashboard/dogrulama&user_token={{user_token}}',
            type: 'post',
            data: 'code=' + $('#modal-dogrulama input[name=\'code\']').val(),
            dataType: 'json',

            beforeSend: function() {
                $('#button-dogrulama').buttonanimate('loading');
            },

            complete: function() {
                $('#button-dogrulama').buttonanimate('reset');
            },

            success: function(json) {
                if (json.error.warning) {
                  alerterror(json.error.warning);
                }

                if (json.success) {
                     $('#modal-dogrulama').modal('hide');
                    location = json.success;
                }

            },

            error: function(xhr, ajaxOptions, thrownError) {
                console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }

        });

    });
</script>
<script>
$(document).ready(function() {
	 $('#alert').observe(function() {
        window.setTimeout(function() {
            $('#alert .alert-dismissible').fadeTo(3000, 0, function() {
                $(this).remove();
            });
        }, 3000);
    });
 });

 +function($) {
    $.fn.observe = function(callback) {
        observer = new MutationObserver(callback);

        observer.observe($(this)[0], {
            characterData: false,
            childList: true,
            attributes: false
        });
    };
}(jQuery);

</script>

