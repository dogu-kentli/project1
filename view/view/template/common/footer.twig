        }
    });
});
</script>

<script>
$(document).ready(function(){
  $("#menu > li").each(function(){
    let parentTitle = $(this).find(".menu-title").first().text().trim();
    let children = $(this).find("ul li a");

    if(children.length > 0){
      let $optgroup = $("<optgroup>", { label: parentTitle });

      children.each(function(){
        let childName = $(this).text().trim();
        $optgroup.append($("<option>", { 
          text: childName, 
          value: childName
        }));
      });

      // Select içine ekle
      $("#feedbackSection").append($optgroup);
    }
  });
});

</script>

<script>
$('#button-modal-feedback').on('click', function() {
    $('.text-danger').find('span').remove();
    var bildirim_tipi = $('input[name=\'bildirim_tipi\']:checked').val();
    $.ajax({
      url: 'index.php?route=setting/user_feedback/savefeedback&user_token={{ user_token }}',
      type: 'post',
      dataType: 'json',
      data: $('#form-modal-feedback').serialize() + '&bildirim_tipi=' + encodeURIComponent(bildirim_tipi),

      beforeSend: function() {
            $('#button-modal-feedback').buttonanimate('loading');
       },

        complete: function() {
            $('#button-modal-feedback').buttonanimate('reset');
        },
        success: function(json) {

       if (json.error.warning) {
          alerterror(json.error.warning);
       }
       
       if (json.success) {
        $('#feedback-data').load('index.php?route=setting/user_feedback/dataFeedback&user_token={{ user_token }}');
         $('#modal-feedback').modal('hide');
          Swal.fire({     
            text: 'Geri Bildiriminiz başarıyla kayıt edildi. En kısa zamanda incelenip geri dönüş yapılacaktır.',
            icon: 'success',
            confirmButtonText: 'Tamam',
            width: '400px', // kutu genişliğini küçült
            customClass: {
                popup: 'small-swal-popup',
                title: 'small-swal-title',
                confirmButton: 'btn-sm'
            }
            });
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });
 });
</script>
<script type="text/javascript"><!--
$('#button-upload-feedback').on('click', function() {
	$('#form-upload').remove();

	$('body').prepend('<form enctype="multipart/form-data" id="form-upload" style="display: none;"><input type="file" name="file" /></form>');

	$('#form-upload input[name=\'file\']').trigger('click');

	if (typeof timer != 'undefined') {
    	clearInterval(timer);
	}

	timer = setInterval(function() {
		if ($('#form-upload input[name=\'file\']').val() != '') {
			clearInterval(timer);

			$.ajax({
				url: 'index.php?route=catalog/download/upload&user_token={{ user_token }}&bolum="bildirim"',
				type: 'post',
				dataType: 'json',
				data: new FormData($('#form-upload')[0]),
				cache: false,
				contentType: false,
				processData: false,
				beforeSend: function() {
					$('#button-upload-feedback').buttonanimate('loading');
				},
				complete: function() {
					$('#button-upload-feedback').buttonanimate('reset');
				},
				success: function(json) {
                 $('.alert-dismissible').remove();
					if (json.error) {
                      alerterror(json.error);
					}

					if (json.success) {
						$('#modal-feedback .filename').val(json['filename']);
                        $('#modal-feedback .code').val(json['code']);
                        alertsuccess(json.success);
        
					}
				},
				error: function(xhr, ajaxOptions, thrownError) {
					alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
				}
			});
		}
	}, 500);
});
//--></script>
