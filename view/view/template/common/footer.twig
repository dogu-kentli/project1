
<div id="cover-spin" style="display:none;"></div>
<div align="center">{{ text_footer }}<br />{{ text_version }}</div>
<div class="modal fade" id="modal-store" tabindex="-1" aria-labelledby="exampleModalLabel" aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div id="modal-body" class="modal-body">

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>

            </div>
        </div>
    </div>
</div>

<div class="switcher-body">

    <div class="offcanvas offcanvas-end shadow border-start-0 p-0" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Görüntü Ayarları</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" onclick="$('.offcanvas').removeClass('show');"></button>
        </div>
        <div id="offcanvas-popover" class="offcanvas-body">

            <div class="form-check form-check-inline">
                <input class="form-check-input form-check-input-theme" type="radio" for="#018bd3" name="inlineRadioOptions" id="MinimalTheme" value="minimal-theme" {% if theme == 'minimal-theme' %} checked {% endif %}>
                <label class="form-check-label" for="MinimalTheme">Açık Renk</label>
            </div>
            
            <div class="form-check form-check-inline">
                <input class="form-check-input form-check-input-theme" type="radio" for="#fff" name="inlineRadioOptions" id="DarkTheme" value="dark-theme" {% if theme == 'dark-theme' %} checked {% endif %}>
                <label class="form-check-label" for="DarkTheme">Koyu</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input form-check-input-theme" type="radio" for="#fff" name="inlineRadioOptions" id="SemiDarkTheme" value="semi-dark" {% if theme == 'semi-dark' %} checked {% endif %}>
                <label class="form-check-label" for="SemiDarkTheme">Yarı koyu</label>
            </div>

            <hr />

            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Sol Menü Ayarları</h5>
            <div class="form-check form-check-inline">
                <input class="form-check-input input-sidebar" type="radio" name="menu_sidebar" id="inpu-sidebar1" value="1" {% if sidebar  == 1 %} checked {% endif %}>
                <label class="form-check-label" for="acik">Kapalı Menü</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input input-sidebar" type="radio" name="menu_sidebar" id="inpu-sidebar12" value="2" {% if sidebar == 2 %} checked {% endif %}>
                <label class="form-check-label" for="kapali">Açık Menü</label>
            </div>
           
            <hr />
            {% if level %}
            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Geliştirici Ayarlarıı</h5>
            <hr />
            <div class="form-check form-switch">
                <input class="form-check-input form-check-developer" data-toggle="tooltip" title="Tema önbelleği kapatırsanız sayfa yüklenmesi yavaşlar. Geliştirme durumlarında kapatılması önerilir" data-for="theme" name="developer_theme" value="1" type="checkbox" id="developer-theme" {% if developer_theme %} checked {% endif %}>
                <label class="form-check-label" for="flexSwitchCheckDefault">Tema Önebbeleği</label>
            </div>
           
            <div class="form-check form-switch">
                <input class="form-check-input form-check-developer" data-toggle="tooltip" title="Dinamik css ön işlemcisi için açık kalması önerilir." name="developer_sass" value="1" type="checkbox" data-for="sass" id="developer-sass" {% if developer_sass %} checked {% endif %}>
                <label class="form-check-label" for="flexSwitchCheckDefault">SASS</label>
            </div>
            
            <hr />
            {% endif %}
            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Font Boyutu</h5>
            <hr />
            <div class="d-flex align-items-center gap-2 my-3">
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 10 %} active {% endif %}" data-size="10">10</button>
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 12 %} active {% endif %}" data-size="12">12</button>
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 14 %} active {% endif %}" data-size="14">14</button>
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 16 %} active {% endif %}" data-size="16">16</button>
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 18 %} active {% endif %}" data-size="18">18</button>
                <button type="button" class="btn btn-outline-info btn-sm font-size-btn {% if font_setting == 20 %} active {% endif %}" data-size="20">20</button>
            </div>

            <hr />
            <h6 class="mb-0">Tema Seti Renk Ayarları</h6>
            <hr />
            <div class="header-colors-indigators">
                <div class="row row-cols-auto g-1">
                    <!-- Renk kutuları -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor1" data-class="headercolor1" data-color="#0d6efd"></div></div> <!-- Mavi -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor2" data-class="headercolor2" data-color="#0891b2"></div></div> <!-- Yeşil -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor3" data-class="headercolor3" data-color="#dc3545"></div></div> <!-- Kırmızı -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor4" data-class="headercolor4" data-color="#fd7e14"></div></div> <!-- Turuncu -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor5" data-class="headercolor5" data-color="#ffc107"></div></div> <!-- Sarı -->
                    <div class="col"><div style="width:40px;height:40px;" class="indigator headercolor6" data-class="headercolor6" data-color="#20c997"></div></div> <!-- Turkuaz -->                   
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modal-dogrulama" tabindex="-1" aria-labelledby="emailVerifyLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      
      <!-- Header -->
      <div class="modal-header">
        <h5 class="modal-title" id="emailVerifyLabel">
          <i class="bi bi-envelope-check-fill text-primary me-2"></i> E-posta Doğrulama
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      
      <!-- Body -->
      <div class="modal-body">
        <p class="mb-3">E-posta adresinize bir doğrulama kodu gönderildi. Lütfen aşağıya giriniz:</p>
        <form id="verifyForm">
          <div class="mb-3">
            <label for="verificationCode" class="form-label fw-bold">Doğrulama Kodu</label>
            <input type="text" name="code" class="form-control" id="input-dogrulama-code" placeholder="123456" disabled>
          </div>
        </form>
      </div>
      
      <!-- Footer -->
      <div class="modal-footer">
        <button type="button" id="button-dogrulama" class="btn btn-sm btn-info">Doğrula</button>
      </div>
      
    </div>
  </div>
</div>
</div>

<div class="modal fade" id="modal-feedback" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered"> 
    <div class="modal-content shadow">
      
      
      <form id="form-modal-feedback">

        <div class="modal-header border-bottom-0">
          <h4 class="modal-title fw-bold " id="exampleModalLabel">Geri Bildirim Formu</h4>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
        </div>
        
        <div class="modal-body">
           <input type="hidden" name="feedback_id" value="0">
          
          <div class="alert alert-secondary mb-4" style="max-height:180px; overflow-y:auto;">
            <h6 class="fw-bold border-bottom pb-2 mb-3">
                <i class="bi bi-info-circle me-2"></i> Geri Bildirim Bilgilendirmesi
            </h6>
            <p class="mb-2 small">
                Değerli kullanıcı,<br>
                Geri bildirimleriniz bizim için değerlidir. Sürecin daha hızlı ve sağlıklı ilerleyebilmesi için lütfen geri bildirimlerinizi açık ve anlaşılır şekilde iletiniz.
            </p>
            <ol class="small ps-3 mb-2">
                <li>Sorun veya talebinizi kısa ve net bir şekilde açıklayınız.</li>
                <li>Hata bildirimi yapıyorsanız, mümkünse ekran görüntüsü veya fotoğraf ekleyiniz.</li>
                <li>Yeni bir fonksiyon,özellik veya değişiklik için,öneri seçeneğini seçiniz.</li>
                <li>Gerekli durumlarda ek bilgi ve görseller paylaşınız.</li>
                <li>Geri bildirimlerinizin durumunu aynı bölüm üzerinden takip edebilirsiniz.</li>
                <li>Kullanım mecrası (Sosyal medya, baskı vb.)</li>
            </ol>
            <p class="small mb-0">
                Göstermiş olduğunuz ilgi ve katkılarınız için teşekkür ederiz. Paylaştığınız her geri bildirim, hizmetlerimizin ve sistemimizin daha da geliştirilmesine katkı sağlayacaktır.
            </p>
          </div>
          
          <div class="alert bg bg-light-danger mb-4 note" style="display:none"></div>

          <div class="mb-3">
            <label class="form-label fw-bold">Geri Bildirim Seçenekleri:</label>
            <div class="d-flex flex-wrap gap-3 p-3 border border-secondary-subtle rounded bg-light-subtle">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="bildirim_tipi" value="1" checked="checked">
                <label class="form-check-label fw-medium">Şikâyet</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="bildirim_tipi" value="2">
                <label class="form-check-label fw-medium">Öneri / Yeni Özellik </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="bildirim_tipi" value="3">
                <label class="form-check-label fw-medium">Hata Bildirimi</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="bildirim_tipi" value="4">
                <label class="form-check-label fw-medium">Diğer</label>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">İlgili Bölüm</label>
            <select class="form-select border-secondary-subtle" id="feedbackSection" name="bolum">
                <option value="">Seçiniz...</option>
            </select>
          </div>

          <div class="mb-4">
            <label for="oncelikRange" class="form-label fw-bold">Öncelik Seviyesi</label>
            <div class="px-2">
              <input type="range" class="form-range slider-success" min="1" max="3" step="1" id="oncelikRange" name="oncelik" value="1">
              <div class="row text-center mt-1 fs-7 text-muted">
                <div id="lbl-dusuk" class="col-4 text-start text-success fw-bold opacity-100">🟢 Düşük</div>
                <div id="lbl-orta" class="col-4 text-warning opacity-50">🟡 Orta</div>
                <div id="lbl-yuksek" class="col-4 text-end text-danger opacity-50">🔴 Yüksek</div>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Detaylı Açıklama</label>
            <textarea name="description" rows="4" placeholder="Şikayet, öneri, hata bildirimi veya yeni taleplerinizi buraya detaylı şekilde yazınız..." class="form-control border-secondary-subtle" required></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Görsel Ekle</label>
            <div class="input-group">
              <input type="text" name="filename[filename]" class="form-control filename" placeholder="Seçilen dosya yok" readonly>
              <input type="hidden" name="filename[code]" class="form-control code" placeholder="Seçilen dosya yok" readonly>
              <button type="button" id="button-upload-feedback" class="btn btn-outline-info">
                <i class="bi bi-cloud-arrow-up me-2"></i> Gözat
              </button>
            </div>
            <div class="form-text"><strong>Not :</strong> İzin verilen dosya tipleri {{filetype}}</div>
          </div>
        </div>
        
        <div class="modal-footer bg-light border-top-0">
          <button type="button" id="button-modal-feedback" class="btn btn-primary px-4 fw-semibold">Kaydet</button>
        </div>

      </form> <!-- FORM ETİKETİNİ BURADA KAPATIYORUZ -->

    </div>
  </div>
</div>
