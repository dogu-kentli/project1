<!doctype html>
<html lang="tr" class="minimal-theme">
<head>
  <!-- Required meta tags -->
  <title>{{"UDEF ADMİN PANELİ"}}</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" href="https://udef.org.tr/obs/image/favicon.png" type="image/png" />
  <!-- Bootstrap CSS -->
  <link href="view/stylesheet/bootstrap.min.css?v=987888" rel="stylesheet" />
  <link href="view/stylesheet/bootstrap-extended.css" rel="stylesheet" />
  <link href="view/stylesheet/style.css" rel="stylesheet" />
  <!-- jQuery 3.7.1 minified CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <link href="view/stylesheet/style.css" rel="stylesheet" />
  <link href="view/stylesheet/icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css">
  <script src="view/javascript/bootstrap.bundle.min.js"></script>
  <script src="view/javascript/jquery.min.js"></script>

</head>
<body class="bg-surface">
    {% if error_warning %}
	   <div id="alert" class="alert border-0 border-danger border-start border-2 bg-danger alert-dismissible fade show py-2">
        <div class="d-flex align-items-center">
          <div class="fs-3 text-white"><i class="bi bi-x-circle-fill"></i></div>
          <div class="ms-3"><div class="text-white"> {{ error_warning }} </div></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
	 {% endif %}
     <div class="wrapper">
	 
	  <header style="display:none;">
          <nav class="navbar navbar-expand-lg navbar-light bg-white rounded-0 border-bottom">
            <div class="container">
              <a class="navbar-brand" href="#"><img src="view/image/logo.png" width="110" alt=""/></a>
              <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav mb-2 mb-lg-0 align-items-center">
                  
                 
                </ul>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                  <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle dropdown-toggle-nocaret" href="#" data-bs-toggle="dropdown">
                     
                    </a>
                    <ul class="dropdown-menu">
                      
                    </ul>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" href="javascript:;"></a>
                  </li>
                </ul>
                <div class="d-flex ms-3 gap-3">
                  <a href="authentication-signin-with-header-footer.html" class="btn btn-primary btn-sm px-4 radius-30">Login</a>
                  <a href="authentication-signup-with-header-footer.html" class="btn btn-white btn-sm px-4 radius-30">Register</a>
                </div>
              </div>
            </div>
          </nav>
       </header>
     
       <main class="authentication-content">
        <div class="container-fluid">
		
          <div class="authentication-card">
		 
            <div class="card shadow rounded-0 overflow-hidden">
              <div class="row g-0">
                <div class="col-lg-6 bg-login d-flex align-items-center justify-content-center">
                  {% if config_banner %}
                  <img src="{{config_banner}}" width="485" height="auto" class="img-fluid" alt="">
                  {% endif %}
                </div>
                <div class="col-lg-6">
                  <div class="card-body p-5 p-sm-5">
                    <h5 class="card-title">UDEF YÖNETİCİ GİRİŞ EKRANI</h5>
                    <p class="card-text mb-5">Kullanıcı adınızı ve parolanızı girerek sisteme giriş yapabilirsiniz. Giriş yaptıktan sonra, dilerseniz kullanıcılar bölümünden şifre ve kullanıcı bilgilerinizi değiştire bilirsiniz..
                    🔒 Giriş bilgilerinizi kimseyle paylaşmayınız. Güvenliğiniz için bu bilgileri gizli tutmanız önerilir.</p>
					 <form action="{{ action }}" method="post" class="form-body" enctype="multipart/form-data">
                     
                      <div class="login-separater text-center mb-4"> <span>Kullanıcı adı ve şifrenizi yazarak giriş yapınız.</span>
                        <hr>
                      </div>
                        <div class="row g-3">
                          <div class="col-12">
                            <label for="inputEmailAddress" class="form-label">{{ entry_username }}</label>
                            <div class="ms-auto position-relative">
                              <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-person-circle"></i></div>
                              <input type="text" name="username" value="{{ username }}" class="form-control radius-25 ps-5" id="input-username" placeholder="{{ entry_username }}">
                            </div>
                          </div>
                          <div class="col-12">
                            <label for="inputChoosePassword" class="form-label">{{ entry_password }}</label>
                            <div class="ms-auto position-relative">
                              <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-lock-fill"></i></div>
                              <input type="password" name="password" value="{{ password }}" class="form-control radius-25 ps-5" id="input-password" placeholder="{{ entry_password }}">
                            </div>
                          </div>
                          <div class="col-6">
                            <div class="form-check form-switch">
                              <input class="form-check-input" type="checkbox" id="toggle-password" >
                              <label class="form-check-label" for="flexSwitchCheckChecked">Şifreyi Göster</label>
                            </div>
                          </div>
                          <div class="col-6 text-end">	<a href="{{forgotten}}">{{ text_forgotten }}</a>
                          </div>
                          <div class="col-12">
                            <div class="d-grid">
                              <button type="submit" class="btn btn-primary btn-lg radius-20">{{ "OTURUM AÇ" }}</button>
                            </div>
                          </div>
                          
                        </div>
						{% if redirect %}
                        <input type="hidden" name="redirect" value="{{ redirect }}" />
                        {% endif %}
                    </form>
                 </div>
                </div>
              </div>
            </div>
          </div>
        </div>
       </main>
	   
	   <footer class="bg-white border-top p-3 text-center fixed-bottom" style="display:none;">
        <p class="mb-0">{{powvered}}</p>
      </footer>
        
       <!--end page main-->

  </div>
  <!--end wrapper-->


  <!--plugins-->
  <script src="view/javascript/jquery-3.7.1.min.js"></script>
 <script src="view/javascript/pace.min.js"></script>
  
</body>
<script>
$(document).ready(function () {
    setTimeout(function () {
        $('.alert-dismissible').fadeTo(3000, 0, function() {
            $(this).remove();
        });
    }, 3000);
});
</script>

<script>
$(function() {
  $('#toggle-password').on('change', function() {
    const input = $('#input-password');
    input.attr('type', this.checked ? 'text' : 'password');
  });
});
</script>



</html>