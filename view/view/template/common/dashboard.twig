<script>
    $(document).on('click', '.sort', function(e) {
        e.preventDefault();
        $('#cover-spin').show(0);

        var target = $(this).data('id');
        var href = $(this).attr('href');

        // Özel tarih seçeneği ise inputlardan değerleri al
        if ($(this).data('custom')) {
            $('#cover-spin').hide();
            return;
        }

        $(target).load(href, function() {
            $('#cover-spin').hide();
        });
    });

    // Tarih inputları değiştiğinde otomatik çalışacak
    $(document).on('blur', '.date-sort', function() {
        $('#cover-spin').show(0);

        var target = $(this).data('id');
        var href = $(this).data('link'); // parametresiz base URL

        var date_start = $(target + " input[name='date_start']").val();
        var date_end = $(target + " input[name='date_end']").val();

        if (!date_start || !date_end) {
            $('#cover-spin').hide();
            return;
        }

        href += '&date_start=' + encodeURIComponent(date_start) + '&date_end=' + encodeURIComponent(date_end);

        $(target).load(href, function() {
            $('#cover-spin').hide();
        });

        console.log(href);
    });


    // Sayfa ilk açıldığında default yüklemeler
    $('#dernekler-data').load('index.php?route=extension/dashboard/dernekler/datadernek&user_token={{ user_token }}');
    $('#basvuru-data').load('index.php?route=extension/dashboard/basvuru/databasvuru&user_token={{ user_token }}');
    $('#etkinlik-data').load('index.php?route=extension/dashboard/etkinlik/dataetkinlik&user_token={{ user_token }}');
</script>



<link type="text/css" href="view/javascript/jquery/jqvmap/jqvmap.css" rel="stylesheet" media="screen" />
<script type="text/javascript" src="view/javascript/jquery/jqvmap/jquery.vmap.js"></script>
<script type="text/javascript" src="view/javascript/jquery/jqvmap/maps/jquery.vmap.turkey.js"></script>
<script type="text/javascript">
    $(document).ready(function() {
        $.ajax({
            url: 'index.php?route=extension/dashboard/map/map&user_token={{ user_token }}',
            dataType: 'json',
            success: function(json) {
                var data = {}; // data object olarak tanımlandı

                // json içindeki verileri harita için uygun formata dönüştürme
                $.each(json, function(code, value) {
                    data[code] = value.total;
                });

                // 2. jVectorMap Haritasını Başlatma
                $('#vmap').vectorMap({
                    map: 'turkey_tr',
                    backgroundColor: '',
                    borderColor: '#fff',
                    color: '#919190',
                    hoverColor: '#000000',
                    borderColor: '#818181',
                    selectedColor: '#ccc',
                    scaleColors: ['#23a1d1'],
                    enableZoom: true,
                    showTooltip: true,
                    values: data,
                    normalizeFunction: 'polynomial',

                    // Harita üzerine gelindiğinde (Tooltip)
                    onLabelShow: function(event, label, code) {
                        if (json[code]) {
                            // Düzeltme: Gizli Span ID'si için bölge kodu olan 'code' kullanıldı.
                            // Bu span, tıklama anında bölge ID'sini almak için kullanılıyor.
                            label.html('<strong>' + label.text() + '</strong><br/>' + json[code]['name'] + '<br /><span id="il-' + code + '" style="display:none;">' + json[code]['total'] + '</span>');
                        }
                    },

                    // Harita bölgesine tıklandığında
                    onRegionClick: function(event, code, regionName) {
                        // Gizli spandan haritaya ait benzersiz ID'yi (il_id) alıyoruz.
                        var il_id = $('#il-' + code).text();

                        if (il_id === '') {
                            console.log('Bölge (' + regionName + ') için detay verisi bulunamadı.');
                            return;
                        }

                        // 3. Detay Bilgilerini Çekme (AJAX)
                        $.ajax({
                            url: 'index.php?route=extension/dashboard/map/info&user_token={{ user_token }}&code=' + il_id,
                            dataType: 'json',
                            success: function(json) {
                                // Önceki sonuçları temizle
                                $('#modal-body').empty(); // Modal içeriğini tamamen temizle
                                var html = '<div class="row">'; // Bootstrap row ile başladık

                                if (json.store && json.store.length > 0) {
                                    $.each(json.store, function(i, store) {
                                        var divclass = (json.store.length > 1) ? 'col-sm-12 col-md-6' : 'col-sm-12';

                                        html += '<div class="' + divclass + ' mt-3">'; // Tekil mağaza/dernek kartı
                                        // **Bootstrap 5 list-group yapısı**
                                        html += ' <div class="list-group">';

                                        // Logo
                                        html += ' <div class="list-group-item text-center">';
                                        html += '  <img src="' + store.logo + '" class="img-thumbnail" alt="' + store.name + '">';
                                        html += ' </div>';

                                        // Başlık + Sosyal Medya
                                        html += ' <div class="list-group-item bg-primary text-white d-flex justify-content-between align-items-center">';
                                        html += '  <strong>' + store.name + '</strong>';
                                        html += '  <span class="d-flex gap-2">';
                                        html += '  <a href="' + store.in_url + '" target="_blank" class="text-white"><i class="fab fa-instagram"></i></a>';
                                        html += '  <a href="' + store.fb_url + '" target="_blank" class="text-white"><i class="fab fa-facebook"></i></a>';
                                        html += '  <a href="' + store.tw_url + '" target="_blank" class="text-white"><i class="fab fa-twitter"></i></a>';
                                        html += '  <a href="' + store.yt_url + '" target="_blank" class="text-white"><i class="fab fa-youtube"></i></a>';
                                        html += '  </span>';
                                        html += ' </div>';
                                        html += ' <div class="list-group-item d-flex justify-content-between"><span><strong>Dernek Başkanı:</strong></span> <span>' + store.baskan + '</span></div>';
                                        html += ' <div class="list-group-item d-flex justify-content-between"><span><strong>Başkan Telefon:</strong></span> <span>' + store.telephone2 + '</span></div>';
                                        html += ' <div class="list-group-item d-flex justify-content-between"><span><strong>Dernek Telefon:</strong></span> <span>' + store.telephone + '</span></div>';
                                        html += ' <a href="' + store.web + '" target="_blank" class="list-group-item list-group-item-action"><i class="fa fa-globe text-primary me-2"></i> ' + store.web + '</a>';
                                        html += ' <div class="list-group-item"><i class="fa fa-envelope text-primary me-2"></i> ' + store.email + '</div>';
                                        html += ' <div class="list-group-item"><i class="fa fa-map-marker text-primary me-2"></i> ' + store.address + '</div>';
                                        html += ' <div class="list-group-item"><i class="fa fa-user text-primary me-2"></i> Toplam Üye Sayısı: <strong>' + store.total + '</strong></div>';
                                        html += ' </div>'; // list-group DIV'i kapandı
                                        html += '</div>'; // col DIV'i kapandı
                                    });
                                }
                                html += '</div>'; // row DIV'i kapandı

                                $('#modal-body').append(html);

                                // Modal boyutunu ayarlama
                                if (json.store && json.store.length > 1) {
                                    $('#modal-store').find('.modal-dialog').removeClass('modal-sm').addClass('modal-md'); // Birden çok sonuç varsa daha geniş (xl)
                                } else {
                                    $('#modal-store').find('.modal-dialog').addClass('modal-md').removeClass('modal-sm'); // Tek sonuç varsa küçük (sm)
                                }

                                var modalEl = document.getElementById('modal-store');
                                var modal = new bootstrap.Modal(modalEl);
                                modal.show();
                            }
                        });
                    }
                });
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert("AJAX Hatası:\r\n" + thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    });
</script>

<script>
  $(function () {
        "use strict";

        // veriyi burada tanımlıyoruz
        const dataFromTwig = {{bolgeler|default([])|json_encode|raw}};

        if (!Array.isArray(dataFromTwig) || dataFromTwig.length === 0) return;

        const chartSeries = [];
        const chartLabels = [];
        const chartColors = [];

        const colorMap = {
            primary: "#3361ff",
            danger: "#e72e2e",
            success: "#12bf24",
            warning: "#ff6632",
            info: "#89b3f7",
            purple: "#d54be4"
        };

        dataFromTwig.forEach(item => {
            chartSeries.push(Number(item.total)); // 0 olsa bile push et
            chartLabels.push(item.name);
            chartColors.push(colorMap[item.color] || "#999999");
        });

        const options = {
            series: chartSeries,
            labels: chartLabels,
            colors: chartColors,
            chart: {
                type: 'donut',
                height: 310,
                width: '100%',
                
                toolbar: {
                    show: false
                }
            },
            // TOOLTIP DÜZELTMESİ
            tooltip: {
                enabled: true,
                shared: false,
                intersect: true,
                theme: '',
                y: {
                    formatter: function(val) {
                        return val;
                    },
                    title: {
                        formatter: function(seriesName) {
                            return seriesName + ":";
                        }
                    }
                }
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '65%',
                    },
                    // Dilimin grafikte her halükarda yer kaplamasını sağlar
                    dataLabels: {
                        minAngleToShowLabel: 0.1 // 0.1 derece bile olsa etiketi (yüzdeyi) göster
                    }
                }
            },

            dataLabels: {
                enabled: true,
                minAngleToShowLabel: 0.1, // Buraya da ekliyoruz
                formatter: function(val) {
                    return val.toFixed(1) + "%";
                },
                dropShadow: {
                    enabled: true
                }
            },

            legend: {
                show: false
            },
            stroke: {
                colors: ['#ffffff'],
                width: 2
            }
        };

        // Eski grafiği temizleyip yenisini bas (Çakışma olmasın)
        const chartElement = document.querySelector("#chart3");
        chartElement.innerHTML = '';
        const chart = new ApexCharts(chartElement, options);
        chart.render();
    });
</script>
<script>
    $(document).ready(function() {
        function startCountdowns() {
            $('.countdown-wrapper').each(function() {
                var $wrapper = $(this);
                var targetDateString = $wrapper.data('datetime'); // ISO formatındaki tarih (YYYY-MM-DDTHH:mm)

                // Hedef tarihi milisaniyeye çevir
                var countDownDate = new Date(targetDateString).getTime();

                // Eğer gelen tarih geçersizse konsola yaz ve geç
                if (isNaN(countDownDate)) {
                    console.error("Geçersiz tarih formatı:", targetDateString);
                    return;
                }

                // Her eleman için ayrı bir zamanlayıcı (interval) başlat
                var x = setInterval(function() {
                    var now = new Date().getTime();
                    var distance = countDownDate - now;

                    // Süre bittiyse
                    if (distance < 0) {
                        clearInterval(x);
                        $wrapper.addClass('d-none'); // Geri sayımı gizle
                        $wrapper.siblings('.countdown-finished').removeClass('d-none'); // "Başladı" badge'ini göster
                        return;
                    }

                    // Gün, Saat, Dakika ve Saniye hesaplamaları
                    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    // Başına sıfır ekleme fonksiyonu (Örn: 5 yerine 05 göstermek için)
                    days = days < 10 ? "0" + days : days;
                    hours = hours < 10 ? "0" + hours : hours;
                    minutes = minutes < 10 ? "0" + minutes : minutes;
                    seconds = seconds < 10 ? "0" + seconds : seconds;

                    // HTML içeriklerini güncelle
                    $wrapper.find('.days').text(days);
                    $wrapper.find('.hours').text(hours);
                    $wrapper.find('.minutes').text(minutes);
                    $wrapper.find('.seconds').text(seconds);

                }, 1000);
            });
        }

        // Fonksiyonu tetikle
        startCountdowns();
    });
</script>
