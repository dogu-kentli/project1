    <div class="stats-grid">
        <div class="stat-card border-instagram">
            <i class="fab fa-instagram social-icon" style="color: #E1306C;"></i>
            <span class="social-name">INSTAGRAM</span>
            <div class="social-data">
                <div><span>Takipçi</span><strong>{{ teskilat_raporu.sosyal_hesaplar.instagram_takipci }}</strong></div>
                <div><span>İçerik</span><strong>{{ teskilat_raporu.sosyal_hesaplar.instagram_icerik }}</strong></div>
