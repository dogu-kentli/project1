        <div class="stat-card"><span>ORTALAMA KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.egitim_sohbetler.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_sohbetler.program2}}</strong></div>
        <div class="stat-card"><span>ORTALAMA KATILIMCI SAYISI <br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_sohbetler.katilim2}}</strong></div>
