            <i class="fab fa-facebook-f social-icon" style="color: #1877F2;"></i>
            <span class="social-name">FACEBOOK</span>
            <div class="social-data">
                <div><span>Takipçi</span><strong>{{ teskilat_raporu.sosyal_hesaplar.facebook_takipci }}</strong></div>
                <div><span>İçerik</span><strong>{{ teskilat_raporu.sosyal_hesaplar.facebook_icerik }}</strong></div>
            </div>
        </div>
        <div class="stat-card border-x">
            <i class="fab fa-x-twitter social-icon" style="color: #000;"></i>
            <span class="social-name">X (TWITTER)</span>
            <div class="social-data">
                <div><span>Takipçi</span><strong>{{ teskilat_raporu.sosyal_hesaplar.twitter_takipci }}</strong></div>
                <div><span>İçerik</span><strong>{{ teskilat_raporu.sosyal_hesaplar.twitter_icerik }}</strong></div>
            </div>
        </div>
        <div class="stat-card border-youtube">
            <i class="fab fa-youtube social-icon" style="color: #FF0000;"></i>
            <span class="social-name">YOUTUBE</span>
            <div class="social-data">
                <div><span>Takipçi</span><strong>{{ teskilat_raporu.sosyal_hesaplar.youtube_takipci }}</strong></div>
                <div><span>İçerik</span><strong>{{ teskilat_raporu.sosyal_hesaplar.youtube_icerik }}</strong></div>
            </div>
        </div>
    </div>
</div>

<script>
    $('#btnPrint').click(function () {
        window.print();
    });
</script>

</body>
</html>