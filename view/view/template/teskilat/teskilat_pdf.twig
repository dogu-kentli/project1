    <div class="edu-subsection-title">MALİ ZİYARET SAYISI</div>
    <div class="stats-grid">
        <div class="stat-card money-card"><strong>{{teskilat_raporu.fon_calismalari.mali_ziyaret}}</strong></div>
        
    </div>

