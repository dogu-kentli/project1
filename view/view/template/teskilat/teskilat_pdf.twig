        <div class="stat-card"><span>KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.egitim_meslek.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_meslek.program2}}</strong></div>
        <div class="stat-card"><span>KATILIMCI SAYISI <br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_meslek.katilim2}}</strong></div>
    </div>

     <div class="edu-subsection-title">DİĞER EĞİTİM ÇALIŞMALARI</div>
    <div class="stats-grid">
        <div class="stat-card"><span>PROGRAM SAYISI<br> ERKEKLER</span><strong>{{teskilat_raporu.egitim_diger.program1}}</strong></div>
        <div class="stat-card"><span>KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.egitim_diger.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_diger.program2}}</strong></div>
        <div class="stat-card"><span>KATILIMCI SAYISI <br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_diger.katilim2}}</strong></div>
