        <div class="stat-card"><span>KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.egitim_seminer.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.egitim_seminer.program2}}</strong></div>
