        <div class="stat-card"><span>KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.sosyal_calismalar_diger.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.sosyal_calismalar_diger.program2}}</strong></div>
