    </div>

    <div class="edu-subsection-title">KÜLTÜR-SANAT FAALİYETLERİ</div>
     <div class="stats-grid">
        <div class="stat-card"><span>PROGRAM SAYISI<br> ERKEKLER</span><strong>{{teskilat_raporu.sosyal_calismalar_sanat.program1}}</strong></div>
        <div class="stat-card"><span>KATILIMCI SAYISI <br> ERKEKLER</span><strong>{{teskilat_raporu.sosyal_calismalar_sanat.katilim1}}</strong></div>
        <div class="stat-card"><span>PROGRAM SAYISI<br> HANIMLAR</span><strong>{{teskilat_raporu.sosyal_calismalar_sanat.program2}}</strong></div>
        <div class="stat-card"><span>KATILIMCI SAYISI <br> HANIMLAR</span><strong>{{teskilat_raporu.sosyal_calismalar_sanat.katilim2}}</strong></div>
    </div>

    <div class="edu-subsection-title">DİĞER SOSYAL ÇALIŞMALAR</div>
