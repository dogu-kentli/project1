                <th >Açıklama</th>
              </tr>
            </thead>
             <tbody id="egitim-calismalari1">
            {% set row = 0 %}
             {% for key,value in egitim_calismalari1 %}
             <tr id="egitim1-row{{key}}">
              <td>
                <input type="date" name="egitim_calismalari1[{{ key }}][tarih]" value="{{ value.tarih }}" placeholder="Tarih" class="input-border-none mutad{{row}}" disabled>
              </td>
              <td>
                <input type="text" name="egitim_calismalari1[{{ key }}][faaliyet_adi]" value="{{ value.faaliyet_adi }}" placeholder="Faaliyet Adı" class="input-border-none" readonly>
              </td>
               <td>
                <select name="egitim_calismalari1[{{ key }}][mutad]" value="{{ value.mutad }}" for="{{row}}" onclick="mutadautocomplete('{{row}}')" placeholder="Yapıldı/Yapılmadı" class="form-control mutad-egitim">
                   <option value="Yapılmadı" {% if value.mutad == 'Yapılmadı' %} selected {% endif %}>Yapılmadı</option>
                   <option value="Yapıldı" {% if value.mutad == 'Yapıldı' %} selected {% endif %}>Yapıldı</option>
                </select>
              </td>             
              <td>
                <input type="text" name="egitim_calismalari1[{{ key }}][katilim_sayisi]" value="{{ value.katilim_sayisi }}" placeholder="Katılım Sayısı" class="input-border-none mutad{{row}}" disabled>
              </td>
               <td >
                <textarea  name="egitim_calismalari1[{{ key }}][aciklama]"  onkeyup="autoTextHeight(this)" placeholder="Kısa bir açıklama yazınız." class="input-border-none textarea mutad{{row}}" disabled>{{ value.aciklama }}</textarea>
              </td>
              <td style="width:1%;" class="text-end">
                <button type="button" data-toggle="tooltip" title="{{ 'Satır Sil' }}" onclick="$('#egitim1-row{{ key }}').remove();" class="btn btn-danger btn-sm" disabled>
                    <i class="bi bi-dash-circle"></i>
                </button>
            </td>
           </tr>
           {% set row = row + 1 %}
          {% endfor %}
            </tbody>
