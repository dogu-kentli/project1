                <th>İrtibatta Olduğumuz Öğrenci Sayısı <span data-toggle="tooltip" data-placement="top" title="{{text_dipnot18}}" style="color:#008bd2;"><i class="bi bi-question-circle"></i></span></th>
                <th>Mevcut Öğrenci Sayısı <span data-toggle="tooltip" data-placement="top" title="{{text_dipnot4}}" style="color:#008bd2;"><i class="bi bi-question-circle"></i></th>
                <th>Bu ay Tanışılan <br>Öğrenci Sayısı <span data-toggle="tooltip" data-placement="top" title="{{text_dipnot5}}" style="color:#008bd2;"><i class="bi bi-question-circle"></i></th>
                <th>Ülke Başkanı Sayısı <span data-toggle="tooltip" data-placement="top" title="{{text_dipnot6}}" style="color:#008bd2;"><i class="bi bi-question-circle"></i></th>
