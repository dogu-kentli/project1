      success: function(json) {
        
        if (json.error.warning) {
	        $('.button-save').prop('disabled',true);
          $('#table-data').hide();
          $('#alert').prepend(
                '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-2">' +
                '<div class="d-flex align-items-center">' +
                '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
                '<div class="ms-3"><div class="text-dynamic">' + json.error.warning + '</div></div>' +
                '</div>' +
                '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                '</div>'
            );
        
        }

         if (json.success) {
           $('#report-message').addClass('alert-dismissible').html(json.success);
           $('#report-message').show();
           $('.json-table').remove();
           $('.button-save').prop('disabled',false);
           $('#table-data').show();
           $('#rapor-donemi').hide().find('span').remove();

           if(json['egitim_faaliyetleri']) {
             $('#egitim-calismalari2').append(json['egitim_faaliyetleri']);
           }

           if(json['ogrenci_faaliyetleri']) {
             $('#ogrenci-calismalari').append(json['ogrenci_faaliyetleri']);
           }

           if(json['sosyal_faaliyetler']) {
             $('#sosyal-calismalar').append(json['sosyal_faaliyetler']);
           }

           if(json['genel_faaliyetler']) {
             $('#genel-calismalar').append(json['genel_faaliyetler']);
           }

           if(json['total2']) {
             $('#input-mali-ziyaret').val(json['total2']);
           }

           if(json['total3']) {
             $('#input-gidilen-ziyaret').val(json['total3']);
           }

           if(json['total1']) {
             $('#input-gelen-ziyaret').val(json['total1']);
           }

            $('table tbody textarea').keyup();
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });
}

//--></script>


