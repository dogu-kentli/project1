  $('.alert-dismissible').remove();
    $.ajax({
      url: 'index.php?route=teskilat/teskilat/donemkontrolYear&user_token={{ user_token }}&teskilat_rapor_year_id={{teskilat_rapor_year_id}}&donemi=' +  element.value,
      type: 'post',
      dataType: 'json',
      success: function(json) {
        if (json['warning']) {
          $('#rapor-donemi').show().find('td').html('<span class="text-danger">' + json['warning'] + '</span>');
          $('.button-save').prop('disabled',true);
          $('#table-data').hide();
        }

        if (json.error.warning) {
	      alerterror(json.error.warning);
         }

         if (json.success) {
           $('#report-message').addClass('alert-dismissible').html(json.success + ' <button type="button" class="close" data-dismiss="alert">&times;</button>');
           $('#report-message').show();
           $('.json-table').remove();
           $('.button-save').prop('disabled',false);
           $('#table-data').show();
           $('#donem-baslik').html(`${element.value - 1}-${element.value}`);
           $('#rapor-donemi').hide().find('span').remove();

           if(json['egitim_faaliyetleri']) {
             $('#egitim-calismalari2').append(json['egitim_faaliyetleri']);
           }

           if(json['total2']) {
             $('#input-mali-ziyaret').val(json['total2']);
           }

           if(json['total3']) {
             $('#input-gidilen-ziyaret').val(json['total3']);
           }

           if(json['total1']) {
             $('#input-gelen-ziyaret').val(json['total1']);
           }

        
            $('table tbody textarea').keyup();
        }
      },
      error: function(xhr, ajaxOptions, thrownError) {
        alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
      }
    });
}

//--></script>



