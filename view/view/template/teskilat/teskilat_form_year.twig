		  }
	  });
//--></script>
<script type="text/javascript"><!--
$('.button-save').on('click', function() {
  $('.text-danger,.alert-dismissible').remove();
  var errorArray = [];
  
  var donemi = $('input[name=\'donemi\']').val();

  if(donemi == '') {
    errorArray.push('Lütefen dönemi bilirtiniz.');
    $('input[name=\'donemi\']').after('<div class="text-danger"><span>Lütfen dönemi belirtiniz</span></div>'); 
  }

  $('#form-report-year input[required]').each(function() {
     event.preventDefault();
        if ($(this).val() === '') {
            errorArray.push('Lütfen gerekli alanları doldurun.');
            $(this).after('<div class="text-danger"><span>Zorunlu</span></div>');
            $(this).css('border', '1px solid #f78981');// Çerçeveyi kırmızı yap
        }
  });

  if (errorArray.length === 0) {
    $('#form-report-year').submit();        
  } else {
    $('#alert').prepend(
                '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-2">' +
                '<div class="d-flex align-items-center">' +
                '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
                '<div class="ms-3"><div class="text-dynamic">Lütfen eksik bilgileri doldurun</div></div>' +
                '</div>' +
                '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                '</div>'
            ); 
  }
});

//--></script>
