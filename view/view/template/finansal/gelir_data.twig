<script type="text/javascript">
function gelirSave() {
  var url_filter = $('input[name^="filter_url"]').val();
  var error = '';
  $('#tab-data').find('.auto-complate').each(function(index, element) {
    const $element = $(element);
    const value = $element.val().trim();
    const isRequired = $element.prop('required');

    if (isRequired && value === '') {
      $element.find('span').hide();
      $element.show();
      $element.css('border-color', 'red');

      //error = "Lütfen kırmızı renkle belirtilmiş alanları doldurunuz.";
    } else {
      $element.css('border-color', '');
    }
  });

  if (error) {
    alerterror(error);
    return;
  }

  $.ajax({
    url: 'index.php?route=finansal/gelir/save&user_token={{ user_token }}',
    type: 'post',
    dataType: 'json',
    data: $('#form-gelir .post-field').find('input,select,textarea').serialize(),
        success: function(json) {
            if (json.error.warning) {
               alerterror(json.error.warning);
            }
            
            if (json.success) {
             $('#tab-data').load(url_filter, initializeDragDrop);
             $('input[name^=\'form\']').val(json['form']);
      
              alertsuccess(json.success);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
        });
    }
    

function gelirautocomplete(gelir_row) {
  $('#tab-data .auto-complate').autocomplete({
  
    source: function(request, response) {
      $.ajax({
        url: 'index.php?route=setting/autocomplete/gelirgroupautocomplete&user_token={{ user_token }}&bolum=' + $(this).attr('data-for') + '&filter_name=' + encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item.name,
              label2: item.disabled,
              value: item.id
            };
          }));
        }
      });
    },
    select: function(item) {
      if (item.value == 'new') {
        $('#modal-bagisci').modal('show');
        return false;
      }

      if (item.label !== 'TRY' && $(this).attr('data-for') === 'currency') {
        $(this).closest('td').find('.input-hidden-kur').val($('#currency' + item.label).attr('for'));
      }

      $(this).val(item.label);
      
      $(this).closest('td').find('.input-hidden').val(item.value);
    }
  });
}
</script>
<script>
function editGelir(rowId) {
    // Önce tüm satırları resetle
    $('tbody tr').each(function() {
        $(this).removeClass('post-field');
         $(this).removeClass('bg-light-info');
        $(this).find('.edit-mode').hide().removeClass('active-row post-field');
        $(this).find('.view-mode').show();
        $('[id^="btn-edit"]').show();
        $(this).find('.btn-save').hide();
    });

    // Şimdi sadece seçilen satırı aktif et
    var $row = $('#gelir-row' + rowId);
   
    $row.find('.edit-mode').show().addClass('active-row post-field');
    $row.find('.view-mode').hide();
    $row.addClass('post-field');

    // Butonları ayarla
    $row.find('#btn-edit' + rowId).hide();
    $row.find('.btn-save' + rowId).show();
    $row.addClass('bg-light-info');

    // Ekstra fonksiyonlar
    gelirautocomplete(rowId);
    $('#button-gelir').show();
    // autoExpandTextarea($row.find('textarea'));
}

function autoExpandTextarea($textarea) {
  $textarea.css('height', 'auto');
  $textarea.css('height', $textarea.prop('scrollHeight') + 'px');
}
</script>

<script>
function selectBolum(bolum, rowId) {
  $('#form-gelir input').attr('required', true);
  const $name = $('input[name="data_gelir[' + rowId + '][adsoyad]"]');
  const $tur = $('input[name="data_gelir[' + rowId + '][tur]"]');
  const $gider_category = $('input[name="data_gelir[' + rowId + '][gider_category]"]');
   
  if (bolum == 2) {
    $name.val('');
    $name.prop('disabled', false);
    $name.removeAttr('required');
    $gider_category.prop('required', true);
    $gider_category.prop('disabled', false);
    $tur.attr('data-for', '3');
  } else if (bolum == 1) {
    $name.prop('disabled', false);
    $name.prop('required', false);
    $gider_category.val('');
    $gider_category.prop('disabled', true);
    $tur.attr('data-for', '2');
  }else{
   $('#form-gelir input').removeAttr('required');
  }
}
$('.select-bolum').trigger('change');
</script>

<script>
$(function () {
    // Popover'ı başlat
    $('#date-range-display').popover({
        html: true,
        placement: 'bottom',
        title: 'Tarih Aralığı Seçin',
        content: function () {
            return $('#popover-content').html();
        }
    });

    // Popover dışına tıklandığında kapatma (opsiyonel)
    $('body').on('click', function (e) {
        if ($(e.target).data('toggle') !== 'popover' && $(e.target).parents('.popover').length === 0) {
            $('[data-toggle="popover"]').popover('hide');
        }
    });
});

// Uygula butonuna basıldığında çalışacak fonksiyon
function applyDateFilter() {
    // Popover içindeki inputlardan değerleri al (Popover clone oluşturduğu için özel seçici gerekir)
    var start = $('.popover #popover_start').val();
    var end = $('.popover #popover_end').val();

    if(start && end) {
        $('#date-range-display').val(1);
        $('#date-range-display').trigger('change');
    }
  
    $('#date-range-display').popover('hide');
}
</script>
