<div class="table-responsive-sm">
    <form id="form-gelir">
        <table class="table table-bordered align-middle mb-0" style="font-size: 12px;">
            <thead class="align-middle text-white" style="background-color: #018bd3; font-weight: bold;">
                <tr>
                    <th class="text-center" style="width: 50px;">...</th>
                    <th>Bağışçı / Birim</th>
                    <th>Tarih / Açıklama</th>
                    <th>Bölüm / Proje</th>
                    <th>Hesap / Tür</th>
                    <th>Fon / Yöntem</th>
                    <th>Gider Kategorisi</th>
                    <th class="text-center" style="width: 120px;">Tutar</th>
                    <th class="text-center" style="width: 100px;">Eylemler</th>
                </tr>
            </thead>
            <tbody>
                <input type="hidden" name="filter_url" value="{{mali_gelir_link}}" class="form-control" />
                
                {% set gelir_row = 0 %}
                {% for gelir in gelir_data %}
                <tr id="gelir-row{{ gelir_row }}">
                    
                    <!-- 1. SÜTUN: SÜRÜKLE & SEÇ -->
                    <td class="text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-arrows-move text-secondary fs-6" style="cursor: move;" title="Taşı"></i>
                            <input type="checkbox" class="form-check-input m-0 row-checkbox" name="select[]" value="{{gelir.mali_id}}" style="cursor: pointer;">
                        </div>
                    </td>

                    <!-- 2. SÜTUN: BAĞIŞÇI (AD SOYAD) & BİRİM -->
                    <td>
                        <input type="hidden" name="data_gelir[{{gelir_row}}][mali_id]" value="{{gelir.mali_id}}" />
                        <div class="edit-mode" style="display:none;">
                            <input type="text" name="data_gelir[{{gelir_row}}][adsoyad]" value="{{gelir.name}}" placeholder="Ad Soyad" data-for="adsoyad" class="form-control auto-complate form-control-sm mb-1" />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][bagisci_id]" value="{{gelir.bagisci_id}}" />
                            
                            <input type="text" name="data_gelir[{{gelir_row}}][birim]" value="{{gelir.birim}}" data-for="8" placeholder="Birim" class="form-control auto-complate form-control-sm" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][birim_id]" value="{{gelir.birim_id}}" />
                        </div>
                        <div class="view-mode">
                            <strong class="d-block text-dark">{{gelir.name}}</strong>
                            <small class="text-muted d-block" style="font-size: 11px;">
                                <i class="bi bi-tag me-1"></i>Birim: {{gelir.birim}}
                            </small>
                        </div>
                    </td>

                    <!-- 3. SÜTUN: TARİH & AÇIKLAMA -->
                    <td>
                        <div class="edit-mode" style="display:none;">
                            <input type="date" name="data_gelir[{{gelir_row}}][date]" value="{{gelir.date}}" class="form-control form-control-sm mb-1" />
                            <textarea name="data_gelir[{{gelir_row}}][description]" placeholder="Açıklama" class="form-control form-control-sm" rows="1">{{gelir.description_long}}</textarea>
                        </div>
                        <div class="view-mode">
                            <span class="d-block fw-bold text-secondary mb-1" style="font-size: 12px;">{{gelir.date|date("d.m.Y")}}</span>
                            <span class="d-block text-dark text-truncate" style="max-width: 180px;" title="{{gelir.description_long}}">
                                {{gelir.description|default('-')}}
                            </span>
                        </div>
                    </td>

                    <!-- 4. SÜTUN: BÖLÜM & PROJE -->
                    <td>
                        <div class="edit-mode" style="display:none;">
                            <select name="data_gelir[{{gelir_row}}][bolum]" onchange="selectBolum(this.value,'{{gelir_row}}');" class="form-select form-select-sm mb-1">
                                {% for key,value in bolumler %}
                                <option value="{{key}}" {% if gelir.bolum == key %} selected {% endif %}>{{value}}</option>
                                {% endfor %}
                            </select>
                            <input type="text" name="data_gelir[{{gelir_row}}][proje]" value="{{gelir.proje}}" data-for="7" placeholder="Proje" class="form-control auto-complate form-control-sm" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][proje_id]" value="{{gelir.proje_id}}" />
                        </div>
                        <div class="view-mode">
                            <span class="badge bg-light text-dark border mb-1" style="font-size: 11px;">{{ bolumler[gelir.bolum] }}</span>
                            <small class="text-muted text-truncate d-block" style="max-width: 140px;" title="{{gelir.proje}}">{{gelir.proje}}</small>
                        </div>
                    </td>

                    <!-- 5. SÜTUN: HESAP & TÜR -->
                    <td>
                        <div class="edit-mode" style="display:none;">
                            <input type="text" name="data_gelir[{{gelir_row}}][hesap]" value="{{gelir.hesap}}" placeholder="Hesap" data-for="1" class="form-control auto-complate form-control-sm mb-1" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][hesap_id]" value="{{gelir.hesap_id}}" />
                            <input type="text" name="data_gelir[{{gelir_row}}][tur]" value="{{gelir.tur}}" placeholder="Tür" data-for="2" class="form-control auto-complate form-control-sm" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][tur_id]" value="{{gelir.tur_id}}" />
                        </div>
                        <div class="view-mode">
                            <span class="d-block text-dark">{{gelir.hesap}}</span>
                            <small class="text-muted d-block">{{gelir.tur}}</small>
                        </div>
                    </td>

                    <!-- 6. SÜTUN: FON & GEL/GİD ŞEKLİ -->
                    <td>
                        <div class="edit-mode" style="display:none;">
                            <input type="text" name="data_gelir[{{gelir_row}}][fon]" value="{{gelir.fon}}" placeholder="Fon" data-for="4" class="form-control auto-complate form-control-sm mb-1" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][fon_id]" value="{{gelir.fon_id}}" />
                            <input type="text" name="data_gelir[{{gelir_row}}][gelir_sekli]" value="{{gelir.gelir_sekli}}" data-for="5" placeholder="Yöntem" class="form-control auto-complate form-control-sm" required />
                            <input type="hidden" name="data_gelir[{{gelir_row}}][gelir_sekli_id]" value="{{gelir.gelir_sekli_id}}" />
                        </div>
                        <div class="view-mode">
                            <span class="d-block text-dark">{{gelir.fon}}</span>
                            <small class="text-muted d-block">{{gelir.gelir_sekli}}</small>
                        </div>
                    </td>

                    <!-- 7. SÜTUN: GİDER KATEGORİSİ -->
                    <td>
                        <div class="edit-mode" style="display:none;">
                            <input type="text" name="data_gelir[{{gelir_row}}][gider_category]" value="{{gelir.gider_category}}" data-for="6" placeholder="Kategori" class="form-control auto-complate form-control-sm">
                            <input type="hidden" name="data_gelir[{{gelir_row}}][gider_category_id]" value="{{gelir.gider_category_id}}" />
                        </div>
                        <div class="view-mode">
                            <span class="text-truncate d-block" style="max-width: 120px;">{{gelir.gider_category}}</span>
                        </div>
                    </td>

                    <!-- 8. SÜTUN: TUTAR (TEK VE NET) -->
                    <td class="text-end">
                        <div class="edit-mode" style="display:none;">
                            <div class="">
                                <input type="text" name="data_gelir[{{gelir_row}}][currency]" value="{{gelir.currency}}" data-for="currency" class="form-control auto-complate text-center fw-bold text-success"  required />
                                <input type="text" name="data_gelir[{{gelir_row}}][tutar]" value="{{gelir.tutar}}" data-mask="#.##,00" class="form-control" style="color:{{gelir.color}};" required />
                            </div>
                            <input type="hidden" name="data_gelir[{{gelir_row}}][kur]" value="{{gelir.kur}}" />
                        </div>
                        <div class="view-mode font-monospace">
                            <span class="fs-6 " style="color:{{gelir.color}};">
                                {{gelir.math_sembol}}{{gelir.tutar}} <span class="text-dark small fw-normal">{{gelir.currency}}</span>
                            </span>
                        </div>
                    </td>

                    <!-- 9. SÜTUN: EYLEMLER -->
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-1">
                            <button type="button" onclick="gelirSave();" class="btn btn-success btn-sm btn-save{{gelir_row}} btn-save" style="display:none;" title="Kaydet">
                                <i class="bi bi-save"></i>
                            </button>
                            <button type="button" id="btn-edit{{gelir_row}}" onclick="editGelir('{{gelir_row}}');" class="btn btn-outline-info btn-sm" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" onclick="remove('{{gelir.mali_id}}');" class="btn btn-outline-danger btn-sm" title="Sil">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                {% set gelir_row = gelir_row + 1 %}
                {% endfor %}
            </tbody>
        </table>
    </form>
</div>

<div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
 <script type="text/javascript">
 $('#cover-spin').hide(0);
  var gelir_row = {{ gelir_row }};
  function addGelir() {
    html = '<tr id="gelir-row' + gelir_row + '" class="post-field align-middle bg-light-info">';
    
    // 1. SÜTUN: SÜRÜKLE & SEÇ
    html += ' <td class="text-center">';
    html += '   <div class="d-flex align-items-center justify-content-center gap-2">';
    html += '     <i class="fa fa-arrows-v" style="font-size:16px; cursor: move;"></i>';
    html += '     <input type="checkbox" class="form-check-input m-0 row-checkbox" name="select[]" value="0" style="cursor: pointer;">';
    html += '   </div>';
    html += ' </td>';

    // 2. SÜTUN: BAĞIŞÇI (AD SOYAD) & BİRİM
    html += ' <td class="text-left">';
    html += '   <input name="mali_id" type="hidden" value="0"/>';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][adsoyad]" data-for="adsoyad" value="" placeholder="{{ "Bağışçı / Ad Soyad" }}" class="form-control input-sm auto-complate mb-1" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][bagisci_id]" value="" class="input-hidden"/>';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][birim]" value="" data-for="8" placeholder="{{ "Birim" }}" class="form-control input-sm auto-complate" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][birim_id]" value="" class="input-hidden"/>';
    html += ' </td>';

    // 3. SÜTUN: TARİH & AÇIKLAMA
    html += ' <td class="text-left">';
    html += '   <input type="date" name="data_gelir[' + gelir_row + '][date]" value="{{bugun}}" placeholder="{{ "Tarih" }}" class="form-control input-sm auto-complate mb-1" required/>';
    html += '   <textarea name="data_gelir[' + gelir_row + '][description]" placeholder="{{ "Açıklama" }}" class="form-control input-sm" rows="1"></textarea>';
    html += ' </td>';

    // 4. SÜTUN: BÖLÜM & PROJE
    html += ' <td class="text-left">';
    html += '   <select name="data_gelir[' + gelir_row + '][bolum]" onchange="selectBolum(this.value,' + gelir_row + ');" class="form-select input-sm select-bolum mb-1">';
                {% for key,value in bolumler %}
    html += '     <option value="{{key}}">{{value}}</option>';
                {% endfor %}
    html += '   </select>';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][proje]" value="" data-for="7" placeholder="{{ "Proje" }}" class="form-control input-sm auto-complate" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][proje_id]" value="" class="input-hidden"/>';
    html += ' </td>';

    // 5. SÜTUN: HESAP & TÜR
    html += ' <td class="text-left">';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][hesap]" value="" data-for="1" title="hesap" placeholder="{{ "Hesaplar" }}" class="form-control input-sm auto-complate mb-1" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][hesap_id]" value="" class="input-hidden"/>';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][tur]" value="" data-for="2" for2="3" placeholder="{{ "Tür" }}" class="form-control input-sm auto-complate" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][tur_id]" value="" class="input-hidden"/>';
    html += ' </td>';

    // 6. SÜTUN: FON & GELİR ŞEKLİ (YÖNTEM)
    html += ' <td class="text-left">';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][fon]" value="" data-for="4" placeholder="{{ "Fon" }}" class="form-control input-sm auto-complate mb-1" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][fon_id]" value="" class="input-hidden"/>';
    html += '   <input type="text" name="data_gelir[' + gelir_row + '][gelir_sekli]" value="" data-for="5" placeholder="{{ "Gelir Şekli" }}" class="form-control input-sm auto-complate" required/>';
    html += '   <input type="hidden" name="data_gelir[' + gelir_row + '][gelir_sekli_id]" value="" class="input-hidden"/>';
