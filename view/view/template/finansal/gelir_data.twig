    html += '   <div class="d-flex justify-content-center gap-1">';
    html += '     <button type="button" id="btn-save' + gelir_row + '" onclick="gelirSave();" data-toggle="tooltip" title="{{ "Düzenleme" }}" class="btn btn-success btn-sm"><i class="bi bi-save"></i></button>';
