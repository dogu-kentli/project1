<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Görev Logları Yönetimi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <style>
    body {
      font-size: 0.9rem;
    }
    h2 {
      font-size: 1.25rem;
    }
    .highlighted {
      background-color: #e6f7ff !important;
      transition: background-color 0.3s ease;
    }
    .table-responsive {
      overflow-x: auto;
    }
    .log-details-pre {
      white-space: pre-wrap;
      word-wrap: break-word;
      background-color: #f8f9fa;
      padding: 10px;
      border-radius: 5px;
      border: 1px solid #dee2e6;
      font-size: 0.8rem;
    }
    .table th, .table td {
      vertical-align: middle;
      padding: 0.5rem 0.5rem;
      font-size: 0.85rem;
    }
    .table thead th {
      white-space: nowrap;
    }

    .btn-sm {
      font-size: 0.75rem;
      padding: 0.25rem 0.5rem;
    }
    .modal-title {
      font-size: 1rem;
    }
  </style>
</head>
<body class="bg-light">

<div class="container-fluid py-4">
  <div class="row mb-3">
    <div class="col-md-6">
      <h2 class="text-primary mb-0">
        <i class="fas fa-clipboard-list me-2"></i> (ID: #{{ gorev_id }})
      </h2>
    </div>
    <div class="col-md-6 text-end">
      <input type="text" id="logSearch" class="form-control form-control-sm" placeholder="Tarih, Kullanıcı veya İşlemde Ara..." onkeyup="filterTable()">
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-striped table-sm mb-0" id="logTable">
          <thead class="bg-light text-white">
            <tr>
              <th style="width: 1%;" class="text-center" style="width: 5%;">#</th>
              <th style="width: 15%;">Tarih</th>
              <th style="width: 15%;">Kullanıcı</th>
              <th style="width: 10%;">IP</th>
              <th style="width: 25%;">İşlem</th>
              <th class="text-end" style="width: 10%;">Eylem</th>
            </tr>
          </thead>
          <tbody>
            {% for log in loglar %}
              <tr id="row-{{ loop.index }}">
                <td class="text-center">{{ log.id ?? loop.index }}</td>
                <td>{{ log.tarih ?? '-' }}</td>
                <td>{{ log.kullanici ?? '-' }}</td>
                <td>{{ log.ip ?? '-' }}</td>
                <td class="text-truncate">{{ log.islem ?? '-' }}</td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modal-{{ loop.index }}" onclick="highlightRow({{ loop.index }})">
                    <i class="fas fa-eye me-1"></i> Detay
                  </button>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="6" class="text-center text-muted py-3">
                  <i class="fas fa-exclamation-triangle me-2"></i> Bu göreve ait kayıt bulunamadı.
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal'lar -->
{% for log in loglar %}
<div class="modal fade" id="modal-{{ loop.index }}" tabindex="-1" aria-labelledby="modalLabel-{{ loop.index }}" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-light">
        <h5 class="modal-title" id="modalLabel-{{ loop.index }}">
          <i class="fas fa-info-circle me-1 text-primary"></i> İşlem Detayı (ID: {{ log.id ?? loop.index }})
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <div class="modal-body">
        <p><strong>Tarih:</strong> {{ log.tarih ?? '-' }} | <strong>Kullanıcı:</strong> {{ log.kullanici ?? '-' }} | <strong>İşlem:</strong> {{ log.islem ?? '-' }}</p>
        <p><strong>Tarayıcı:</strong> {{ log.tarayici ?? '-' }}</p>
        <hr>
        <h6>Diğer Ayrıntılar:</h6>
        <pre class="log-details-pre mb-0">{{ log.ayrinti ?? 'Detay bulunamadı.' }}</pre>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Kapat</button>
      </div>
    </div>
  </div>
</div>
{% endfor %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function highlightRow(index) {
    document.querySelectorAll('#logTable tbody tr').forEach(row => row.classList.remove('highlighted'));
    const row = document.getElementById('row-' + index);
    if (row) row.classList.add('highlighted');

    const modal = document.getElementById('modal-' + index);
    if (modal) {
      modal.addEventListener('hidden.bs.modal', () => {
        row.classList.remove('highlighted');
      }, { once: true });
    }
  }

  function filterTable() {
    const filter = document.getElementById('logSearch').value.toUpperCase();
    const rows = document.querySelectorAll('#logTable tbody tr');

    rows.forEach(row => {
      const cells = row.querySelectorAll('td');
      const match = [1, 2, 4].some(i => cells[i]?.textContent.toUpperCase().includes(filter));
      row.style.display = match ? '' : 'none';
    });
  }
</script>
</body>
</html>