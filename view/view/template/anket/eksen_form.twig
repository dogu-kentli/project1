                    type: 'post',
                    dataType: 'json',
                    data: new FormData($('#form-upload')[0]),
                    cache: false,
                    contentType: false,
                    processData: false,

                    beforeSend: function() {
                        $('#cover-spin').show(0);
                    },
                    complete: function() {
                        $('#cover-spin').hide(0);
                    },

                    success: function(json) {
                        if (json.error) {
                            alerterror(json.error);
                        }

                        if (json.success) {
                            alertsuccess(json.success);
                            $('#input-image').val(json['image']);
                            var imgPath = 'image/' + json['image'];  
                            // admin tarafında çalışıyorsan:
                            imgPath = '../' + imgPath;

                            $('#src-image').attr('src', imgPath).attr('width', 220).attr('height', 147);
                            }},
                            error: function(xhr, ajaxOptions, thrownError) {
                                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
                            }
                });
            }
        }, 500);
    });
</script>
<script>
function generateFormPreview() {
    const $previewBody = $('#modal-preview-body');
    $previewBody.empty();

    // 1. Ana Bilgileri Topla (Başlık, Afiş, Açıklama) 
    const formTitle = $('input[name="name"]').val() || 'Başlıksız Form';
    
    // Resim/Afiş kontrolü 
    const $imgElement = $('#src-image');
    const imgSrc = $imgElement.attr('src');
    let imageHtml = '';
    
    if (imgSrc && !imgSrc.includes('no_image') && imgSrc !== '') {
        imageHtml = `
            <div class="text-center mb-4">
                <img src="${imgSrc}" class="img-fluid rounded-3 shadow-sm border" style="max-height: 300px; width: 100%; object-fit: cover;" alt="Form Afişi">
            </div>
        `;
    }

    // RichTextEditor içeriğini güncelleyip alalım 
    if (typeof editor1 !== 'undefined') { 
        $('#textarea-editor').val(editor1.getHTMLCode());
    }
    const formDesc = $('#textarea-editor').val() || '';

    // Üst Bilgi Şablonu 
    let previewHtml = `
        <div class="form-preview-header mb-4">
            ${imageHtml}
            <h2 class="fw-bold text-dark mb-2">${formTitle}</h2>
            ${formDesc ? `<div class="text-muted p-2 bg-light rounded-3 mb-3" style="font-size: 0.95rem;">${formDesc}</div>` : ''}
            <hr class="text-muted opacity-25">
        </div>
    `;

    // 2. Bölümleri ve Soruları Döngüyle Çek 
    const sections = $('.section-item');

    if (sections.length === 0) {
        previewHtml += '<p class="text-muted text-center my-4">Formda henüz hiçbir bölüm veya soru bulunmuyor.</p>';
    } else {
        sections.each(function() {
            const $section = $(this);
            const sectionTitle = $section.find('input[name*="[bolum]"]').val();
            const $questions = $section.find('.q-box');

            previewHtml += `<div class="preview-section-block mb-4 p-3 border border-light-subtle rounded-3 bg-light-subtle">`;
            
            if (sectionTitle) {
                previewHtml += `<h6 class="fw-bold border-bottom pb-2 text-dark mb-3">${sectionTitle}</h6>`;
            }

            $questions.each(function(index) {
                const $qBox = $(this);
                const questionText = $qBox.find('input[name*="[soru]"]').val() || `Soru ${index + 1}`;
                
                // İSTEDİĞİNİZ KISIM: input'a yazılan kısa açıklama değerini çekiyoruz 
                const shortDescription = $qBox.find('input[name*="[placeholder]"]').val() || '';
                
                const type = $qBox.find('input[type="hidden"][name*="[type]"]').val() || 'text';
                
                previewHtml += `<div class="mb-4 bg-white p-3 rounded-3 shadow-sm">
                    <label class="form-label fw-bold text-secondary mb-1">${index + 1}. ${questionText}</label>`;

                // EĞER KISA AÇIKLAMA DOLDURULMUŞSA: Label'ın hemen altına ekliyoruz 
                if (shortDescription) {
                    previewHtml += `<div class="text-muted fst-italic mb-2" style="font-size: 0.82rem; margin-top: -2px;">${shortDescription}</div>`;
                }

                // Yanıt Türü Tiplerine Göre HTML Çıktısı (Önizleme elemanları için placeholder artık boş kalabilir veya amaca uygun düzenlenebilir)
                if (type === 'text') {
                    previewHtml += `<input type="text" class="form-control border-secondary-subtle shadow-none" placeholder="Kullanıcı buraya kısa cevap yazacak..." disabled>`;
                } 
                else if (type === 'textarea') {
                    previewHtml += `<textarea class="form-control border-secondary-subtle shadow-none" rows="3" placeholder="Kullanıcı buraya uzun paragraf yazacak..." disabled></textarea>`;
                } 
                else if (type === 'date') {
                    previewHtml += `<input type="date" class="form-control border-secondary-subtle shadow-none" disabled>`;
                } 
                else if (type === 'file') {
                    previewHtml += `<input type="file" class="form-control border-secondary-subtle shadow-none" disabled>`;
                } 
                else if (type === 'rating') {
                    previewHtml += `
                        <div class="text-warning fs-3 my-1">
                            <i class="bi bi-star"></i> <i class="bi bi-star"></i> <i class="bi bi-star"></i> <i class="bi bi-star"></i> <i class="bi bi-star"></i>
                        </div>`;
                } 
                else if (type === 'select') {
                    previewHtml += `<select class="form-select border-secondary-subtle shadow-none" disabled><option>-- Seçim Yapınız --</option>`;
                    $qBox.find('.opt-input').each(function() {
                        const optVal = $(this).val();
                        if(optVal) previewHtml += `<option>${optVal}</option>`;
                    });
                    previewHtml += `</select>`;
                } 
                else if (type === 'radio' || type === 'checkbox') {
                    const inputType = type === 'radio' ? 'radio' : 'checkbox';
                    const inputClass = type === 'radio' ? 'form-check-input rounded-circle' : 'form-check-input';
                    
                    $qBox.find('.opt-input').each(function(oIdx) {
                        const optVal = $(this).val() || `Seçenek ${oIdx + 1}`;
                        previewHtml += `
                            <div class="form-check my-2">
                                <input class="${inputClass}" type="${inputType}" disabled>
                                <label class="form-check-label text-dark fw-normal ms-1">${optVal}</label>
                            </div>`;
                    });
                }

                previewHtml += `</div>`;
            });

            previewHtml += `</div>`;
        });
    }

    // 3. Oluşturulan HTML'i Modal İçine Bas ve Modalı Göster
    $previewBody.html(previewHtml);
    
    const previewModal = new bootstrap.Modal(document.getElementById('previewModal'));
    previewModal.show();
}
</script>
