{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" data-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-report').toggleClass('hidden-sm hidden-lg');" class="btn btn-default hidden-md"><i class="fa fa-filter"></i> Filitre</button>
		    <a href="{{ export }}" data-toggle="tooltip" title="Exel Dökümü" class="btn btn-success"><i class="fa fa-download"></i></a>
      </div>
      <h1><i class="fa fa-bar-chart"></i></h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
<div class="row">
  <div id="filter-report" class="col-sm-12 hidden-sm hidden-lg">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-filter"></i> {{ text_filter }}</h3>
      </div>
      <div class="panel-body">
	    <div class="form-group">
          <label class="control-label" for="input-information">{{ column_category1 }}</label>
          <select name="filter_category1" id="input-category1" class="form-control">
           <option value="" selected="selected">{{ text_select }}</option>
                {% for category1 in categories1 %}
                    <option value="{{ category1.grup  }}"  {% if filter_category1 == category1.grup %} selected {% endif %}>{{ category1.grup }}</option>
                {% endfor %}
              </select>
        </div>

        <div class="form-group">
          <label class="control-label" for="input-information">{{ column_category2 }}</label>
          <select name="filter_category2" id="input-category2" class="form-control">
           <option value="" selected="selected">{{ text_select }}</option>
               {% for category2 in categories2 %}
                    <option value="{{ category2.custom_field_value_id  }}" {% if filter_category2 == category2.custom_field_value_id %} selected {% endif %}>{{ category2.name }}</option>
                {% endfor %}
              </select>
        </div>
		  <div class="form-group">
          <label class="control-label" for="input-information">{{ entry_name }}</label>
          <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ entry_customer }}" id="input-name" class="form-control" />
        </div>
        <div class="form-group">
          <label class="control-label" for="input-date-start">{{ entry_date_start }}</label>
          <div class="input-group date">
            <input type="text" name="filter_date_start" value="{{ filter_date_start }}" placeholder="{{ entry_date_start }}" data-date-format="DD/MM/YYYY" id="input-date-start" class="form-control" />
            <div class="input-group-btn">
            <button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button>
            </div></div>
        </div>        
        <div class="form-group">
          <label class="control-label" for="input-date-end">{{ entry_date_end }}</label>
          <div class="input-group date">
            <input type="text" name="filter_date_end" value="{{ filter_date_end }}" placeholder="{{ entry_date_end }}" data-date-format="DD/MM/YYYY" id="input-date-end" class="form-control" />
            <div class="input-group-btn">
            <button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button>
            </div></div>
        </div>
        <div class="form-group text-right">		  
          <button type="button" id="button-filter" class="btn btn-default"><i class="fa fa-filter"></i> {{ button_filter }}</button>
		  <button type="button"  id="button-filter-reset" class="btn btn-danger"><i class="fa fa-remove"></i> Temizle</button>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-12">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-bar-chart"></i> {{ "Rapor Detayları" }}</h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive">
          <table class="table table-bordered">
            <thead>
              <tr>
                <td class="text-left">{{ column_category1 }}</td>
                <td class="text-left">{{ column_category2 }}</td>
                <td class="text-left">{{ column_etkinlik_adi }}</td>
                <td class="text-left">{{ column_tarih }}</td>
                <td class="text-left">{{ column_katilim }}</td>
				<td class="text-left">{{ column_description }}</td>
                <td class="text-left">{{ column_store }}</td>
  
              </tr>
            </thead>
            <tbody>
            
            {% if informations %}
            {% for information in informations %}
            <tr>
              <td class="text-left">{{ information.category1 }}</td>
              <td class="text-left">{{ information.category2 }}</td>
              <td class="text-left">{{ information.etkinlik_adi }}</td>
              <td class="text-left">{{ information.date_added }}</td>
              <td class="text-left">{{ information.katilim }}</td>
               <td class="text-left">{{ information.description }}</td>
              <td class="text-left">{{ information.store['name'] }}</td>
            </tr>
            {% endfor %}
            {% else %}
            <tr>
              <td class="text-center" colspan="7">{{ text_no_results }}</td>
            </tr>
            {% endif %}
            </tbody>
            
          </table>
        </div>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$('#button-filter-reset').on('click', function() {
  url = 'index.php?route=report/etkinlik_transaction&user_token={{ user_token }}';     
  location = url;
});
</script>
<script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';
	
	var filter_name = $('input[name=\'filter_name\']').val();
	
	if (filter_name) {
		url += '&filter_name=' + encodeURIComponent(filter_name);
	}
	
	var filter_category1 = $('select[name=\'filter_category1\']').val();
	
	if (filter_category1) {
		url += '&filter_category1=' + encodeURIComponent(filter_category1);
	}
	
	var filter_category2 = $('select[name=\'filter_category2\']').val();
	
	if (filter_category2) {
		url += '&filter_category2=' + encodeURIComponent(filter_category2);
	}

  var filter_date_start = $('input[name=\'filter_date_start\']').val();
	
	if (filter_date_start) {
		url += '&filter_date_start=' + encodeURIComponent(filter_date_start);
	}
	
	var filter_date_end = $('input[name=\'filter_date_end\']').val();
	
	if (filter_date_end) {
		url += '&filter_date_end=' + encodeURIComponent(filter_date_end);
	}
	
	location = 'index.php?route=report/etkinlik_transaction&user_token={{ user_token }}' + url;
});
//--></script> 

<script type="text/javascript"><!--
$('.date').datetimepicker({
	language: '{{ datepicker }}',
	pickTime: false
});
//--></script>

{{ footer }} 