{{ header }}{{ column_left }}
<main class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-sm-flex align-items-center mb-3">

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
                    {% endfor %}
                </ol>
            </nav>
        </div>

       <div class="ms-auto text-end me-3">
         <a href="javascript:void(0)" id="button-report" data-toggle="tooltip" title="{{ "Sosyal Medya Tasarımlı Raporu Oluştur" }}" class="btn btn-warning btn-sm"><i class="bi bi-pie-chart-fill"></i> {{" Rapor Oluştuştr "}}</a>
         <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Ekle</a>
         <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger btn-sm" onclick="confirm('{{ text_confirm }}') ? $('#form-information').submit() : false;"><i class="bi bi-trash"></i> Sil</button>
        </div>
    </div>
    <!--end breadcrumb-->

    <div class="row">
        <div class="col-12 col-lg-12 d-flex">
            <div class="card w-100">
                <div class="card-header py-3">
                    <div class="row g-3">
                        <div class="col-lg-4 col-6 me-auto">
                            <div class="ms-auto position-relative">
                                <div class="position-absolute top-50 translate-middle-y search-icon px-2"><i class="bi bi-search"></i></div>
                                <input type="text" name="filter_name" value="{{filter_name}}" id="input-filter-name" placeholder="İsim yazınız..." class="form-control ps-4 r">
                                <input type="hidden" name="filter_customer_id" value="{{filter_customer_id}}" id="input-filter-name" placeholder="Konusunu yazınız" class="form-control ps-4 auto-filter">
                            </div>
                        </div>

                        <div class="col-lg-2 col-6 col-md-3">
                            
                        </div>

                        <div class="col-lg-1 co1-6 col-md-3">
                            <select name="limit" class="form-select auto-filter">
                                {% for key,value in limits %}
                                <option value="{{value}}" {% if filter_limit == value %} selected="selected" {% endif %}>{{value}}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-information">
                    <div class="card-body">

                        <div class="table-responsive-sm">
                            <table class="table table-bordered align-middle mb-0">
                           <thead class="align-middle" style="background-color:#018bd3;color:#fff;font-weight:bold;">
                                   <tr>
                  <th style="width: 1px;" class="text-center">{{"#"}}</th>
                  <th class="text-left">
                      {{ "Öğrenci Adı" }}
                  </th>
                   <th class="text-left">
                      {{ "Önceki Derneği" }}
                  </th>
                   <th class="text-left">
                     {{ "Gittiği Dernek" }}
                  </th>
                    <th class="text-left">
                      {{ "Transfer Tarihi" }}
                  </th>
                </tr>
                                </thead>
                               <tbody>
                {% if customers_transfer %}
                  {% for customer in customers_transfer %}
                    <tr>
                      <td class="text-center">{{customer.row}}</td>
                      <td class="text-left ">
                      {% if store_id == 0 %}
                      <strong><a href="{{customer.edit}}">{{ customer.name }}</a></strong>
                      {% else %}
                      <strong>{{ customer.name }}</strong>
                      {% endif %}
                      </td>
                       <td class="text-center">
                        <div class="border rounded p-2 bg-light">
                        {{ customer.store1.name }}
                        </div>
                        </td>
                        <td class="text-center">
                        <div class="border rounded p-2 bg-light">
                        {{ customer.store2.name }}
                        </div>
                        </td>
                       <td class="text-left">{{ customer.date_added }}</td>
                    </tr>
                  {% endfor %}
                 {% else %}
                  <tr>
                    <td class="text-center" colspan="4">{{ text_no_results }}</td>
                  </tr>
                {% endif %}
              </tbody>
                            </table>
                        </div>

                         <div class="row mt-3">
  <div class="col-12 col-sm-6 d-flex justify-content-center justify-content-sm-start">
    {{ pagination }}
  </div>
  <div class="col-12 col-sm-6 small text-muted text-center text-sm-end">
    {{ results }}
  </div>
</div>
                </form>
            </div>
        </div>


    </div>

    {{footer}}
</main>
<script type="text/javascript"><!--
$('.auto-filter').on('change', function() {
   $('#cover-spin').show(0);
  url = 'index.php?route=customer/customer_transfer&user_token={{ user_token }}';

  if ($('input[name=\'filter_customer_id\']').val()) {
		url += '&filter_customer_id=' + encodeURIComponent($('input[name=\'filter_customer_id\']').val());
	}

	if ($('select[name=\'limit\']').val()) {
		url += '&limit=' + encodeURIComponent($('select[name=\'limit\']').val());
	}

	location = url;
});

$('#button-clear').on('click', function() {
	url = 'index.php?route=catalog/information&user_token={{ user_token }}';
	location = url;
});
//--></script>

<script type="text/javascript"><!--
$('input[name=\'filter_name\']').autocomplete({
	 
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=customer/customer/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['customer_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		 $('input[name=\'filter_name\']').val(item['label']);
      $('input[name=\'filter_customer_id\']').val(item['value']);
     $('input[name=\'filter_customer_id\']').trigger('change');
	}
});
//--></script>