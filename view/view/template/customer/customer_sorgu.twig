{{ header }}{{ column_left }}
<main class="page-content">
            <!--breadcrumb-->
            <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
             
              <div class="ps-3">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb mb-0 p-0">
				    {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
					{% endfor %}
                  </ol>
                </nav>
              </div>
              <div class="ms-auto">
                
              </div>
            </div>
            <!--end breadcrumb-->

              <div class="card">
               
                <div class="card-header py-3"> 
                  <div class="row g-1 align-items-center">

                  <div class="alert border-0 border-dark border-start border-42 bg-light-info alert-dismissible fade show py-1">
                    <div class="d-flex align-items-center">
                      <div class="fs-3 text-info"><i class="bi bi-info-circle-fill"></i>
                      </div>
                      <div class="ms-3">
                        <div class="text-dark">Sorgulamayı Telefon numarası (Başında sıfır olmadan 507..), Kimlik bilgisi veya E-posta adresinden herhangi biriyle yapabilirsiniz</div>
                      </div>
                    </div>
          
                  </div>
                    
                    <div class="position-relative">
                        <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-search"></i></div>
                        <input type="text" name="filter_name" value="{{filter_name}}" placeholder="{{"Teleon Numarası (507... gibi), Kimlik Bilgisi veya E-posta adresini yazınız."}}" id="input-customer" class="form-control form-control-lg ps-5" type="text" placeholder="Öğrenci adı yazınız...">
                        <input type="hidden" name="filter_customer_id" value="" placeholder="{{"Öğrenci Id"}}" id="input-customer-id" class="form-control btn-lg auto-complete" style="background:#BBF0F0;"/>
                    </div>
                   
                  </div>
                 </div>
                <div class="card-body">
                    <div class="row row-cols-1 row-cols-xl-2 row-cols-xxl-3">
                       {% for customer in customers %}
                       <div class="col">
                         <div class="card border shadow-none radius-10">
                           <div class="card-body">
                            <div class="d-flex align-items-center gap-3">
                              <div class="icon-box bg-light-primary border-0">
                                <i class="bi bi-person text-primary"></i>
                              </div>
                              <div class="info">
                                 <h5 class="mb-2">{{customer.name}}</h5>
                                 <p class="mb-1"><strong>Derneği :</strong> {{customer.store['name']}}</p>
                                 <p class="mb-1"><strong>E-Posta :</strong>{{customer.email}} </p>
                                 <p class="mb-1"><strong>Tel:</strong>{{customer.telephone}}</p>
                               
                                <!-- Select kutusu -->
                                <div class="mt-2 mb-3" {% if customer.store_id != store_id %} style="display:none;" {% endif %}>
                                  <select name="gstore_id" class="form-select ">
                                    <option value="">{{"--Gönderilecek Derneği Seçin.."}}</option>
                                    {% for store in stores %}
                                      <option value="{{store.store_id}}">{{store.name}}</option>
                                    {% endfor %}
                                  </select>
                                </div>

                                <p class="card-text referans" style="display:none;">
                                 <textarea name="referans" rows="4" placeholder="Öğrenci için bir referans yazısı yazınız." class="form-control" ></textarea>
                                </p>

                                <!-- Buton -->
                                <button type="button" id="button-transfer" value="1" name="{{customer.customer_id}}" for="{{customer.store_id}}" class="btn btn-rainbow-custom btn-glow-blue">
                                 
                                  Öğrenciyi Talep Et
                                </button>


                              </div>
                           </div>
                           </div>
                         </div>
                       </div>
                      {% endfor %}
                      
                  </div><!--end row-->
                   {% if customers_transfer and store_id == 0 %}
                  <div class="row">
                      <div class="col-12 col-lg-12">
                         <div class="card border shadow-none radius-10">
                           <div class="card-body">
                               <div class="table-responsive">
                                
                                 <table class="table align-middle mb-0">
                                   <thead class="table-light">
                                     <tr>
                                       <th>Öğrenci</th>
                                       <th>Şuanki Derneği</th>
                                       <th>Transfer İsteyen Dernek</th>
                                      
                                     </tr>
                                   </thead>
                                   <tbody>
                                    {% for transfer in customers_transfer %}
                                     <tr>
                                      <td>{{transfer.name}}</td>
                                      <td>{{transfer.old_store['name']}}</td>
                                      <td>{{transfer.new_store['name']}}</td>
                                    </tr>
                                    
                                     {% endfor %}
                                    
                                   </tbody>
                                 </table>
                                  
                               </div>
                           </div>
                         </div>
                      </div>
                    
                        </div>
  {% endif %}
                        


                     </div>
                  </div><!--end row-->

                </div>
              </div>
           {{footer}}
</main>
<script type="text/javascript"><!--
$('input[name=\'filter_name\']').autocomplete({
  
	'source': function(request, response) {
     
		$.ajax({
			url: 'index.php?route=setting/autocomplete/customerTransferautocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['customer_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
		 $('input[name=\'filter_customer_id\']').val(item['value']);
     $('input[name=\'filter_customer_id\']').trigger('change');
	}
});

//--></script> 
<script type="text/javascript"><!--
$('.auto-complete').on('change', function() {
	url = 'index.php?route=customer/customer_sorgu&user_token={{ user_token }}';

	var filter_customer_id = $('input[name=\'filter_customer_id\']').val();

	if (filter_customer_id) {
		url += '&filter_customer_id=' + encodeURIComponent(filter_customer_id);
	}

	location = url;
});

$('select[name=\'gstore_id\']').on('change', function() {
	$('.referans').show();
  $('.card-1').css('height','205px');
});
//--></script>

<script type="text/javascript"><!--
$('button[id=\'button-transfer\']').on('click', function() {
   var customer_id = $(this).attr('name');
   var store_id = $(this).attr('for');
   var tip = $(this).attr('value');
   var error = 'Lütfen Gönderilecek derneği seçiniz.';

   if (confirm('{{ text_confirm }}') == false) {    
        exit();
   }

   if (tip == 2) {    
       var store_id = $('select[name=\'gstore_id\']').val();
   }


	$.ajax({
		url: 'index.php?route=customer/customer_sorgu/addTransfer&user_token={{ user_token }}&customer_id=' + customer_id + '&store_id=' + store_id + '&tip=' + tip + '&referans=' + $('textarea[name=\'referans\']').val(),
		dataType: 'json',
       beforeSend: function() {
					$('#spinner' + customer_id).removeClass('visually-hidden');
				},
				
		   success: function(json) {
         $('.alert-dismissible').remove();
        
        if (json['error_permission']) {
         $('#alert').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error_permission'] +'</span>');
         $('#spinner' + customer_id).removeClass('visually-hidden');
        }
  
		  	if (json.success) {
          setTimeout(function() { $('#alert-message').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-exclamation-circle" ></i> ' + json.success + '</div>');}, 1000)
          setTimeout(function() {$('button[name=' + customer_id + ']').prop('disabled', true);}, 1000)
          setTimeout(function() {$('#spinner' + customer_id).removeClass('visually-hidden');}, 1000)
          setTimeout(function() {$('button[name=' + customer_id + ']').html('<i class="bi bi-check"></i> TAMAMLANDI');}, 1000)
			  }

		 },
		 
     error: function(xhr, ajaxOptions, thrownError) {
				alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
    }

	});
});
//--></script>