{{ header }}{{ column_left }}
<main id="page-content" class="page-content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-12 mx-auto">
        <div class="card">
          <div class="card-header py-3 bg-transparent">
            <div class="d-sm-flex align-items-center">
              <h5 class="mb-2 mb-sm-0">Form Özel Alanlar</h5>
              <div class="ms-auto">
                <button type="submit" form="form-custom-field" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
                  <i class="bi bi-save"></i>
                </button>
               
                <button type="button" class="btn btn-info text-white" data-bs-toggle="modal" data-bs-target="#modal-import">
                  <i class="bi bi-plus-square"></i> Toplu Ekle
                </button>
                 <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-secondary">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </a>
              </div>
            </div>
          </div>

          <div class="card-body">
            <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-custom-field">
              <fieldset>
                <legend class="mb-4">{{ text_custom_field }}</legend>
                
                <div class="row mb-3 required">
                  <label class="col-sm-2 col-form-label fw-bold">{{ entry_name }}</label>
                  <div class="col-sm-10">
                    {% for language in languages %}
                    <div class="input-group mb-2">
                      <span class="input-group-text"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
                      <input type="text" name="custom_field_description[{{ language.language_id }}][name]" value="{{ custom_field_description[language.language_id] ? custom_field_description[language.language_id].name }}" placeholder="{{ entry_name }}" class="form-control"/>
                    </div>
                    {% if error_name[language.language_id] %}
                    <div class="text-danger small">{{ error_name[language.language_id] }}</div>
                    {% endif %}
                    {% endfor %}
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-2 col-form-label" for="input-location">{{ entry_location }}</label>
                  <div class="col-sm-10">
                    <select name="location" id="input-location" class="form-select">
                      <option value="account" {% if location == 'account' %}selected{% endif %}>{{ text_account }}</option>
                      <option value="address" {% if location == 'address' %}selected{% endif %}>{{ text_address }}</option>
                    </select>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-2 col-form-label" for="input-type">{{ entry_type }}</label>
                  <div class="col-sm-10">
                    <select name="type" id="input-type" class="form-select">
                      <optgroup label="{{ text_choose }}">
                        <option value="select" {% if type == 'select' %}selected{% endif %}>{{ text_select }}</option>
                        <option value="radio" {% if type == 'radio' %}selected{% endif %}>{{ text_radio }}</option>
                        <option value="checkbox" {% if type == 'checkbox' %}selected{% endif %}>{{ text_checkbox }}</option>
                      </optgroup>
                      <optgroup label="{{ text_input }}">
                        <option value="text" {% if type == 'text' %}selected{% endif %}>{{ text_text }}</option>
                        <option value="textarea" {% if type == 'textarea' %}selected{% endif %}>{{ text_textarea }}</option>
                      </optgroup>
                      <optgroup label="{{ text_file }}">
                        <option value="file" {% if type == 'file' %}selected{% endif %}>{{ text_file }}</option>
                      </optgroup>
                      <optgroup label="{{ text_date }}">
                        <option value="date" {% if type == 'date' %}selected{% endif %}>{{ text_date }}</option>
                        <option value="time" {% if type == 'time' %}selected{% endif %}>{{ text_time }}</option>
                        <option value="datetime" {% if type == 'datetime' %}selected{% endif %}>{{ text_datetime }}</option>
                      </optgroup>
                    </select>
                  </div>
                </div>

                <div class="row mb-3" id="display-value">
                  <label class="col-sm-2 col-form-label" for="input-value">{{ entry_value }}</label>
                  <div class="col-sm-10">
                    <input type="text" name="value" value="{{ value }}" placeholder="{{ entry_value }}" id="input-value" class="form-control"/>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-2 col-form-label" for="input-value">{{ entry_required }}</label>
                 <div class="col-sm-10">
                  <div class="d-flex flex-wrap gap-3 mt-1">
                    {% set customer_group_row = 0 %}
                    {% for customer_group in customer_groups %}
                      <div class="form-check form-check-inline">
                        <input 
                          class="form-check-input" 
                          type="checkbox" 
                          name="custom_field_customer_group[{{ customer_group_row }}][required]" 
                          value="{{ customer_group.customer_group_id }}" 
                          id="required-group-{{ customer_group_row }}"
                          {% if customer_group.customer_group_id in custom_field_required %} checked="checked" {% endif %}
                        />
                        <label class="form-check-label" for="required-group-{{ customer_group_row }}">
                          {{ customer_group.name }}
                        </label>
                      </div>
                      {% set customer_group_row = customer_group_row + 1 %}
                    {% endfor %}
                  </div>
                </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-10">
                   <div class="form-check form-switch">
                {% if status %} {% set checked = 'checked' %} {% else %}{% set checked = '' %} {% endif %}
                <input class="form-check-input" type="checkbox" {{ checked }} name="status" value="1" id="statusSwitch" style="width:3rem;height:1.5rem;">
              </div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-2 col-form-label" for="input-sort-order">
                    <span data-bs-toggle="tooltip" title="{{ help_sort_order }}">{{ entry_sort_order }}</span>
                  </label>
                  <div class="col-sm-10">
                    <input type="text" name="sort_order" value="{{ sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
                  </div>
                </div>
              </fieldset>

              <hr class="my-4">

              <div id="custom-field-value">
                <fieldset>
                  <legend>{{ text_value }}</legend>
                  <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle">
                      <thead class="table-light">
                        <tr>
                          <th class="required">{{ entry_custom_value }}</th>
                          <th>{{ entry_group }}</th>
                          <th style="width: 10%;">{{ entry_sort_order }}</th>
                          <th style="width: 10%;">Durumu</th>
                          <th style="width: 50px;">İşlem</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% set custom_field_value_row = 0 %}
                        {% for custom_field_value in custom_field_values %}
                        <tr id="custom-field-value-row{{ custom_field_value_row }}">
                          <td>
                            <input type="hidden" name="custom_field_value[{{ custom_field_value_row }}][custom_field_value_id]" value="{{ custom_field_value.custom_field_value_id }}"/>
                            {% for language in languages %}
                            <div class="input-group mb-1">
                              <input type="text" name="custom_field_value[{{ custom_field_value_row }}][custom_field_value_description][{{ language.language_id }}][name]" value="{{ custom_field_value.custom_field_value_description[language.language_id] ? custom_field_value.custom_field_value_description[language.language_id].name }}" placeholder="{{ entry_custom_value }}" class="form-control form-control-sm"/>
                            </div>
                            {% if error_custom_field_value[custom_field_value_row][language.language_id] %}
                            <div class="text-danger small">{{ error_custom_field_value[custom_field_value_row][language.language_id] }}</div>
                            {% endif %}
                            {% endfor %}
                          </td>
                          <td>
                            <input type="text" name="custom_field_value[{{ custom_field_value_row }}][group]" value="{{ custom_field_value.custom_field_value_description[2].group }}" placeholder="{{ entry_group }}" class="form-control form-control-sm"/>
                          </td>
                          <td>
                            <input type="text" name="custom_field_value[{{ custom_field_value_row }}][sort_order]" value="{{ custom_field_value.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control form-control-sm"/>
                          </td>
                          <td class="text-center">
                            <div class="form-check form-switch d-inline-block">
                              <input class="form-check-input" type="checkbox" name="custom_field_value[{{ custom_field_value_row }}][custom_field_value_description][2][status]" value="1" {% if custom_field_value.custom_field_value_description[2].status %}checked{% endif %}>
                            </div>
                          </td>
                          <td class="text-center">
                            <button type="button" onclick="$('#custom-field-value-row{{ custom_field_value_row }}').remove();" data-bs-toggle="tooltip" title="{{ button_remove }}" class="btn btn-outline-danger btn-sm">
                              <i class="bi bi-dash-circle"></i>
                            </button>
                          </td>
                        </tr>
                        {% set custom_field_value_row = custom_field_value_row + 1 %}
                        {% endfor %}
                      </tbody>
                      <tfoot>
                        <tr>
                          <td colspan="4"></td>
                          <td class="text-center">
                            <button type="button" onclick="addCustomFieldValue();" data-bs-toggle="tooltip" title="{{ button_custom_field_value_add }}" class="btn btn-primary btn-sm">
                              <i class="bi bi-plus-circle"></i>
                            </button>
                          </td>
                        </tr>
                      </tfoot>
                    </table>
                  </div>
                </fieldset>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  {{footer}}
</main>

<div class="modal fade" id="modal-import" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importModalLabel">Toplu Metin Ekle</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="form-import">
          <div class="mb-3">
            <label for="input-text" class="form-label text-primary fw-bold">Eklenecek metin:</label>
            <textarea class="form-control" name="text" rows="6" id="input-text" placeholder="Grup 1, Grup 2, Grup 3..."></textarea>
            <div class="form-text mt-2 small text-muted">Lütfen değerleri aralarında (,) virgül kullanarak yapıştırınız.</div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
        <button type="button" id="button-creat" class="btn btn-primary">Oluştur</button>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
$('select[name=\'type\']').on('change', function() {
	if (this.value == 'select' || this.value == 'radio' || this.value == 'checkbox') {
		$('#custom-field-value').show();
		$('#display-value, #display-validation').hide();
	} else {
		$('#custom-field-value').hide();
		$('#display-value, #display-validation').show();
	}

	if (this.value == 'date') {
		$('#display-value > div').html('<div class="input-group date"><input type="text" name="value" value="' + $('#input-value').val() + '" placeholder="{{ entry_value }}" data-date-format="YYYY-MM-DD" id="input-value" class="form-control" /><div class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></div></div>');
	} else if (this.value == 'time') {
		$('#display-value > div').html('<div class="input-group time"><input type="text" name="value" value="' + $('#input-value').val() + '" placeholder="{{ entry_value }}" data-date-format="HH:mm" id="input-value" class="form-control" /><div class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></div></div>');
	} else if (this.value == 'datetime') {
		$('#display-value > div').html('<div class="input-group datetime"><input type="text" name="value" value="' + $('#input-value').val() + '" placeholder="{{ entry_value }}" data-date-format="YYYY-MM-DD HH:mm" id="input-value" class="form-control" /><div class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></div></div>');
	} else if (this.value == 'textarea') {
		$('#display-value > div').html('<textarea name="value" placeholder="{{ entry_value }}" id="input-value" class="form-control">' + $('#input-value').val() + '</textarea>');
	} else {
		$('#display-value > div').html('<input type="text" name="value" value="' + $('#input-value').val() + '" placeholder="{{ entry_value }}" id="input-value" class="form-control" />');
	}

	$('.date').datetimepicker({
		language: '{{ datepicker }}',
		pickTime: false
	});

	$('.time').datetimepicker({
		language: '{{ datepicker }}',
		pickDate: false
	});

	$('.datetime').datetimepicker({
		language: '{{ datepicker }}',
		pickDate: true,
		pickTime: true
	});
});

$('select[name=\'type\']').trigger('change');

var custom_field_value_row = {{ custom_field_value_row }};

function addCustomFieldValue() {
	html = '<tr id="custom-field-value-row' + custom_field_value_row + '">';
	html += '  <td class="text-left" style="width: 50%;"><input type="hidden" name="custom_field_value[' + custom_field_value_row + '][custom_field_value_id]" value="" />';
  {% for language in languages %}
	html += ' <input type="text" name="custom_field_value[' + custom_field_value_row + '][custom_field_value_description][{{ language.language_id }}][name]" value="" placeholder="{{ entry_custom_value }}" class="form-control" />';
  {% endfor %}
	html += '  </td>';
	html += '  <td class="text-right"><input type="text" name="custom_field_value[' + custom_field_value_row + '][group]" value="default" placeholder="{{ entry_group }}" class="form-control" /></td>';
	html += '  <td class="text-right" style="width: 10%;"><input type="text" name="custom_field_value[' + custom_field_value_row + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" class="form-control" /></td>';
	html += '  <td class="text-right" style="width: 10%;"></td>';
  html += '  <td class="text-left"><button type="button" onclick="$(\'#custom-field-value-row' + custom_field_value_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-dash-circle"></i></button></td>';
	html += '</tr>';

	$('#custom-field-value tbody').append(html);

	custom_field_value_row++;
}

//--></script>


<script>
var custom_field_value_row = $('#custom-field-value tbody tr').length; // Mevcut satır sayısını al
$('#button-creat').on('click', function () {

    let textareaVal = $('textarea[name="text"]').val();
    if (!textareaVal.trim()) return;

    let values = textareaVal.split(',');
    let sort_order = custom_field_value_row + 1; // Mevcut satır sayısına göre başlat

    values.forEach(function (val) {
        let trimmedVal = val.trim();
        if (trimmedVal === '') return;

        let html = '<tr id="custom-field-value-row' + custom_field_value_row + '">';
        html += '<td class="text-left" style="width: 50%;">';
        html += '<input type="hidden" name="custom_field_value[' + custom_field_value_row + '][custom_field_value_id]" value="" />';

        {% for language in languages %}
        html += '<input type="text" name="custom_field_value[' + custom_field_value_row + '][custom_field_value_description][{{ language.language_id }}][name]" value="' + trimmedVal + '" placeholder="{{ entry_custom_value }}" class="form-control" />';
        {% endfor %}
        html += '</td>';

        html += '<td class="text-right">';
        html += '<input type="text" name="custom_field_value[' + custom_field_value_row + '][group]" value="default" placeholder="{{ entry_group }}" class="form-control" />';
        html += '</td>';

        html += '<td class="text-right" style="width: 10%;">';
        html += '<input type="text" name="custom_field_value[' + custom_field_value_row + '][sort_order]" value="' + sort_order + '" placeholder="{{ entry_sort_order }}" class="form-control" />';
        html += '</td>';

        html += '<td class="text-right" style="width: 10%;">';
        html += '<input type="checkbox" id="switch-checkbox" name="custom_field_value[' + custom_field_value_row + '][custom_field_value_description][2][status]" value="1" data-toggle="toggle" data-onstyle="success" data-offstyle="danger" data-size="sm" checked style="width: 10%;display:none;">';
        html += '</td>';

        html += '<td class="text-left">';
        html += '<button type="button" onclick="$(\'#custom-field-value-row' + custom_field_value_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-dash-circle"></i></button>';
        html += '</td>';

        html += '</tr>';

        $('#modal-import').modal('hide');
        $('#custom-field-value tbody').append(html);

        custom_field_value_row++;
        sort_order++;
    });

    $('textarea[name="text"]').val('');
});

</script>