{{ header }}{{ column_left }}
<main id="page-content" class="page-content">
  <div class="row">
    <div class="col-lg-12 mx-auto">
      <div class="card">
        <div class="card-header py-3 bg-transparent">
          <div class="d-sm-flex align-items-center">
            <h5 class="mb-2 mb-sm-0">Kullanıcı Düzenleme Formu</h5>
            <div class="ms-auto">
              <button type="submit" form="form-user" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary btn-sm">
                <i class="bi bi-save"></i>
              </button>
               <a href="{{ cancel }}" type="button" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light border border-dark shadow-sm bg-white btn-sm">
                <i class="bi bi-arrow-counterclockwise"></i>
              </a>
            </div>
          </div>
        </div>

        <div class="card-body">
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-user" class="row g-4">
            
            <div class="col-12">
              <label class="form-label fw-bold" for="input-name">{{ entry_username }}</label>
               <input type="text" name="username" value="{{ username }}" placeholder="{{ entry_username }}" id="input-username" class="form-control"/>
              {% if error_username %}
                <div class="text-danger">{{ error_username }}</div>
              {% endif %}
            </div>

             <div class="col-12 col-md-6">
              <label class="form-label fw-bold" for="input-name">{{ entry_firstname }}</label>
              <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname" class="form-control"/>
              {% if error_firstname %}
                <div class="text-danger">{{ error_firstname }}</div>
              {% endif %}
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-bold" for="input-name">{{ entry_lastname }}</label>
              <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" class="form-control"/>
              {% if error_lastname %}
                <div class="text-danger">{{ error_lastname }}</div>
              {% endif %}
            </div>

            <div class="col-12">
              <label class="form-label fw-bold" for="input-name">{{ entry_email }}</label>
               <input type="text" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email" class="form-control"/>
              {% if error_email %}
                <div class="text-danger">{{ error_email }}</div>
              {% endif %}
            </div>

            <div class="col-12" {% if level != 1 %} style="display:none;" {% endif %}>
              <label class="form-label fw-bold" for="input-name">{{ entry_user_group }}</label>
               <select name="user_group_id" id="input-user-group" class="form-select">
                {% for user_group in user_groups %}
                <option value="{{ user_group.user_group_id }}" {% if user_group.user_group_id == user_group_id %} selected="selected" {% endif %}>{{ user_group.name }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="col-12" id="store" {% if level != 1 %} style="display:none;" {% endif %}>
              <label class="form-label fw-bold" for="input-name">{{ entry_dernek }}</label>
               <select name="store_id" class="form-select">
               {% if level == 1 %}
               <option value="0"{% if level == 1 %}  selected="selected"  {% endif %}>{{ "UDEF" }}</option>
               {% endif %}
                {% for store in stores %}
                  <option value="{{ store.store_id }}" class="store store-2"{% if store.store_id == store_id %}  selected="selected"  {% endif %}>{{ store.name }}</option>
                {% endfor %}
              </select>
            </div>

           
            <div class="col-12" id="parent-category" {% if user_parent_id != 1 %}  style="display:none;" {% endif %}>
              <label class="form-label fw-bold" for="input-name">{{ "Kategorisi" }}</label>
               <select name="parent_id" class="form-select">
                <option value="1" {% if parent_id == 1 %}  selected="selected" {% endif %}>{{ "Genel Yönetici" }}</option>
                <option value="2" hidden {% if parent_id == 2 %}  selected="selected"  {% endif %}>{{ "Personel" }}</option>
                <option value="3"  {% if parent_id == 3 %}  selected="selected"  {% endif %}>{{ "Kullanıcı" }}</option>
              </select>
            </div>

           
            <div class="col-12" style="display:none;">
              <label class="form-label fw-bold" for="input-name">{{ entry_image }}</label>
               <div class="profile-avatar text-start">
                  <a href="javascript:void(0);" id="button-thumb-image" class="thumbnail">
                    <img src="{{ thumb }}" id="thumb-img" class="border border-primary border-primary rounded-lg shadow"  width="120" height="120"  title="Resim eklemek için tıklayın" class="rounded-circle"></a>
                    <input type="hidden" name="image" value="{{ image }}" id="input-image"/>
                </div>
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-bold" for="input-name">{{ entry_password }}</label>
               <input type="password" name="password" value="{{ password }}" placeholder="{{ entry_password }}" id="input-password" class="form-control" autocomplete="off"/>
              {% if error_password %}
                <div class="text-danger">{{ error_password }}</div>
              {% endif %}
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-bold" for="input-name">{{ entry_confirm }}</label>
              <input type="password" name="confirm" value="{{ confirm }}" placeholder="{{ entry_confirm }}" id="input-confirm" class="form-control"/>
              {% if error_confirm %}
                <div class="text-danger">{{ error_confirm }}</div>
              {% endif %}
            </div>
        
            <div class="col-12">
              <label class="form-label d-block">{{ entry_status }} (Aktif / Pasif)</label>
              <div class="form-check form-switch">
                {% if status %} {% set checked = 'checked' %} {% else %}{% set checked = '' %} {% endif %}
                <input class="form-check-input" type="checkbox" {{ checked }} name="status" value="1" id="statusSwitch" style="width:3rem;height:1.5rem;">
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div>
  {{ footer }}
</main>
<script>
$('input[name^=\'filter_personel\']').autocomplete({
    'source': function(request, response) {
      $.ajax({
        url: 'index.php?route=setting/autocomplete/autocompletePersoneller&user_token={{ user_token }}&filter_personel=' +  encodeURIComponent(request),
       dataType: 'json',
        success: function(json) {
          
          response($.map(json, function(item) {
            return {
              label: item['name'],
              value: item['personel_id'],
            }
          }));
        }
      });
    },

    'select': function(item) {
      $('input[name^=\'filter_personel\']').val(item['label']);
      $('input[name^=\'filter_personel_id\']').val(item['value']);
  
    }
  });
  </script>
<script>
var error_warning = '{{error_warning}}';
var success = '{{success}}';
$(document).ready(function() {
  if(error_warning) {
     alerterror(error_warning);
  }

  if (success) {
    alertsuccess(success);
  }
});
</script>
