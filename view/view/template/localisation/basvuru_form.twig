	editor1cfg.toolbar = "basic";
	editor1cfg.lang = "tr"; // Türkçe dil ayarı
	editor1cfg.removeButtons = ["images", "video"];
  editorResizeMode: "none";
	var editor1 = new RichTextEditor("#textarea-editor", editor1cfg);
</script>

<script>
$(document).ready(function () {
	$("rte-toolbar-button[rte-cmd-name='togglemore']").css({"pointer-events": "none","opacity": "0.4"});
});

</script>

<script>
var error_warning = '{{error_warning}}';
var error_filename = '{{error_filename}}';
var error_question = '{{error_question}}';
if(error_filename) {
  error_warning = error_filename;
  $('input[name=\'file\']').prop('checked',true);
   $('#filename').show();
}

if(error_question) {
  error_warning = error_question;
  $('input[name=\'ques\']').prop('checked',true);
   $('#question').show();
}


$(document).ready(function() {
  if(error_warning) {
    alerterror(error_warning);
  }
});
</script>

<style>
rte-floatpanel.rte-floatpanel-paragraphop {
  display: none !important;
}
</style>
