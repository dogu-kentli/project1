$(document).ready(function () {
	$("rte-toolbar-button[rte-cmd-name='togglemore']").css({"pointer-events": "none","opacity": "0.4"});
});

</script>

<script>
var error_warning = '';
var error_filename = '{{error_filename}}';
var error_question = '{{error_question}}';
if(error_filename) {
  error_warning = error_filename;
  $('input[name=\'file\']').prop('checked',true);
   $('#filename').show();
}

if(error_question) {
  error_warning = error_question;
  $('input[name=\'ques\']').prop('checked',true);
   $('#question').show();
}


$(document).ready(function() {
     if(error_warning) {
      $('#alert').prepend(
            '<div class="alert border-0 border-danger border-start border-2 bg-light-danger alert-dismissible fade show py-2">' +
              '<div class="d-flex align-items-center">' +
                '<div class="fs-3 text-danger"><i class="bi bi-x-circle-fill"></i></div>' +
                '<div class="ms-3"><div class="text-dynamic">' + error_warning + '</div></div>' +
              '</div>' +
              '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
            '</div>'
        );
    }
});
</script>
<script>
var code = '{{code}}';
$(document).ready(function () {
  if ($('#input-secim').is(':checked')) {
    $('#button-copy').show();
    $('#input-code').val(code);
  } else {
    $('#button-copy').hide();
    $('#input-code').val('');
  }

   $('#input-secim').on('change', function () {
    if ($(this).is(':checked')) {
      $('#button-copy').show();
      $('#input-code').val(code);
    } else {
      $('#button-copy').hide();
      $('#input-code').val('');
    }
  });
});
</script>
<script>
  $('#button-copy').on('click', function () {
    $('input[name="form_url"]').attr('type','text');
    var copyText = $('input[name="form_url"]');
    copyText.select();
    document.execCommand("copy");

     $('input[name="form_url"]').attr('type','hidden');

    // Tooltip konumlandırma
    var button = $(this);
    var tooltip = $('#copy-tooltip');
    var offset = button.position();

    tooltip.css({
      top: offset.top - tooltip.outerHeight() - 8,
      left: offset.left + (button.outerWidth() / 2) - (tooltip.outerWidth() / 2)
    });

    // Göster ve sonra gizle
    tooltip.fadeIn(200);
    setTimeout(function () {
      tooltip.fadeOut(300);
    }, 2000);
  });
</script>

<style>

#copy-tooltip {
    position: absolute;
    background-color: #333;
    color: #fff;
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 13px;
    white-space: nowrap;
    z-index: 1000;
    display: none;
    transform: translateY(-100%);
}
</style>

