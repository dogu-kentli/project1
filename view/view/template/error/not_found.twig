{{ header }}{{ column_left }}
<main class="page-content">
            <!--breadcrumb-->
            <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        
              <div class="ps-3">
                <nav aria-label="breadcrumb">
                   <ol class="breadcrumb mb-0 p-0">
				           {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{home}}"><i class="bx bx-home-alt"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{breadcrumb.text}}</li>
					          {% endfor %}
                  </ol>
                </nav>
              </div>
              <div class="ms-auto">
                
              </div>
            </div>
            <!--end breadcrumb-->

            <div class="error-404 d-flex align-items-center justify-content-center">
              <div class="container">
                <div class="card py-5">
                  <div class="row g-0">
                    <div class="col-xl-5">
                      <div class="card-body p-4">
                        <h1 class="display-1"><span class="text-warning">5</span><span class="text-danger">0</span><span class="text-primary">0</span></h1>
                        <h2 class="font-weight-bold display-4">{{ heading_title }}</h2>
                        <p>{{ text_not_found }}!</p>
                        <div class="mt-5">	
                        <a href="{{home}}" class="btn btn-lg btn-primary px-md-5 radius-30">Devam Et</a>
                        
                        </div>
                      </div>
                    </div>
                    <div class="col-xl-7">
                      <img src="assets/images/error/505-error.png" class="img-fluid" alt="">
                    </div>
                  </div>
                  <!--end row-->
                </div>
              </div>
            </div>
          </main>
{{ footer }}