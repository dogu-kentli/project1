<script>
$('#button-toplanti-generate').on('click', function() {
    var $btn = $(this);
    $.ajax({
        url: 'index.php?route=toplanti/toplanti/save&user_token={{ user_token }}&toplanti_no=' + $('input[name=\'toplanti_no\']').val(),
        type: 'post',
        dataType: 'json',
        data: $('#form-toplanti').serialize(),
        beforeSend: function() {
            $btn.buttonanimate('loading');
        },
        complete: function() {
            $btn.buttonanimate('reset');
        },
        success: function(json) {
            if (json.error.warning) {
                alerterror(json.error.warning);
            }

            if (json.success) {
                $('#modal-toplanti').modal('hide');
                $('#form-toplanti-data').load('index.php?route=toplanti/toplanti/dataToplanti&user_token={{ user_token }}' + '&toplanti_history_id=' + json['toplanti_history_id']);
                $('#step-1,#buttons').hide();
                $('#step-2').show();
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
    });
});
</script>
<script>
var error_warning = '{{error_warning}}';
var success = '{{success}}';
$(document).ready(function() {
     if(error_warning) {
      alerterror(error_warning);
     }

     if (success) {
	  alertsuccess(success);
    }
});
</script>